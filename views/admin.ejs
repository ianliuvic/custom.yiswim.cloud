<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin.css?v=<%= Date.now() %>">
</head>
<body>

    <header class="adm-header">
        <div class="adm-header-left">
            <span class="adm-header-title">Hongxiu Admin Panel</span>
        </div>
        <div class="adm-header-right">
            <span class="adm-user-info">
                <strong><%= user.username %></strong>
                <a href="/" class="adm-nav-link">Back to Site</a>
                <a href="/logout" class="adm-nav-link adm-logout">Log Out</a>
            </span>
        </div>
    </header>

    <main class="adm-main">
        <!-- Tab Navigation -->
        <div class="adm-tabs">
            <button class="adm-tab active" data-tab="inquiries" onclick="switchAdminTab('inquiries')">Inquiries</button>
            <button class="adm-tab" data-tab="feedbacks" onclick="switchAdminTab('feedbacks')">Feedbacks</button>
        </div>

        <!-- ===== Inquiries Tab ===== -->
        <div id="tab-inquiries" class="adm-tab-content">
        <div class="adm-toolbar">
            <div class="adm-filters">
                <button class="adm-filter-btn active" data-filter="all">All</button>
                <button class="adm-filter-btn" data-filter="active">Active</button>
                <button class="adm-filter-btn" data-filter="deleted">Deleted</button>
            </div>
            <div class="adm-search">
                <input type="text" id="searchInput" placeholder="Search Inquiry No. / Username / Email" />
                <button id="searchBtn">Search</button>
            </div>
        </div>

        <div class="adm-batch-bar" id="batchBar">
            <span id="batchCount">Selected 0 item(s)</span>
            <button class="adm-btn adm-btn-restore" id="batchRestoreBtn" onclick="batchRestore()">Batch Restore</button>
            <button class="adm-btn adm-btn-danger" id="batchDeleteBtn" onclick="batchHardDelete()">Batch Hard Delete</button>
            <button class="adm-btn adm-btn-cancel" onclick="clearSelection()">Clear Selection</button>
        </div>

        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th style="width:36px"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this.checked)"></th>
                        <th>Inquiry No.</th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Files</th>
                        <th>Created At</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="inquiryBody"></tbody>
            </table>
        </div>

        <div class="adm-pagination" id="pagination"></div>
        </div>
        <!-- End Inquiries Tab -->

        <!-- ===== Feedbacks Tab ===== -->
        <div id="tab-feedbacks" class="adm-tab-content" style="display:none;">
        <div class="adm-toolbar">
            <div class="adm-filters">
                <button class="adm-fb-filter-btn active" data-filter="all">All</button>
                <button class="adm-fb-filter-btn" data-filter="pending">Pending</button>
                <button class="adm-fb-filter-btn" data-filter="accepted">Accepted</button>
                <button class="adm-fb-filter-btn" data-filter="rejected">Rejected</button>
                <button class="adm-fb-filter-btn" data-filter="rewarded">Rewarded</button>
            </div>
            <div class="adm-search">
                <input type="text" id="fbSearchInput" placeholder="Search Username / Email / Content" />
                <button id="fbSearchBtn">Search</button>
            </div>
        </div>

        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Type</th>
                        <th>Content</th>
                        <th>Screenshots</th>
                        <th>Coupon</th>
                        <th>Created At</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="feedbackBody"></tbody>
            </table>
        </div>

        <div class="adm-pagination" id="fbPagination"></div>
        </div>
        <!-- End Feedbacks Tab -->
    </main>

    <!-- 询盘详情面板 -->
    <div id="detailPanel" class="adm-detail-panel" style="display:none;">
        <div class="adm-detail-hero">
            <div class="adm-detail-hero-top">
                <button class="adm-back-btn" onclick="closeDetail()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to List
                </button>
                <span id="detailStatus" class="adm-badge"></span>
            </div>
            <div class="adm-detail-hero-title">
                <h2 id="detailTitle"></h2>
                <button class="adm-detail-action-btn" onclick="exportPDF()" title="Export">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Export
                </button>
                <button class="adm-detail-action-btn" onclick="exportZIP()" title="ExportZIP">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Export ZIP
                </button>
            </div>
            <div id="detailStats" class="adm-detail-stats"></div>
        </div>
        <div id="detailContent" class="adm-detail-content"></div>
    </div>

    <!-- Feedback Detail Panel -->
    <div id="fbDetailPanel" class="adm-detail-panel" style="display:none;">
        <div class="adm-detail-hero">
            <div class="adm-detail-hero-top">
                <button class="adm-back-btn" onclick="closeFbDetail()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to List
                </button>
                <span id="fbDetailStatus" class="adm-badge"></span>
            </div>
            <div class="adm-detail-hero-title">
                <h2 id="fbDetailTitle"></h2>
            </div>
            <div id="fbDetailStats" class="adm-detail-stats"></div>
        </div>
        <div id="fbDetailContent" class="adm-detail-content"></div>
    </div>

    <!-- Confirmation Dialog -->
    <div class="adm-modal-mask" id="modalMask">
        <div class="adm-modal">
            <div class="adm-modal-title" id="modalTitle"></div>
            <div class="adm-modal-body" id="modalBody"></div>
            <div class="adm-modal-footer">
                <button class="adm-btn adm-btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="adm-btn adm-btn-confirm" id="modalConfirm">Confirm</button>
            </div>
        </div>
    </div>

    <script src="/admin.js?v=<%= Date.now() %>"></script>
</body>
</html>
