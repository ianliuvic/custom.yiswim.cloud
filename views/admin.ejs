<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/admin.css">
</head>
<body>

    <header class="adm-header">
        <div class="adm-header-left">
            <span class="adm-header-title">Hongxiu 管理后台</span>
        </div>
        <div class="adm-header-right">
            <span class="adm-user-info">
                <strong><%= user.username %></strong>
                <a href="/" class="adm-nav-link">返回前台</a>
                <a href="/logout" class="adm-nav-link adm-logout">退出</a>
            </span>
        </div>
    </header>

    <main class="adm-main">
        <div class="adm-toolbar">
            <div class="adm-filters">
                <button class="adm-filter-btn active" data-filter="all">全部</button>
                <button class="adm-filter-btn" data-filter="active">正常</button>
                <button class="adm-filter-btn" data-filter="deleted">已删除</button>
            </div>
            <div class="adm-search">
                <input type="text" id="searchInput" placeholder="搜索询盘号 / 用户名 / 邮箱" />
                <button id="searchBtn">搜索</button>
            </div>
        </div>

        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>询盘号</th>
                        <th>用户</th>
                        <th>邮箱</th>
                        <th>文件数</th>
                        <th>创建时间</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody id="inquiryBody"></tbody>
            </table>
        </div>

        <div class="adm-pagination" id="pagination"></div>
    </main>

    <!-- 确认弹窗 -->
    <div class="adm-modal-mask" id="modalMask">
        <div class="adm-modal">
            <div class="adm-modal-title" id="modalTitle"></div>
            <div class="adm-modal-body" id="modalBody"></div>
            <div class="adm-modal-footer">
                <button class="adm-btn adm-btn-cancel" onclick="closeModal()">取消</button>
                <button class="adm-btn adm-btn-confirm" id="modalConfirm">确认</button>
            </div>
        </div>
    </div>

    <script src="/admin.js"></script>
</body>
</html>
