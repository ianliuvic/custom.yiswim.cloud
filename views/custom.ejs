        // 4. 辅助选择函数
        function selectSewingMethod(sectionKey, methodName, el) {
            labelConfig.sections[sectionKey].method = methodName;
            el.parentNode.querySelectorAll('.sewing-card').forEach(c => c.classList.remove('selected'));
            el.classList.add('selected');
            updateLabelSummary();
        }

        function selectLabelPlacement(pos, el) {
            labelConfig.placement = pos;
            document.querySelectorAll('.hotspot').forEach(h => h.classList.remove('selected'));
            el.classList.add('selected');
            updateLabelSummary();
        }

        // 5. 文件上传与预览逻辑 (适配多区块)
        function handleLabelSectionFiles(input, sectionKey) {
            const files = Array.from(input.files);
            const data = labelConfig.sections[sectionKey];
            
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) { showToast(`文件 ${file.name} 超过 20MB`, 'error'); return; }
                if (!data.files.some(f => f.name === file.name && f.size === file.size)) {
                    data.files.push(file);
                }
            });

            document.getElementById(`name-${sectionKey}`).innerText = `已选 ${data.files.length} 个文件`;
            renderLabelSectionPreviews(sectionKey);
            updateLabelSummary();
            input.value = '';
        }

        function renderLabelSectionPreviews(sectionKey) {
            const grid = document.getElementById(`preview-${sectionKey}`);
            if(!grid) return;
            grid.innerHTML = '';
            
            labelConfig.sections[sectionKey].files.forEach((file, index) => {
                const isImage = file.type.startsWith('image/');
                const ext = file.name.split('.').pop().toUpperCase();
                let content = isImage 
                    ? `<img src="${URL.createObjectURL(file)}" onclick="openOemPreview(this.src, '${file.name}')">` 
                    : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:#64748b;font-size:10px;font-weight:bold;">${ext}</div>`;

                grid.insertAdjacentHTML('beforeend', `
                    <div class="oem-preview-item" style="width:50px; height:50px;">
                        ${content}
                        <button type="button" class="oem-preview-remove" onclick="removeLabelSectionFile('${sectionKey}', ${index})">&times;</button>
                    </div>
                `);
            });
        }

        function removeLabelSectionFile(sectionKey, index) {
            labelConfig.sections[sectionKey].files.splice(index, 1);
            const data = labelConfig.sections[sectionKey];
            document.getElementById(`name-${sectionKey}`).innerText = data.files.length > 0 ? `已选 ${data.files.length} 个文件` : '选择 AI / PDF / PNG';
            renderLabelSectionPreviews(sectionKey);
            updateLabelSummary();
        }

        // 6. 交互式地图切换 (连体/分体)
        function changeMapType(type) {
            const mapContainer = document.getElementById('placement-map');
            const switcher = mapContainer.nextElementSibling.querySelector('.mode-switcher');
            
            switcher.querySelectorAll('.mode-option').forEach(opt => {
                opt.classList.remove('active');
                if(opt.innerText.includes(type === 'onepiece' ? '连体' : '分体')) opt.classList.add('active');
            });

            const mapImg = mapContainer.querySelector('.map-svg');
            const onepieceSvg = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 120'%3E%3Cpath d='M30,20 Q50,10 70,20 L80,50 Q80,80 50,110 Q20,80 20,50 Z' fill='none' stroke='%23333' stroke-width='1'/%3E%3C/svg%3E";
            const bikiniSvg = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 120'%3E%3Cpath d='M30,20 Q50,10 70,20 L80,40 Q50,35 20,40 Z M30,70 Q50,60 70,70 L80,90 Q50,115 20,90 Z' fill='none' stroke='%23333' stroke-width='1'/%3E%3C/svg%3E";
            mapImg.src = (type === 'onepiece') ? onepieceSvg : bikiniSvg;

            mapContainer.querySelectorAll('.hotspot').forEach(h => h.remove());

            const spots = (type === 'onepiece') ? [
                { name: '领后中', top: '20%', left: '50%' },
                { name: '左侧缝', top: '60%', left: '20%' },
                { name: '后腰内侧', top: '85%', left: '50%' }
            ] : [
                { name: '上衣后中', top: '15%', left: '50%' },
                { name: '泳裤后腰', top: '75%', left: '50%' },
                { name: '上衣左侧', top: '30%', left: '20%' }
            ];

            spots.forEach(s => {
                const hotspot = document.createElement('div');
                hotspot.className = 'hotspot';
                hotspot.style.top = s.top; hotspot.style.left = s.left;
                hotspot.onclick = function() { selectLabelPlacement(s.name, this); };
                hotspot.innerHTML = `<span class="hotspot-label">${s.name}</span>`;
                if(labelConfig.placement === s.name) hotspot.classList.add('selected');
                mapContainer.appendChild(hotspot);
            });
        }

        // 7. 汇总更新
        function updateLabelSummary() {
            const st = document.getElementById('sum-trim-label');
            const isEnabled = document.querySelector('input[name="need_label"][value="yes"]').checked;
            
            if (!isEnabled) {
                st.innerText = '不需要';
                st.style.color = '#64748b'; st.style.fontWeight = 'normal';
                return;
            }
        
            const modeText = labelConfig.mode === 'combined' ? '集成标' : '分体标';
            const matText = labelConfig.material;
            
            // 检查是否有文字或文件
            const hasBrandContent = labelConfig.sections.brand.text.trim() !== '' || labelConfig.sections.brand.files.length > 0;
            const hasCareContent = labelConfig.mode === 'split' ? (labelConfig.sections.care.text.trim() !== '' || labelConfig.sections.care.files.length > 0) : false;
            
            const contentStatus = (hasBrandContent || hasCareContent) ? '内容已就绪' : '待补充内容';
        
            st.innerHTML = `<div style="text-align:right;">${modeText} | ${matText}<br><span style="font-size:10px; opacity:0.8;">位置: ${labelConfig.placement} | ${contentStatus}</span></div>`;
            st.style.color = 'var(--primary-color)'; st.style.fontWeight = 'bold';
        }


        // 初始化加载一次
        document.addEventListener('DOMContentLoaded', () => { 
            if(currentStep === 3) {
                renderLabelUnifiedMaterials(); 
                renderLabelDynamicDetails(); 
            }
        });

