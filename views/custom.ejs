                                    <div class="upload-label-group"><span id="name-${conf.key}" style="font-size:11px; color:#94a3b8;">${data.files.length > 0 ? '已选 '+data.files.length+' 个文件' : '选择 AI / PDF / PNG'}</span></div>
                                    <input type="file" id="file-${conf.key}" class="hidden" multiple onchange="handleLabelSectionFiles(this, '${conf.key}')">
