                    const defaultTextMap = {
                        'design': '点击上传 AI / PDF / 高清图',
                        'string': '点击上传',
                        'default': '点击上传参考文件'
                    };
                    nameEl.innerText = defaultTextMap[type] || defaultTextMap['default'];
                }
            }
            
            // 4. 重新渲染
            renderHangtagPreviews(type);
            updateHangtagSummary();
        }


