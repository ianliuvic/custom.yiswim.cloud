        }
        
        // 9. жӣҙж–°дҫ§иҫ№ж ҸжұҮжҖ» (ж”ҜжҢҒйғЁд»¶з»„еҗҲдёҺдё»/жҙ—ж°ҙеҲҶејҖжҸҗзӨә)
        function updateLabelSummary() {
            const st = document.getElementById('sum-trim-label');
            const isEnabled = document.querySelector('input[name="need_label"][value="yes"]')?.checked;
            
            if (!isEnabled) {
                handleTrimDisabledSummary('label', st);
                return;
            }
        
            // жҠ“еҸ–е…ЁеұҖеӨҮжіЁж–Үжң¬
            labelConfig.remark = document.getElementById('label-remark')?.value.trim() || '';
            const hasContent = (labelConfig.remark !== '' || labelConfig.designFiles.length > 0) ? 'вң“ е·Ідј зЁҝ/еҶ…е®№' : 'Г— еҫ…иЎҘеҶ…е®№';
        
            if (labelConfig.mode === 'auto') {
                st.innerHTML = `<div style="text-align:right;"><span style="color:#10b981; font-weight:600;">зәўз»ЈжҷәиғҪд»Јй…Қ</span><br><span style="font-size:10px; opacity:0.8;">еҶ…е®№: ${hasContent}</span></div>`;
            } else {
                const sizeVal = document.getElementById('label-custom-size')?.value.trim() || '';
                labelConfig.size = sizeVal;
                
                // жҠ“еҸ–дё»жҙ—ж ҮеҲҶејҖзҡ„иҜҰз»ҶеӨҮжіЁ
                const splitVal = document.getElementById('label-split-remark')?.value.trim() || '';
                labelConfig.splitRemark = splitVal;
        
                const matText = labelConfig.material;
                let sizeText = '';
                let sewingText = '';
        
                if (matText === 'е…¶д»–') {
                    sizeText = 'е°әеҜёдёҺзјқеҲ¶иҜҰи§ҒжҸҸиҝ°';
                } else if (matText === 'еҚ°ж Ү') {
                    sizeText = sizeVal ? `е°әеҜё: ${sizeVal}` : 'е°әеҜёеҫ…е®ҡ';
                } else {
                    sizeText = sizeVal ? `е°әеҜё: ${sizeVal}` : 'е°әеҜёеҫ…е®ҡ';
                    
                    // жҠ“еҸ–е№¶еұ•зӨәиҮӘе®ҡд№үзјқеҲ¶зҡ„жҸҸиҝ°
                    labelConfig.sewingRemark = document.getElementById('label-sewing-remark')?.value.trim() || '';
                    if (labelConfig.method === 'е…¶д»–') {
                        sewingText = labelConfig.sewingRemark ? ' | иҮӘе®ҡд№үзјқеҲ¶' : ' | зјқеҲ¶еҫ…иҜҙжҳҺ';
                    } else {
                        sewingText = ` | ${labelConfig.method}`;
                    }
                }
                
                // з»„иЈ…еӨҡдёӘйғЁд»¶зҡ„дҪҚзҪ®ж–Үжң¬
                let placementHtml = '';
                const comps = labelConfig.components;
                
                if (comps.includes('дёҠиЈ…/иҝһдҪ“')) {
                    let pos = labelConfig.placements.top;
                    if (pos === 'иҮӘе®ҡд№үе…¶д»–дҪҚзҪ®') {
                        const customVal = document.getElementById('label-custom-top-text')?.value.trim();
                        pos = customVal ? customVal : 'е…¶д»–дҪҚзҪ®';
                    } else {
                        pos = pos.split(' (')[0];
                    }
                    placementHtml += `<span style="font-size:10px; opacity:0.8; display:block;">[дёҠиЈ…] ${pos}${sewingText}</span>`;
                }
                
                if (comps.includes('дёӢиЈ…/иЈӨиЈ…')) {
                    let pos = labelConfig.placements.bottom;
                    if (pos === 'иҮӘе®ҡд№үе…¶д»–дҪҚзҪ®') {
                        const customVal = document.getElementById('label-custom-bottom-text')?.value.trim();
                        pos = customVal ? customVal : 'е…¶д»–дҪҚзҪ®';
                    } else {
                        pos = pos.split(' (')[0];
                    }
                    placementHtml += `<span style="font-size:10px; opacity:0.8; display:block;">[дёӢиЈ…] ${pos}${sewingText}</span>`;
                }
        
                // --- ж–°еўһпјҡдё»жҙ—ж ҮеҲҶејҖж Үи®° ---
                const splitText = labelConfig.isSet ? '<span style="color:var(--primary-color);"> [дё»жҙ—ж ҮеҲҶејҖ]</span>' : '';
        
                st.innerHTML = `
                    <div style="text-align:right;">
                        ${matText}${splitText}<br>
                        ${placementHtml}
                        <span style="font-size:10px; opacity:0.8;">${sizeText} | ${hasContent}</span>
                    </div>`;
            }
            st.style.color = 'var(--primary-color)'; 
            st.style.fontWeight = 'bold';
        }

        

        // ==========================================
        // е…¶д»–иҫ…ж–ҷйҖ»иҫ‘ (Other Trims)
        // ==========================================
        let otherConfig = {
            remark: '',
            files: []
        };
        
        function handleOtherFiles(input) {
            const files = Array.from(input.files);
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) { alert(`ж–Үд»¶ ${file.name} и¶…иҝҮ 20MB`); return; }
                if (!otherConfig.files.some(f => f.name === file.name && f.size === file.size)) {
                    otherConfig.files.push(file);
                }
            });
        
            const nameEl = document.getElementById('otherFileName');
            if (otherConfig.files.length > 0) {
                nameEl.innerText = `е·ІйҖү ${otherConfig.files.length} дёӘж–Үд»¶`;
                nameEl.style.color = 'var(--primary-color)';
            } else {
                nameEl.innerText = 'зӮ№еҮ»жӯӨеӨ„дёҠдј еҸӮиҖғйҷ„д»¶';
                nameEl.style.color = '#334155';
            }
        
            renderOtherPreviews();
            updateOtherSummary();
            input.value = ''; // е…Ғи®ёйҮҚеӨҚдёҠдј еҗҢеҗҚж–Үд»¶
        }
        
        function renderOtherPreviews() {
            const grid = document.getElementById('otherPreview');
            if(!grid) return;
            grid.innerHTML = '';
            otherConfig.files.forEach((file, index) => {
                const isImage = file.type.startsWith('image/');
