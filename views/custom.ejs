        /* =========================================================
           10. OEM жЁЎеқ—дёҺе•ҶдёҡйңҖжұӮиҜ„дј°
           ========================================================= */
        /* ж–°еўһпјҡзҙ§еҮ‘еһӢйў„и§ҲзҪ‘ж јпјҢж¶ҲйҷӨеӨ§й—ҙйҡҷ */
        .tight-preview-grid {
            display: grid !important;
            /* ејәеҲ¶еҲ—е®Ҫдёә 50pxпјҢдёҚеҶҚиҮӘеҠЁж’‘ејҖ */
