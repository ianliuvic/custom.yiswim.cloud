<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- 引入 public 文件夹下的 CSS -->
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        <p><%= message %></p>
        
        <div class="action-box">
            <!-- 这个按钮以后可以用来触发发往 n8n 的请求 -->
            <button id="webhookBtn">测试发送信息到 n8n</button>
        </div>
    </div>

    <script>
        // 前端交互逻辑
        document.getElementById('webhookBtn').addEventListener('click', async () => {
            alert('这是一个基础占位按钮，日后将通过它触发 n8n Webhook！');
            // 未来的代码示例：
            // fetch('https://n8n.yiswim.cloud/webhook/your-webhook-id', { method: 'POST', ... })
        });
    </script>
</body>
</html>
