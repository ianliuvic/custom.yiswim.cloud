    <!-- =========================================================================
         核心 JavaScript 逻辑
         ========================================================================= -->
    <script src="/custom.js"></script>

    <!-- 移动端抽屉切换 -->
    <script>
    function toggleMobileDrawer() {
        var sidebar = document.querySelector('.summary-sidebar');
        var backdrop = document.getElementById('drawerBackdrop');
        var isOpen = sidebar.classList.contains('drawer-open');
        sidebar.classList.toggle('drawer-open', !isOpen);
        backdrop.classList.toggle('active', !isOpen);
    }

    // 横向滚动容器：滑到底部时移除渐隐遮罩
    document.querySelectorAll('.sub-tabs, .stepper, .category-nav').forEach(function(el) {
        el.addEventListener('scroll', function() {
            var atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - 2;
            el.classList.toggle('scrolled-end', atEnd);
        });
    });

    // 移动端头像下拉菜单
    function toggleUserMenu(e) {
        e.stopPropagation();
        var menu = document.getElementById('headerUserMenu');
        menu.classList.toggle('open');
        var guestMenu = document.getElementById('headerGuestMenu');
        if (guestMenu) guestMenu.classList.remove('open');
    }
    function toggleGuestMenu(e) {
        e.stopPropagation();
        var menu = document.getElementById('headerGuestMenu');
        menu.classList.toggle('open');
        var userMenu = document.getElementById('headerUserMenu');
        if (userMenu) userMenu.classList.remove('open');
    }
    document.addEventListener('click', function() {
        var menu = document.getElementById('headerUserMenu');
        if (menu) menu.classList.remove('open');
        var guestMenu = document.getElementById('headerGuestMenu');
        if (guestMenu) guestMenu.classList.remove('open');
    });
    </script>

    <!-- === 1. Chatwoot 动态配置 (含多语言同步) === -->
    <script>
      var systemLang = window.__lang || 'en';
      var chatwootLocale = systemLang === 'en' ? 'en' : 'zh_CN';
      var chatwootToken = systemLang === 'en'
        ? '7SvUcM7Q35czsNHZYcZiXtNu'
        : 'qQNjoJ2DsKdY4Hxmv2pCNM6S';  // 中文Token
    
      window.chatwootSettings = {
        "position": "right",
