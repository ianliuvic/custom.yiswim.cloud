            st.innerHTML = `<div style="text-align:right;">${matPart} | ${shapePart}<br><span style="font-size:10px; opacity:0.8;">${hangtagConfig.stringMat}(${hangtagConfig.stringColor}) | ${craftText}</span>${hasFile}</div>`;
