        function updateOtherSummary() {
            const st = document.getElementById('sum-trim-other');
            const isEnabled = document.querySelector('input[name="need_other"][value="yes"]').checked;
            
            if (!isEnabled) {
                st.innerText = '不需要';
                st.style.color = '#64748b'; 
                st.style.fontWeight = 'normal';
