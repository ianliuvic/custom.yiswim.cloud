        // ==========================================
        // 吊牌逻辑 (Hangtag)
        // ==========================================
        let hangtagConfig = {
            material: '经典白卡 (350g/500g)',
            shape: '标准修长型 (约 4x9cm)',
            stringMat: '通用塑料吊粒',
            stringColor: '白色',
            crafts: [],
            designFiles: [],
            shapeFiles: [] // 新增形状参考文件组
        };

        function selectHangtagAttr(attrType, value, el) {
            hangtagConfig[attrType] = value;
            
            // 处理不同类型的元素互斥选择
            if (attrType === 'material') {
                document.getElementById('content-hangtag').querySelectorAll('.metal-item').forEach(item => item.classList.remove('selected'));
            } else if (attrType === 'shape') {
                document.getElementById('content-hangtag').querySelectorAll('.hangtag-shape-card').forEach(item => item.classList.remove('selected'));
            } else if (attrType === 'stringMat') {
                document.getElementById('content-hangtag').querySelectorAll('.hangtag-string-mat').forEach(item => item.classList.remove('selected'));
            } else if (attrType === 'stringColor') {
                document.getElementById('content-hangtag').querySelectorAll('.string-color-swatch').forEach(item => item.classList.remove('selected'));
            }
            
            el.classList.add('selected');
            updateHangtagSummary();
        }

        function toggleHangtagCraft(craft, el) {
            const index = hangtagConfig.crafts.indexOf(craft);
            if (index > -1) { hangtagConfig.crafts.splice(index, 1); el.classList.remove('selected'); } 
            else { hangtagConfig.crafts.push(craft); el.classList.add('selected'); }
            updateHangtagSummary();
        }

        function syncHangtagColorWithMetal() {
            // 根据金属件颜色自动匹配吊粒颜色
            const metalColor = metalConfig.finish;
            let targetColor = '白色';
            if (metalColor.includes('金')) targetColor = '金色系';
            else if (metalColor.includes('银')) targetColor = '银色系';
            else if (metalColor.includes('黑')) targetColor = '黑色';
            else { showToast('当前金属件颜色无需特殊匹配', 'info'); return; }

            // 触发点击事件
            const swatches = document.querySelectorAll('#hangtag-string-color-container .string-color-swatch');
            for (let swatch of swatches) {
                if (swatch.getAttribute('onclick').includes(targetColor)) {
                    swatch.click();
                    showToast(`已自动同步为：${targetColor}`, 'success');
                    break;
                }
            }
        }

        function handleHangtagFiles(input, type) {
            const files = Array.from(input.files);
            const targetArray = type === 'design' ? hangtagConfig.designFiles : hangtagConfig.shapeFiles;
            
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) { showToast(`文件 ${file.name} 超过 20MB`, 'error'); return; }
                if (!targetArray.some(f => f.name === file.name && f.size === file.size)) {
                    targetArray.push(file);
                }
            });

            const nameEl = document.getElementById(type === 'design' ? 'hangtagFileName' : 'hangtagShapeFileName');
            if (targetArray.length > 0) {
                nameEl.innerText = targetArray.length === 1 ? targetArray[0].name : `已选 ${targetArray.length} 个文件`;
                nameEl.style.color = 'var(--text-main)';
            }
            
            renderHangtagPreviews(type);
            updateHangtagSummary();
            input.value = '';
        }

        function renderHangtagPreviews(type) {
            const grid = document.getElementById(type === 'design' ? 'hangtagPreview' : 'hangtagShapePreview');
            const targetArray = type === 'design' ? hangtagConfig.designFiles : hangtagConfig.shapeFiles;
            grid.innerHTML = '';
            
            targetArray.forEach((file, index) => {
                const isImage = file.type.startsWith('image/');
                const ext = file.name.split('.').pop().toUpperCase();
                let content = isImage 
                    ? `<img src="${URL.createObjectURL(file)}" onclick="openOemPreview(this.src, '${file.name}')">` 
                    : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:#64748b;font-size:10px;font-weight:bold;">${ext}</div>`;

