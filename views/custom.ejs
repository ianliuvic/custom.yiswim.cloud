        /* дёҠдёҖжӯҘжҢүй’®пјҡдҝқжҢҒдҪҺи°ғзҡ„ж¬ЎиҰҒжҢүй’®йЈҺж ј */
        #prevBtn {
            background: #fff;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }
        
        #prevBtn:hover:not(:disabled) {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: var(--text-main);
            transform: translateY(-1px); /* жһҒиҪ»еҫ®зҡ„дёҠжө® */
        }
        
        #prevBtn:active:not(:disabled) {
            transform: translateY(0) scale(0.98); /* зӮ№еҮ»ж—¶жҢүдёӢзҡ„и§Ұж„ҹ */
        }
        
        #prevBtn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: #f1f5f9;
        }
        
        /* дёӢдёҖжӯҘ/жҸҗдәӨжҢүй’®пјҡејәеҢ–е“ҒзүҢж„ҹ */
        #nextBtn {
            background: var(--primary-color);
