                const result = await response.json();
                if (result.success && result.data) {
                    if(result.data.bags) renderBags(result.data.bags);
                    if(result.data.odm_styles) renderOdmStyles(result.data.odm_styles);
                }
            } catch (error) {
                console.error('加载数据失败:', error);
            }
        });

        // --- 1. 动态渲染 ODM 款式与分类 (关键：提取第一张图作为封面) ---
        function renderOdmStyles(styles) {
            const navContainer = document.getElementById('odm-category-nav');
            const contentContainer = document.getElementById('odm-content-container');
            
            if (!styles || styles.length === 0) {
                navContainer.innerHTML = '<p style="color:#999;font-size:12px;">暂无款式数据</p>';
                return;
            }

            // 提取去重后的分类数组
            const categories = [...new Set(styles.map(s => s.category).filter(Boolean))];

            // 【新增】同步 OEM 模块的品类下拉框
            const oemCategorySelect = document.getElementById('oem-category');
            if (oemCategorySelect) {
                // 保留第一个默认空选项
                oemCategorySelect.innerHTML = '<option value="">请选择品类 (Category)...</option>';
                
                // 动态添加来自 API 的分类
                categories.forEach(cat => {
                    const option = document.createElement('option');
                    option.value = cat;
                    option.textContent = cat;
                    oemCategorySelect.appendChild(option);
                });
                
                // 最后追加一个“其他”选项
                const otherOption = document.createElement('option');
                otherOption.value = 'Other';
                otherOption.textContent = '其他款式 (Other Categories)';
                oemCategorySelect.appendChild(otherOption);
            }
            
            navContainer.innerHTML = '';
            contentContainer.innerHTML = '';

            categories.forEach((cat, index) => {
                const isActive = index === 0 ? 'active' : '';
                // 将分类名转为合法的 HTML id
                const catId = `cat-${cat.replace(/\s+/g, '-')}`;
                
                // 生成顶部 Tab
                navContainer.insertAdjacentHTML('beforeend', `
                    <div class="cat-item ${isActive}" onclick="switchCategory('${catId}', this)">${cat}</div>
                `);

                // 生成对应的容器面板
                const paneHtml = `
                    <div id="${catId}" class="cat-pane ${isActive}">
                        <div class="option-grid" id="grid-${catId}"></div>
                    </div>
                `;
                contentContainer.insertAdjacentHTML('beforeend', paneHtml);

                // 将对应分类的款式放入容器
                const catStyles = styles.filter(s => s.category === cat);
                catStyles.sort((a, b) => {
                            return a.name.localeCompare(b.name, 'zh-CN', { numeric: true });
                        });

                const gridContainer = document.getElementById(`grid-${catId}`);

                catStyles.forEach(style => {
                    // 【新增：根据规则对图片数组进行排序】
                    if (style.image_urls && style.image_urls.length > 0) {
                        style.image_urls.sort((a, b) => {
                            // 1. 取出URL最后的文件名部分 (通过 .pop())
                            // 2. 用正则 /_\d+\.\w+$/ 匹配并去掉最后的 "_数字.后缀" (例如 _1.webp)
                            const keyA = a.split('/').pop().replace(/_\d+\.\w+$/, '');
                            const keyB = b.split('/').pop().replace(/_\d+\.\w+$/, '');
                            
                            // 3. 根据剩下的字符串进行字母/数字顺序对比
                            if (keyA === keyB) {
                                // 如果剩下的部分完全一样，则回退到用完整的原链接对比，保证排序稳定性
                                return a.localeCompare(b);
                            }
                            return keyA.localeCompare(keyB);
                        });
                    }

                    // 排序完成后，原数组的顺序已被改变，此时获取的第 [0] 项就是排序最靠前的封面图
                    const coverImg = (style.image_urls && style.image_urls.length > 0) ? style.image_urls[0] : '';
                    // 传入弹窗的 styleJson 也会自动包含已经排好序的图片数组
                    const styleJson = JSON.stringify(style).replace(/"/g, '&quot;');
                    
                    const cardHtml = `
                        <!-- 卡片需加一个特定 ID 方便后续挂载标识 -->
                        <div class="option-item style-item" id="card-${style.name.replace(/\s+/g, '-')}" onclick="selectOdmStyle('${style.name}', this)">
                            
                            <!-- 1. 原有的放大镜按钮 -->
                            <div class="details-btn" onclick="event.stopPropagation(); openDetailModal(${styleJson})" title="查看图片">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                            </div>
                            
                            <!-- 2. 新增的轻定制按钮 -->
                            <div class="customize-btn" onclick="event.stopPropagation(); openCustomModal('${style.name}', this.closest('.option-item'))" title="版型轻定制">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                            </div>

                            <img src="${coverImg}" class="option-img" loading="lazy">
                            <div class="option-info">
                                <!-- 3. 标题旁预留定制标识 -->
                                <h4>${style.name} <span class="custom-badge" id="badge-${style.name.replace(/\s+/g, '-')}">✨ 已定制</span></h4>
                                <p style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${style.description || '精选款式'}</p>
                            </div>
                        </div>
                    `;
                    gridContainer.insertAdjacentHTML('beforeend', cardHtml);
                });
            });
        }

        // ODM 品类切换
        function switchCategory(catId, el) {
            document.querySelectorAll('#odm-category-nav .cat-item').forEach(item => item.classList.remove('active'));
            el.classList.add('active');
            document.querySelectorAll('#odm-content-container .cat-pane').forEach(pane => pane.classList.remove('active'));
            document.getElementById(catId).classList.add('active');
        }

        // ODM 选中款式 (已修复：点击切换时保持定制状态回显)
        function selectOdmStyle(name, el) {
            // 1. 获取右侧汇总的 DOM 节点
            const sumStyleEl = document.getElementById('sum-style');
            
            // 2. 检查全局变量 odmCustomData 中该款式是否有定制数据
            const customData = odmCustomData[name];
            const hasCustomization = customData && (customData.remark !== '' || customData.hasFile);

            // 3. 根据是否有定制数据，动态更新右侧面板的文字
            if (hasCustomization) {
                sumStyleEl.innerHTML = `${name} <span style="color:var(--primary-color); font-size:11px;">(含定制修改)</span>`;
            } else {
                sumStyleEl.innerText = name;
            }

            // 4. 处理卡片的 UI 选中状态
            document.querySelectorAll('.style-item').forEach(item => item.classList.remove('selected'));
            el.classList.add('selected');
            
            // 同步更新当前正在操作的款式名称
            currentEditingStyle = name;
        }

        // ==========================================
        // 轻定制 (Custom Modal) 核心逻辑及文件上传
        // ==========================================
        let odmCustomData = {}; // 全局存储每个款式的定制数据 { remark: string, files: Array<File> }
        let currentEditingStyle = '';
        let currentModalFiles = []; // 临时存储当前弹窗正在编辑的文件数组

        const MAX_FILE_SIZE = 20 * 1024 * 1024; // 20MB

        // 1. 打开定制弹窗
        function openCustomModal(styleName, cardEl) {
            selectOdmStyle(styleName, cardEl); // 自动选中该卡片
            
            currentEditingStyle = styleName;
            document.getElementById('customModalTarget').innerText = `(${styleName})`;
            
            // 数据回显：读取之前保存的备注和文件
            const existingData = odmCustomData[styleName] || { remark: '', files: [] };
            document.getElementById('customRemark').value = existingData.remark;
            
            // 将保存的文件克隆到临时数组，渲染列表
            currentModalFiles = [...existingData.files];
            renderFileList();
            
            document.getElementById('customModal').classList.add('active');
        }

        // 2. 关闭定制弹窗 (不保存更改)
        function closeCustomModal() {
            document.getElementById('customModal').classList.remove('active');
            currentModalFiles = []; // 清空临时数组
        }

        // 3. 保存定制内容并更新标识
        function saveCustomization() {
            const remark = document.getElementById('customRemark').value.trim();
            const hasFile = currentModalFiles.length > 0;

            // 将文本和文件数组存入全局对象
            odmCustomData[currentEditingStyle] = {
                remark: remark,
                files: [...currentModalFiles] // 保存真正的 File 对象数组
            };

            // 更新卡片上的 UI 标识
            const safeId = currentEditingStyle.replace(/\s+/g, '-');
            const badgeEl = document.getElementById(`badge-${safeId}`);
            if (remark !== '' || hasFile) {
                badgeEl.classList.add('active');
            } else {
                badgeEl.classList.remove('active');
            }

            // 更新右侧侧边栏汇总
            const sumStyleEl = document.getElementById('sum-style');
            if (remark !== '' || hasFile) {
                sumStyleEl.innerHTML = `${currentEditingStyle} <span style="color:var(--primary-color); font-size:11px;">(含定制修改)</span>`;
            } else {
                sumStyleEl.innerText = currentEditingStyle;
            }

            closeCustomModal();
        }

        // --- 附件上传核心逻辑 ---

        // 格式化文件大小
        function formatBytes(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024, sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // 获取文件后缀类型用于展示不同颜色的图标
        function getFileExt(filename) {
            return filename.split('.').pop().toLowerCase();
        }

        // 渲染文件列表 UI
        function renderFileList() {
            const listContainer = document.getElementById('customFileList');
            listContainer.innerHTML = ''; // 清空旧列表

            currentModalFiles.forEach((file, index) => {
                const ext = getFileExt(file.name);
                let iconClass = '';
                if (['jpg', 'jpeg', 'png', 'webp', 'gif'].includes(ext)) iconClass = 'img';
                else if (ext === 'pdf') iconClass = 'pdf';
                else if (['ai', 'eps'].includes(ext)) iconClass = 'ai';

                const html = `
                    <div class="file-item">
                        <div class="file-info">
                            <div class="file-icon ${iconClass}">${ext.substring(0, 3)}</div>
                            <div class="file-details">
                                <span class="file-name" title="${file.name}">${file.name}</span>
                                <span class="file-size">${formatBytes(file.size)}</span>
                            </div>
                        </div>
                        <button class="file-remove" onclick="removeModalFile(${index})" title="移除文件">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                        </button>
                    </div>
                `;
                listContainer.insertAdjacentHTML('beforeend', html);
            });
        }

        // 删除单个文件
        function removeModalFile(index) {
            currentModalFiles.splice(index, 1);
            renderFileList();
        }

        // 统一处理新加入的文件 (检查大小并合并)
        function handleFilesAdded(files) {
            const newFiles = Array.from(files);
            let alertMsg = '';

            newFiles.forEach(file => {
                // 1. 检查大小
                if (file.size > MAX_FILE_SIZE) {
                    alertMsg += `文件 "${file.name}" 超过20MB限制，已被忽略。\n`;
                    return;
                }
                // 2. 避免同名文件重复添加 (简单的业务校验)
                const isDuplicate = currentModalFiles.some(existing => existing.name === file.name && existing.size === file.size);
                if (!isDuplicate) {
                    currentModalFiles.push(file);
                }
            });

            if (alertMsg) alert(alertMsg);
            renderFileList();
        }

        // ==========================================
        // OEM 模块逻辑
        // ==========================================
        let oemFiles = { tech: [], ref: [] };

        // 1. 切换样衣地址显示
        function togglePhysicalInfo(isVisible) {
            const infoBox = document.getElementById('oem-address-info');
            if (isVisible) infoBox.classList.remove('hidden');
            else infoBox.classList.add('hidden');
        }

        // 2. 处理 OEM 文件上传渲染
        function handleOemFiles(input, type) {
            const files = Array.from(input.files);
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) {
                    alert(`文件 ${file.name} 超过20MB`);
                    return;
                }
                oemFiles[type].push(file);
            });
            renderOemFileList(type);
            input.value = ''; // 重置
        }

        function renderOemFileList(type) {
            const container = document.getElementById(`oem${type.charAt(0).toUpperCase() + type.slice(1)}List`);
            container.innerHTML = '';
            oemFiles[type].forEach((file, index) => {
                const ext = file.name.split('.').pop().toLowerCase();
                const html = `
                    <div class="file-item" style="padding: 6px 10px;">
                        <div class="file-info" style="gap:8px;">
                            <div class="file-icon" style="width:24px; height:24px; font-size:9px;">${ext.substring(0,3)}</div>
                            <span class="file-name" style="font-size:12px; max-width:150px;">${file.name}</span>
                        </div>
                        <button type="button" class="file-remove" onclick="removeOemFile('${type}', ${index})">×</button>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        function removeOemFile(type, index) {
            oemFiles[type].splice(index, 1);
            renderOemFileList(type);
        }

        // 3. 增强：绑定 OEM 区域的拖拽事件
        document.addEventListener('DOMContentLoaded', () => {
            ['Tech', 'Ref'].forEach(type => {
                const zone = document.getElementById(`oem${type}Dropzone`);
                if(!zone) return;
                zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
                zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
                zone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    zone.classList.remove('dragover');
                    handleOemFiles({ files: e.dataTransfer.files }, type.toLowerCase());
                });
            });
        });

        // --- 绑定事件：点击选择文件 ---
        document.getElementById('customFile').addEventListener('change', function(e) {
            handleFilesAdded(e.target.files);
            this.value = ''; // 清空 input 的值，确保下次选同一个文件依然能触发 change 事件
        });

        // ==========================================
        // OEM 模块逻辑：图片预览与处理
        // ==========================================
        let oemImages = { tech: [], ref: [] };

        function handleOemImages(input, type) {
            const files = Array.from(input.files);
            const validImages = files.filter(file => {
                const isImg = file.type.startsWith('image/');
                if (!isImg) alert(`文件 ${file.name} 不是图片格式`);
                return isImg && file.size <= 20 * 1024 * 1024;
            });

            validImages.forEach(file => {
                // 避免重复
                if (!oemImages[type].some(existing => existing.name === file.name)) {
                    oemImages[type].push(file);
                    
                    // 创建预览
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        addPreviewToGrid(type, e.target.result, oemImages[type].length - 1);
                    };
                    reader.readAsDataURL(file);
                }
            });
            input.value = ''; 
        }

        function addPreviewToGrid(type, src, index) {
            const grid = document.getElementById(`oem${type.charAt(0).toUpperCase() + type.slice(1)}Preview`);
            const html = `
                <div class="oem-preview-item" data-index="${index}">
                    <img src="${src}">
                    <button type="button" class="oem-preview-remove" onclick="removeOemImage('${type}', ${index})">&times;</button>
                </div>
            `;
            grid.insertAdjacentHTML('beforeend', html);
        }

        function removeOemImage(type, index) {
            oemImages[type].splice(index, 1);
            // 重新渲染预览格以保持索引正确
            const grid = document.getElementById(`oem${type.charAt(0).toUpperCase() + type.slice(1)}Preview`);
            grid.innerHTML = '';
            oemImages[type].forEach((file, idx) => {
                const reader = new FileReader();
                reader.onload = (e) => addPreviewToGrid(type, e.target.result, idx);
                reader.readAsDataURL(file);
            });
        }

        // 重新绑定拖拽事件到新的 Dropzone
        document.addEventListener('DOMContentLoaded', () => {
            ['Tech', 'Ref'].forEach(type => {
                const zone = document.getElementById(`oem${type}Dropzone`);
                if(!zone) return;
                zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
                zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
                zone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    zone.classList.remove('dragover');
                    handleOemImages({ files: e.dataTransfer.files }, type.toLowerCase());
                });
            });
        });

        // --- 绑定事件：拖拽文件 ---
        const dropzone = document.getElementById('customDropzone');
        
        if (dropzone) { // 加上这层判断，即使 HTML 没写对也不会让整个页面崩溃
            dropzone.addEventListener('dragover', (e) => {
                e.preventDefault(); 
                dropzone.classList.add('dragover');
            });
        
            dropzone.addEventListener('dragleave', (e) => {
                e.preventDefault();
                dropzone.classList.remove('dragover');
            });
        
            dropzone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropzone.classList.remove('dragover');
                if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
                    handleFilesAdded(e.dataTransfer.files);
                }
            });
        }

        // --- 2. 弹窗与多图轮播逻辑 ---
        let currentModalImages = [];
        let currentImageIndex = 0;

        function openDetailModal(itemData) {
            document.getElementById('modalTitle').innerText = itemData.name || '产品详情';
            
            // 解析图片数组
            currentModalImages = itemData.image_urls || [];
            if(typeof itemData.image_urls === 'string') currentModalImages = [itemData.image_urls];
            
            currentImageIndex = 0;
            renderModalCarousel();
            
            document.getElementById('modalDesc').innerHTML = `
                <div style="background:#f9f9f9; padding:12px; border-radius:4px; margin-top:15px;">
                    <strong style="color:var(--text-main);">详情简介：</strong><br>
                    <span style="color:#666;">${itemData.description || '暂无详细说明。'}</span>
                </div>
            `;
            document.getElementById('detailModal').classList.add('active');
        }

        function renderModalCarousel() {
            const imgEl = document.getElementById('modalImg');
            const prevBtn = document.getElementById('carousel-prev');
            const nextBtn = document.getElementById('carousel-next');
            const dotsContainer = document.getElementById('carousel-dots');
            const carouselBox = document.getElementById('modalCarousel');

            if (!currentModalImages || currentModalImages.length === 0) {
                carouselBox.style.display = 'none';
                dotsContainer.innerHTML = '';
                return;
            }

            carouselBox.style.display = 'flex';
            imgEl.src = currentModalImages[currentImageIndex];

            // 只有一张图时，隐藏左右箭头和小圆点
            if (currentModalImages.length <= 1) {
                prevBtn.style.display = 'none';
                nextBtn.style.display = 'none';
                dotsContainer.innerHTML = '';
            } else {
                prevBtn.style.display = 'flex';
                nextBtn.style.display = 'flex';
                dotsContainer.innerHTML = currentModalImages.map((_, idx) => `
                    <div class="carousel-dot ${idx === currentImageIndex ? 'active' : ''}" onclick="goToModalImage(${idx})"></div>
                `).join('');
            }
        }

        function carouselMove(step) {
            if (currentModalImages.length <= 1) return;
            currentImageIndex += step;
            if (currentImageIndex < 0) currentImageIndex = currentModalImages.length - 1;
            if (currentImageIndex >= currentModalImages.length) currentImageIndex = 0;
            renderModalCarousel();
        }

        function goToModalImage(idx) {
            currentImageIndex = idx;
            renderModalCarousel();
        }

        function closeDetailModal() { document.getElementById('detailModal').classList.remove('active'); }
        document.getElementById('closeModalBtn').addEventListener('click', closeDetailModal);
        document.getElementById('detailModal').addEventListener('click', function(event) {
            if (event.target === this) closeDetailModal();
        });

        // --- 3. 基础步进控制 ---
        let currentStep = 1;
        const totalSteps = 5;

        function changeStep(n) {
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.remove('active');
            currentStep += n;
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.add('active');
            document.getElementById('prevBtn').disabled = (currentStep === 1);
            
            if (currentStep === totalSteps) {
                document.getElementById('nextBtn').innerText = '确认并提交定制需求';
                document.getElementById('nextBtn').style.backgroundColor = '#27ae60';
                document.getElementById('nextBtn').style.borderColor = '#27ae60';
            } else {
                document.getElementById('nextBtn').innerText = '继续下一步';
                document.getElementById('nextBtn').style.backgroundColor = 'var(--primary-color)';
                document.getElementById('nextBtn').style.borderColor = 'var(--primary-color)';
            }
            document.querySelector('.config-scroll-area').scrollTop = 0;
        }

        function selectItem(category, displayName) {
            document.getElementById(`sum-${category}`).innerText = displayName;
            const container = document.getElementById(`step-${currentStep}`);
            container.querySelectorAll('.option-item').forEach(item => item.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }

        // Step 5: 更新右侧汇总栏的规模状态
        function updateSummaryVolume(text) {
            document.getElementById('sum-volume').innerText = text;
        }

        // 找到您之前写的 clearAllSelections 函数，将 "5. 重置最终备注" 部分替换为：
        // 5. 重置商业需求评估 (Step 5)
        const stageRadio = document.querySelector('input[name="project_stage"][value="concept"]');
        if (stageRadio) stageRadio.checked = true;
        
        const volumeRadio = document.querySelector('input[name="est_volume"][value="sample_only"]');
        if (volumeRadio) {
            volumeRadio.checked = true;
            updateSummaryVolume('仅开发样衣');
        }

        document.getElementById('plan_colors').value = '';
        document.getElementById('plan_sizes').value = '';
        document.getElementById('target_market').value = '';
        document.getElementById('target_price').value = '';
        document.getElementById('final_remark').value = '';


        function toggleStyleMode(mode) {
            const list = document.getElementById('existing-styles');
            const upload = document.getElementById('custom-upload');
            const odmBtn = document.getElementById('mode-odm');
            const oemBtn = document.getElementById('mode-oem');

            if(mode === 'existing') {
                list.classList.remove('hidden'); upload.classList.add('hidden');
                odmBtn.classList.add('active'); oemBtn.classList.remove('active');
                document.getElementById('sum-style').innerText = '未选择'; 
            } else {
                list.classList.add('hidden'); upload.classList.remove('hidden');
                oemBtn.classList.add('active'); odmBtn.classList.remove('active');
                document.getElementById('sum-style').innerText = 'OEM 自定义开发';
            }
        }

        // --- 4. 面料配置逻辑 ---
        let fabricSelection = {
            main: { name: '', mode: 'solid', colors: [], remark: '' },
            lining: { name: '', mode: 'solid', colors: [], remark: '' }
        };
        let activeFabricCat = 'main';

        function switchFabricCat(cat, el) {
            activeFabricCat = cat;
            el.parentNode.querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            document.querySelectorAll('.fabric-pane').forEach(p => p.classList.remove('active'));
            document.getElementById(`fabric-pane-${cat}`).classList.add('active');
            document.getElementById('fabric-config-panel').classList.add('hidden');
        }

        function selectFabric(name, el, cat) {
            const pane = document.getElementById(`fabric-pane-${cat}`);
            pane.querySelectorAll('.fabric-item').forEach(item => item.classList.remove('selected'));
            el.classList.add('selected');

            const arrow = document.getElementById('config-arrow');
            const panel = document.getElementById('fabric-config-panel');
            
            const cardRect = el.getBoundingClientRect();
            const containerRect = el.parentNode.parentNode.getBoundingClientRect(); 
            const offsetLeft = cardRect.left - containerRect.left + (cardRect.width / 2) - 8; 
            
            panel.classList.remove('hidden');
            arrow.style.left = `${offsetLeft}px`;

            fabricSelection[cat].name = name;
            fabricSelection[cat].colors = [];
            document.querySelectorAll('.color-swatch').forEach(sw => sw.classList.remove('selected'));
            document.getElementById('selected-colors-text').innerText = '未选择颜色';
            document.getElementById('selected-colors-text').style.color = '#999';

            document.getElementById('selected-fabric-display').innerText = `${cat === 'main' ? '主面料' : '里料'}配置：${name}`;
            document.getElementById('config-type-tag').innerText = cat === 'main' ? 'MAIN FABRIC' : 'LINING';
            
            updateFabricSummary();
        }

        function switchFabricMode(mode) {
            fabricSelection[activeFabricCat].mode = mode;
            const solidBtn = document.getElementById('mode-solid');
            const printBtn = document.getElementById('mode-print');
            const solidArea = document.getElementById('fabric-solid-area');
            const printArea = document.getElementById('fabric-print-area');

            if (mode === 'solid') {
                solidBtn.classList.add('active'); printBtn.classList.remove('active');
                solidArea.classList.remove('hidden'); printArea.classList.add('hidden');
            } else {
                printBtn.classList.add('active'); solidBtn.classList.remove('active');
                printArea.classList.remove('hidden'); solidArea.classList.add('hidden');
            }
            updateFabricSummary();
        }

        function toggleColor(colorName, el) {
            const targetArray = fabricSelection[activeFabricCat].colors;
            const idx = targetArray.indexOf(colorName);
            
            if (idx > -1) {
                targetArray.splice(idx, 1);
                el.classList.remove('selected');
            } else {
                targetArray.push(colorName);
                el.classList.add('selected');
            }

            const textEl = document.getElementById('selected-colors-text');
            if (targetArray.length === 0) {
                textEl.innerText = '未选择颜色';
                textEl.style.color = '#999';
            } else {
                textEl.innerText = `已选颜色 (${targetArray.length})：${targetArray.join(', ')}`;
                textEl.style.color = 'var(--primary-color)';
            }
            updateFabricSummary();
        }

        function updateFabricSummary() {
            const buildText = (catStr) => {
                const conf = fabricSelection[catStr];
                if (!conf.name) return '未选';
                if (conf.mode === 'print') return `${conf.name} (定制印花)`;
                if (conf.colors.length === 0) return `${conf.name} (待选色)`;
                return `${conf.name} (${conf.colors.length}色)`;
            };

            const mainSum = buildText('main');
            const liningSum = buildText('lining');
            
            document.getElementById('sum-fabric').innerHTML = 
                `<div style="font-size:12px; margin-bottom:4px; color:var(--text-main);">面: ${mainSum}</div>` +
                `<div style="font-size:12px; color:var(--text-main);">里: ${liningSum}</div>`;
        }

        // --- 5. 辅料及包装袋逻辑 ---
        function switchSubTab(paneId, el) {
            document.querySelectorAll('.sub-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(`pane-${paneId}`).classList.add('active');
            el.classList.add('active');
        }

        function toggleTrim(category, isNeeded) {
            const contentBox = document.getElementById(`content-${category}`);
            const summaryText = document.getElementById(`sum-trim-${category}`);
            
            if (isNeeded) {
                contentBox.classList.remove('hidden');
                if (category === 'bag') {
                    updateBagSummary();
                } else {
                    summaryText.innerText = '已开启';
                    summaryText.style.color = 'var(--primary-color)';
                    summaryText.style.fontWeight = 'bold';
                }
            } else {
                contentBox.classList.add('hidden');
                summaryText.innerText = '不需要';
                summaryText.style.color = '#666';
                summaryText.style.fontWeight = 'normal';
            }
        }

        let bagConfig = { material: '未选材质', size: '未选尺寸', print: '未选印刷' };

        function renderBags(bags) {
            const container = document.getElementById('bag-list-container');
            container.innerHTML = ''; 
            bags.forEach(bag => {
                // 【关键修复】：这里也确保只取第0项作为封面
                const coverImg = (bag.image_urls && bag.image_urls.length > 0) ? bag.image_urls[0] : '/images/default-bag.jpg';
                const bagJson = JSON.stringify(bag).replace(/"/g, '&quot;');
                
                const html = `
                    <div class="option-item bag-material" onclick="onBagClick(${bagJson}, this)">
                        <div class="details-btn" onclick="event.stopPropagation(); openDetailModal(${bagJson})" title="查看详情">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        </div>
                        <img src="${coverImg}" class="option-img" loading="lazy">
                        <div class="option-info">
                            <h4>${bag.name}</h4>
                            <p>${bag.description || '优质定制包装'}</p>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        function onBagClick(bag, el) {
            selectBagAttr('material', bag.name, el);
            renderBagSizes(bag.sizes);
            bagConfig.size = '未选尺寸';
            updateBagSummary();
        }

        function renderBagSizes(sizes) {
            const container = document.getElementById('bag-size-container');
            container.innerHTML = ''; 
            if (!sizes || sizes.length === 0) {
                container.innerHTML = '<p style="color:#999; font-size:12px; padding:20px;">该款式暂无可选规格</p>';
                return;
            }
            sizes.forEach(size => {
                const html = `
                    <div class="option-item bag-size" onclick="selectBagAttr('size', '${size}', this)">
                        <!-- 尺寸不需要3:4图片，保留固定高度的色块 -->
                        <div style="height: 100px; background: #fafafa; display: flex; align-items:center; justify-content:center; font-size:18px; font-weight:bold; color:#666; border-bottom: 1px solid #eee;">${size}</div>
                        <div class="option-info"><h4>规格: ${size} cm</h4><p>适配当前选中的袋型</p></div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
            container.insertAdjacentHTML('beforeend', `
                <div class="option-item bag-size" onclick="selectBagAttr('size', '自定义尺寸', this)">
                    <div style="height: 100px; background: #fafafa; display: flex; align-items:center; justify-content:center; font-size:18px; font-weight:bold; color:#ccc; border-bottom: 1px solid #eee;">? x ?</div>
                    <div class="option-info"><h4>自定义尺寸</h4><p>我有特殊要求 (请备注)</p></div>
                </div>
            `);
        }

        function selectBagAttr(attrType, displayName, el) {
            bagConfig[attrType] = displayName;
            const container = document.getElementById('content-bag');
            container.querySelectorAll(`.bag-${attrType}`).forEach(item => item.classList.remove('selected'));
            el.classList.add('selected');
            updateBagSummary();
        }

        function updateBagSummary() {
            const summaryText = document.getElementById('sum-trim-bag');
            if (bagConfig.material === '未选材质' && bagConfig.size === '未选尺寸' && bagConfig.print === '未选印刷') {
                summaryText.innerText = '已开启 (待选择详细配置)';
            } else {
                const matStr = bagConfig.material !== '未选材质' ? bagConfig.material : '??';
                const sizeStr = bagConfig.size !== '未选尺寸' ? bagConfig.size.split(' ')[0] : '??'; 
                const printStr = bagConfig.print !== '未选印刷' ? bagConfig.print : '??';
                summaryText.innerText = `${matStr} | ${sizeStr} | ${printStr}`;
            }
            summaryText.style.color = 'var(--primary-color)';
            summaryText.style.fontWeight = 'bold';
        }

        // ==========================================
        // 全局重置功能 (清空所有已选项)
        // ==========================================
        function clearAllSelections() {
            // 增加确认提示，防止误触导致数据丢失
            if (!confirm('确定要清空所有已选配置并重头开始吗？')) {
                return;
            }

            // 1. 重置款式 (Step 1)
            document.querySelectorAll('.style-item').forEach(item => item.classList.remove('selected'));
            document.getElementById('sum-style').innerText = '未选择';
            odmCustomData = {}; // 清空所有的轻定制数据
            currentEditingStyle = '';
            document.querySelectorAll('.custom-badge').forEach(badge => badge.classList.remove('active')); // 隐藏所有卡片上的"已定制"标签

            // 2. 重置面料 (Step 2)
            fabricSelection = {
                main: { name: '', mode: 'solid', colors: [], remark: '' },
                lining: { name: '', mode: 'solid', colors: [], remark: '' }
            };
            document.querySelectorAll('.fabric-item').forEach(item => item.classList.remove('selected'));
            document.getElementById('fabric-config-panel').classList.add('hidden'); // 隐藏配置台
            document.querySelectorAll('.color-swatch').forEach(sw => sw.classList.remove('selected'));
            document.getElementById('selected-colors-text').innerText = '未选择颜色';
            document.getElementById('selected-colors-text').style.color = '#999';
            document.getElementById('fabric-remark').value = '';
            document.getElementById('sum-fabric').innerHTML = 
                `<div style="font-size:12px; margin-bottom:4px; color:var(--text-main);">面: 未选</div>` +
                `<div style="font-size:12px; color:var(--text-main);">里: 未选</div>`;

            // 3. 重置辅料 (Step 3)
            const trimCategories = ['metal', 'bag', 'hangtag', 'label', 'hygiene', 'other'];
            trimCategories.forEach(category => {
                // 将单选按钮强制切回 "否" (value="no")
                const noRadio = document.querySelector(`input[name="need_${category}"][value="no"]`);
                if(noRadio) noRadio.checked = true;
                // 触发隐藏面板及恢复右侧文本
                toggleTrim(category, false); 
            });
            // 彻底清空包装袋数据
            bagConfig = { material: '未选材质', size: '未选尺寸', print: '未选印刷' };
            document.querySelectorAll('.bag-material, .bag-size, .bag-print').forEach(item => item.classList.remove('selected'));
            if(document.getElementById('bag-design-file')) document.getElementById('bag-design-file').value = '';

            // 4. 重置物流交付 (Step 4)
            document.querySelectorAll('#step-4 .option-item').forEach(item => item.classList.remove('selected'));
            document.getElementById('sum-shipping').innerText = '未选择';

            // 5. 重置最终备注 (Step 5)
            const finalRemark = document.querySelector('#step-5 textarea');
            if (finalRemark) finalRemark.value = '';

            // 6. 界面回到第一步
            if (currentStep !== 1) {
                // 计算当前步数与第1步的差值，通过 changeStep 函数自动处理页面切换
                changeStep(1 - currentStep); 
            }
        }

    </script>
</body>
</html>
