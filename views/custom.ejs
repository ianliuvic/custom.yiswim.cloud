<!DOCTYPE html>
<html lang="<%= lng === 'en' ? 'en' : 'zh-CN' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/custom.css">
    <link rel="stylesheet" href="/modal.css">
    <style>
        /* 移动端抽屉（内联，防缓存） */
        .mobile-summary-fab { display: none !important; }
        .drawer-backdrop { display: none; }
        .drawer-handle { display: none; }
        @media (max-width: 1024px) {
            .mobile-summary-fab {
                display: flex !important;
                position: fixed !important;
                bottom: 70px !important; left: 20px !important;
                z-index: 9990;
                width: 52px !important; height: 52px !important;
                min-width: 52px; max-width: 52px;
                min-height: 52px; max-height: 52px;
                border-radius: 50% !important;
                background: var(--primary-color) !important;
                color: #fff !important; border: none !important;
                padding: 0 !important;
                align-items: center; justify-content: center;
                box-shadow: none;
                cursor: pointer;
                -webkit-appearance: none; appearance: none;
            }
            .mobile-summary-fab:active { transform: scale(0.92); }
            .summary-sidebar {
                display: block !important;
                position: fixed !important;
                bottom: 0; left: 0; right: 0;
                width: 100% !important; min-width: unset !important;
                max-height: 75vh;
                z-index: 9999;
                background: #fff;
                border-radius: 20px 20px 0 0;
                box-shadow: 0 -10px 40px rgba(0,0,0,0.15);
                padding: 24px 24px 32px;
                transform: translateY(100%);
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
                overflow-y: auto;
            }
            .summary-sidebar.drawer-open { transform: translateY(0) !important; }
            .drawer-backdrop {
                position: fixed; inset: 0;
                background: rgba(0,0,0,0.4);
                z-index: 9998;
                backdrop-filter: blur(2px);
                opacity: 0; pointer-events: none;
                transition: opacity 0.3s;
            }
            .drawer-backdrop.active { display: block !important; opacity: 1; pointer-events: auto; }
            .drawer-handle {
                display: block !important;
                width: 40px; height: 4px;
                background: #cbd5e1;
                border-radius: 4px;
                margin: 0 auto 16px;
            }
        }
    </style>
    <script>window.__lang = '<%= lng %>';</script>
    <script src="/i18n.js"></script>
    <script src="/modal.js"></script>
</head>
<body>

    <header class="site-header">
        <div class="header-left" onclick="goToStep1()" style="cursor:pointer" title="返回第一步">
            <img src="/logo.png" alt="Hongxiu Logo" class="site-logo" onerror="this.style.display='none'">
            <span class="site-title">红绣服饰定制系统</span>
        </div>
        <div class="header-right" style="font-size: 14px; color: var(--text-light); display: flex; align-items: center; gap: 12px;">
            <button onclick="setLanguage('<%= lng === 'en' ? 'zh' : 'en' %>')" style="background: none; border: 1px solid var(--border-color); border-radius: 20px; padding: 5px 14px; font-size: 12px; cursor: pointer; color: var(--text-light); transition: all 0.25s; display: inline-flex; align-items: center; gap: 5px; font-weight: 500; letter-spacing: 0.3px;" onmouseover="this.style.borderColor='var(--primary-color)';this.style.color='var(--primary-color)';this.querySelector('svg').style.stroke='var(--primary-color)'" onmouseout="this.style.borderColor='var(--border-color)';this.style.color='var(--text-light)';this.querySelector('svg').style.stroke='currentColor'">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: stroke 0.25s;"><path d="M5 8l6 0"/><path d="M4 12l7 0"/><path d="M8 8c0 2.5-1.5 5-4 6.5"/><path d="M6 8c0 1.5.8 3 2.5 4.5"/><path d="M14 12l3.5 8"/><path d="M14 12l-3.5 8"/><path d="M11.5 17h5"/></svg>
                <%= lng === 'en' ? '中文' : 'EN' %>
            </button>
            <span class="header-user-text">当前用户：<strong><%= user.username %></strong> | 
            <a href="/user" style="color: var(--primary-color); text-decoration: none; font-weight: 500;">用户中心</a> | 
            <a href="/logout" style="color: var(--primary-color); text-decoration: none; font-weight: 500;">安全退出</a></span>
        </div>
    </header>

    <div class="main-container">
        <main class="config-main">
            <nav class="stepper">
                <div class="step active" id="step-1-label">01. 款式定义</div>
                <div class="step" id="step-2-label">02. 面料材质</div>
                <div class="step" id="step-3-label">03. 品牌辅料</div>
                <div class="step" id="step-4-label">04. 物流交付</div>
                <div class="step" id="step-5-label">05. 需求汇总</div>
            </nav>

            <div class="config-scroll-area">
                <form id="configForm" onsubmit="event.preventDefault();">
                    <!-- ==========================================
                         步骤 1: 款式定义
                         ========================================== -->
                    <div class="step-content" id="step-1">
                        <div class="step-desc">请选择定制模式：从现有库中挑选 (ODM) 或 上传自主设计包 (OEM)，支持同时选择/上传多款。</div>
                        
                        <!-- --- 修改后 --- -->
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px;">
                            <div class="mode-switcher" style="margin-bottom: 0;"> <!-- 移除原有 margin-bottom -->
                                <div class="mode-option active" id="mode-odm" onclick="toggleStyleMode('existing')">现有款式 (ODM)</div>
                                <div class="mode-option" id="mode-oem" onclick="toggleStyleMode('custom')">自主设计 (OEM)</div>
                            </div>
                            
                            <button type="button" class="clear-all-btn" onclick="clearCurrentMode()" title="仅清空当前模式的选择">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;">
                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                清空当前选择
                            </button>
                        </div>

                        <!-- 动态生成的 ODM 区域 -->
                        <div id="existing-styles">
                            <div class="category-nav" id="odm-category-nav"><p style="font-size:12px; color:#999;">正在加载款式数据...</p></div>
                            <div id="odm-content-container"></div>
                        </div>

                        <!-- OEM 自主设计模块 -->
                        <div id="custom-upload" class="hidden" style="animation: fadeIn 0.4s ease;">
                            <!-- 新增：项目系列名称与款式数量 -->
                            <div class="oem-section-header" style="margin-bottom: 18px;">
                                <h4 style="font-size: 14px; margin: 0; border-left: 3px solid var(--primary-color); padding-left: 10px;">A. 项目基本信息</h4>
                            </div>  
                            <div class="oem-upload-section" style="margin-bottom: 25px; padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px; background: #fbfcfd;">
                                <div style="display: flex; gap: 20px; align-items: flex-start; margin-bottom: 15px;">
                                    <div style="flex: 2;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">项目/系列名称 <span style="color:#ef4444;">*</span></label>
                                        <input type="text" id="oem-collection-name" class="oem-input-mini" style="width:100%; height:38px; box-sizing:border-box;" placeholder="例如: 2026 Summer Neon Series" autocomplete="off" oninput="updateCombinedStyleSummary()">
                                    </div>
                                    <div style="flex: 1;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">包含款式数 <span style="color:#ef4444;">*</span></label>
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <input type="number" id="oem-collection-count" class="oem-input-mini" style="width:100%; height:38px; box-sizing:border-box;" value="0" min="0" max="50" oninput="renderOemStyleDescInputs()">
                                            <span style="font-size: 12px; color: #64748b;">款</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- 项目简要描述 -->
                                <div style="margin-bottom: 15px;">
                                    <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">项目/系列简要描述</label>
                                    <textarea id="oem-project-desc" class="oem-input-mini" style="width:100%; min-height:56px; box-sizing:border-box; resize:vertical; font-size:12px; line-height:1.6; padding:8px 12px;" placeholder="简要描述您即将上传的款式的整体信息，例如：产品类型、设计风格、目标市场等" maxlength="500"></textarea>
                                </div>
                                <!-- 动态生成的款式简述容器 -->
                                <div id="oem-style-desc-container" style="display: flex; flex-direction: column; gap: 10px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span style="font-size: 11px; font-weight: 600; color: var(--primary-color); min-width: 45px;">款 1 :</span>
                                        <input type="text" class="oem-input-mini" style="flex: 1; height: 32px; font-size: 12px; background: #fff;" placeholder="简要标识 (如: 红色连体款 / Page 1 比基尼上衣)" value="" oninput="oemStyleDescriptions[0]=this.value; updateCombinedStyleSummary();">
                                    </div>
                                </div>
                            </div>
                            <!-- 微调后的极简提示 (暖色调/细虚线/小字体) -->
                            <div style="margin-bottom: 15px; padding: 8px 12px; background: #fffdf5; border: 1px dashed #fde68a; border-radius: 6px; display: flex; align-items: flex-start; gap: 8px;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                <div style="font-size: 11px; color: #92400e; line-height: 1.5;">
                                    <strong>上传对应提示：</strong>若申报了多款设计，请确保下方上传的<strong>参考图文件名</strong>或<strong>工艺单页码</strong>能与 A 区域填写的“款 1、款 2...”描述清晰对应。
                                </div>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 25px; align-items: start;">
                                <!-- A. 灵感参考图 -->
                                <div class="oem-upload-section">
                                    <div class="oem-section-header" style="margin-bottom: 12px;">
                                        <h4 style="font-size: 14px; margin: 0 0 4px; border-left: 3px solid var(--primary-color); padding-left: 10px;">B. 参考图与灵感</h4>
                                        <span class="oem-subtitle" style="margin-left: 13px;">请上传款式参考图或草图 (仅限图片)</span>
                                    </div>
                                    <div class="oem-dropzone" id="oemRefDropzone" onclick="document.getElementById('oemRefFile').click()">
                                        <div style="text-align: center;">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                            <p style="margin-top: 8px; font-size: 12px; color: #64748b;">拖拽或点击上传图片</p>
                                        </div>
                                        <input type="file" id="oemRefFile" accept="image/*" multiple class="hidden" onchange="handleOemFiles(this, 'ref')">
                                    </div>
                                    <div id="oemRefPreview" class="oem-image-preview-grid"></div>
                                </div>
                        
                                <!-- B. 工艺单/设计稿 -->
                                <div class="oem-upload-section">
                                    <div class="oem-section-header" style="margin-bottom: 12px;">
                                        <h4 style="font-size: 14px; margin: 0 0 4px; border-left: 3px solid var(--primary-color); padding-left: 10px;">C. 工艺单/设计稿</h4>
                                        <span class="oem-subtitle" style="margin-left: 13px;">支持图片、PDF、AI、EPS 等格式</span>
                                    </div>

                                    <div class="oem-dropzone" id="oemTechDropzone" onclick="document.getElementById('oemTechFile').click()">
                                        <div style="text-align: center;">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                            <p style="margin-top: 8px; font-size: 12px; color: #64748b;">拖拽或点击上传工艺文件</p>
                                        </div>
                                        <input type="file" id="oemTechFile" multiple class="hidden" onchange="handleOemFiles(this, 'tech')">
                                    </div>
                                    <div id="oemTechPreview" class="oem-image-preview-grid"></div>
                                </div>
                            </div>

                            <!-- D. 尺寸信息 -->
                            <div class="oem-upload-section" style="margin-bottom: 25px;">
                                <div class="oem-section-header" style="margin-bottom: 12px;">
                                    <h4 style="font-size: 14px; margin: 0 0 4px; border-left: 3px solid var(--primary-color); padding-left: 10px;">D. 尺寸信息</h4>
                                    <span class="oem-subtitle" style="margin-left: 13px;">请提供尺寸说明或上传尺寸文件</span>
                                </div>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                                    <!-- 左：文字描述 -->
                                    <div>
                                        <span class="oem-subtitle" style="display: block; margin-bottom: 8px;">尺寸文字说明</span>
                                        <textarea id="oem-size-remark" class="oem-textarea" style="height: 150px;" placeholder="请描述尺码范围、各部位尺寸要求等..." spellcheck="false" oninput="updateCombinedStyleSummary()"></textarea>
                                    </div>
                                    <!-- 右：文件上传 -->
                                    <div>
                                        <span class="oem-subtitle" style="display: block; margin-bottom: 8px;">尺寸文件上传 (支持图片、PDF、AI、EPS 等格式)</span>
                                        <div class="oem-dropzone" id="oemSizeDropzone" onclick="document.getElementById('oemSizeFile').click()" style="height: 150px; box-sizing: border-box;">
                                            <div style="text-align: center;">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                                <p style="margin-top: 8px; font-size: 12px; color: #64748b;">拖拽或点击上传尺寸文件</p>
                                            </div>
                                            <input type="file" id="oemSizeFile" multiple class="hidden" onchange="handleOemFiles(this, 'size')">
                                        </div>
                                        <div id="oemSizePreview" class="oem-image-preview-grid"></div>
                                    </div>
                                </div>
                            </div>
                        
                            <div class="oem-upload-section" style="margin-bottom: 25px;">
                                <h4 style="font-size: 14px; margin-bottom: 15px; border-left: 3px solid var(--primary-color); padding-left: 10px;">E. 补充说明</h4>
                                <textarea id="oem-remark" class="oem-textarea" style="min-height: 150px; resize: vertical;" placeholder="请详细描述您的修改要求或特定工艺要求..." spellcheck="false" oninput="updateCombinedStyleSummary()"></textarea>
                            </div>

                            <div style="background: #fff; border-radius: 12px; display: flex; flex-direction: column; gap: 12px; margin-bottom: 25px;">
                                <div>
                                    <label class="oem-checkbox-label" style="margin: 0; padding: 0;">
                                        <input type="checkbox" id="oem-physical" onchange="togglePhysicalInfo(this.checked)"> 寄送实体样衣进行打版参考
                                    </label>
                                </div>
                                <div id="oem-address-info" class="hidden" style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px dashed #cbd5e1; display: flex; flex-direction: column; gap: 10px; font-size: 12.5px; color: #475569; transition: all 0.3s;">
                                    <div style="display: flex; align-items: flex-start; gap: 6px; line-height: 1.5;">
                                        <span style="font-size: 14px;">📍</span>
                                        <span><strong>收件地址：</strong>中国辽宁省兴城市铁西路10-8A红绣服饰有限公司 (收件人：刘先生 177-1101-4152)</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 10px; margin-top: 4px;">
                                        <span style="font-weight: 500;">寄件单号 (选填)：</span>
                                        <input type="text" class="oem-input-mini" style="flex: 1; max-width: 300px; background: #fff;" placeholder="若已寄出请填写；若尚未寄出，可稍后告知业务经理" autocomplete="off" oninput="updateCombinedStyleSummary()">
                                    </div>
                                </div>
                            </div>

                            <!-- 新增：F. 易漏设计细节核对单 -->
                            <div class="oem-upload-section" id="oem-checklist-section" style="margin-bottom: 25px; background: #fffdf5; border: 1px solid #fde68a; padding: 20px; border-radius: 12px; transition: all 0.3s;">
                                <!-- 标题与全选按钮的左右布局 -->
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                    <div style="display: flex; align-items: flex-start; gap: 10px; padding-right: 20px;">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" style="margin-top: 2px; flex-shrink: 0;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        <div>
                                            <h4 style="font-size: 14px; margin: 0 0 6px; color: #92400e;">核心工艺与细节确认单 <span style="color:#ef4444;">*</span></h4>
                                            <p style="font-size: 11.5px; color: #b45309; margin: 0; line-height: 1.5;">为确保大货落地的极致精准度，以下为您自主设计中<strong>最关键且极易被遗漏的工艺指标</strong>。请务必核对您在上方上传的设计稿或补充说明中已涵盖以下内容，并<strong style="color: #ef4444;">逐一打勾确认</strong>方可进入下一步。</p>
                                        </div>
                                    </div>
                                    
                                    <!-- 一键全选按钮 -->
                                    <button type="button" class="clear-all-btn" id="oem-check-all-btn" onclick="toggleAllOemChecklists()" style="color: #d97706; border: 1px solid #fde68a; background: #fff; padding: 5px 12px; flex-shrink: 0;">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px; vertical-align: -1px;">
                                            <polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                                        </svg>
                                        一键全选
                                    </button>
                                </div>

                                <!-- 改为无间距的连续列表 -->
                                <div id="oem-checklist-container" style="display: flex; flex-direction: column; background: transparent;">
                                    <p style="font-size: 12px; color: #94a3b8; margin: 0;">正在加载必填核对单...</p>
                                </div>

                            </div>
                            
                            <div style="display: flex; justify-content: flex-end; padding-right: 5px; margin-top: 8px;">
                                <div style="display: inline-flex; align-items: center; gap: 6px; color: #64748b; font-size: 12px; font-weight: 500; cursor: pointer; transition: color 0.2s;" 
                                     onmouseover="this.style.color='var(--primary-color)'" 
                                     onmouseout="this.style.color='#64748b'" 
                                     onclick="openNdaModal()">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                    </svg>
                                    <span>所有设计均受 <span style="text-decoration: underline; text-underline-offset: 3px;">保密协议 (NDA)</span> 严格保护</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ==========================================
                         步骤 2: 面料与里料
                         ========================================== -->
                    <div class="step-content hidden" id="step-2">
                        <div class="step-desc">请分别选择对应部位的面料材质。选中后在下方配置台中定义颜色或印花。</div>
                        
                        <!-- 动态生成的 面料切换器 (Mode Switcher 风格) -->
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px;">
                            <div class="mode-switcher" id="fabric-sub-tabs" style="margin-bottom: 0;">
                                <p style="font-size:12px; color:#999; padding: 8px;">正在加载面料数据...</p>
                            </div>
                            
                            <button type="button" class="clear-all-btn" onclick="clearCurrentFabric()" title="仅清空当前面料分类的选择">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;">
                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                清空当前分类
                            </button>
                        </div>

                        <!-- 动态生成的 面料面板 (将原来的主面料、里料面板替换为这一个容器) -->
                        <div id="fabric-panes-container"></div>

                        <div id="fabric-config-panel" class="fabric-config-panel hidden">
                            <div id="config-arrow" class="config-arrow"></div>
                            <div class="config-header">
                                <h4 id="selected-fabric-display">配置选项</h4>
                                <span id="config-type-tag" style="font-size: 11px; padding: 2px 8px; border-radius: 10px; background: #eee; color: #666;">面料</span>
                            </div>
                            
                            <!-- 新增：定制找样专属表单 (默认隐藏) -->
