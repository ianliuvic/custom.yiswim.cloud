<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
    <style>
        /* 深度定制化：扁平化专业设计 */
        :root {
            --primary-color: #aa0000;
            --text-main: #2c3e50;
            --text-light: #7f8c8d;
            --bg-body: #ffffff;
            --bg-side: #fafafa;
            --border-color: #ececec;
        }

        body {
            background-color: var(--bg-body);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: var(--text-main);
        }

        /* 顶部导航：去除阴影，使用细边框 */
        .site-header {
            height: 70px;
            background: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            border-bottom: 1px solid var(--border-color);
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .site-logo {
            height: 40px;
            width: auto;
        }
        .site-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-main);
            letter-spacing: 0.5px;
        }

        /* 主体内容布局 */
        .main-container {
            flex: 1;
            display: flex;
            width: 100%;
        }

        /* 左侧：定制区域 */
        .config-main {
            flex: 1;
            padding: 40px 60px;
            border-right: 1px solid var(--border-color);
        }

        /* 右侧：汇总区域（更平整的侧边栏） */
        .summary-sidebar {
            width: 380px;
            background-color: var(--bg-side);
            padding: 40px;
            position: sticky;
            top: 70px;
            height: calc(100vh - 70px);
            overflow-y: auto;
        }

        /* 进度条：扁平化设计 */
        .stepper {
            display: flex;
            margin-bottom: 50px;
            gap: 20px;
        }
        .step {
            flex: 1;
            padding-bottom: 10px;
            border-bottom: 3px solid #eee;
            font-size: 14px;
            color: var(--text-light);
            transition: all 0.3s;
        }
        .step.active {
            border-bottom-color: var(--primary-color);
            color: var(--primary-color);
            font-weight: 600;
        }

        /* 选项设计：摒弃浮动卡片，改为平铺卡片 */
        .option-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 25px;
        }
        .option-item {
            border: 1px solid var(--border-color);
            background: #fff;
            padding: 0;
            cursor: pointer;
            transition: all 0.2s ease;
            overflow: hidden;
        }
        .option-item:hover {
            border-color: var(--primary-color);
        }
        .option-item.selected {
            border-color: var(--primary-color);
            background-color: #fff9f9;
            outline: 1px solid var(--primary-color);
        }
        .option-img {
            width: 100%;
            height: 180px;
            background-color: #f9f9f9;
            object-fit: cover;
            border-bottom: 1px solid var(--border-color);
        }
        .option-info {
            padding: 15px;
        }
        .option-info h4 { margin: 0 0 5px; font-size: 15px; }
        .option-info p { margin: 0; font-size: 13px; color: var(--text-light); }

        /* 底部版权信息 */
        .site-footer {
            padding: 25px 40px;
            border-top: 1px solid var(--border-color);
            text-align: left;
            font-size: 13px;
            color: #999;
            background-color: #fff;
        }

        /* 按钮设计 */
        .button-group {
            margin-top: 60px;
            display: flex;
            gap: 15px;
        }
        button {
            padding: 12px 30px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid var(--primary-color);
            transition: all 0.3s;
        }
        #nextBtn { background: var(--primary-color); color: #fff; }
        #nextBtn:hover { opacity: 0.9; }
        #prevBtn { background: #fff; color: var(--primary-color); }
        #prevBtn:disabled { border-color: #eee; color: #ccc; cursor: not-allowed; }

        /* 侧边栏明细样式 */
        .summary-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 30px;
            display: block;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 14px;
            border-bottom: 1px dashed #eee;
            padding-bottom: 10px;
        }
        .summary-row .label { color: var(--text-light); }
        .summary-row .value { color: var(--text-main); font-weight: 500; }

        .hidden { display: none !important; }
    </style>
</head>
<body>

    <!-- 顶部导航 -->
    <header class="site-header">
        <div class="header-left">
            <img src="/logo.png" alt="Hongxiu Logo" class="site-logo">
            <span class="site-title">Hongxiu Custom System</span>
        </div>
        <div class="header-right" style="font-size: 14px; color: var(--text-light);">
            当前用户：<strong><%= user.username %></strong> | <a href="/logout" style="color: var(--primary-color); text-decoration: none;">退出系统</a>
        </div>
    </header>

    <div class="main-container">
        <!-- 左侧：逻辑配置区 -->
        <main class="config-main">
            <nav class="stepper">
                <div class="step active" id="step-1-label">01. 款式选择</div>
                <div class="step" id="step-2-label">02. 面料参数</div>
                <div class="step" id="step-3-label">03. 品牌辅助</div>
                <div class="step" id="step-4-label">04. 物流交付</div>
                <div class="step" id="step-5-label">05. 确认提交</div>
            </nav>

            <form id="configForm">
                <!-- 第一步 -->
                <div class="step-content" id="step-1">
                    <h2 style="font-size: 22px; margin-bottom: 10px;">选择您的基本款式</h2>
                    <p style="color: var(--text-light); margin-bottom: 30px;">选择我们为您准备的经典廓形，或通过 OEM 模式提交您的设计方案。</p>
                    
                    <div style="margin-bottom: 30px;">
                        <input type="radio" id="m1" name="styleMode" checked onclick="toggleStyleMode('existing')">
                        <label for="m1" style="margin-right: 20px;">现有库选择 (ODM)</label>
                        <input type="radio" id="m2" name="styleMode" onclick="toggleStyleMode('custom')">
                        <label for="m2">自定义开发 (OEM)</label>
                    </div>

                    <div id="existing-styles" class="option-grid">
                        <div class="option-item" onclick="selectItem('style', 'One-Piece', '简约连体款')">
                            <img src="https://images.unsplash.com/photo-1576188973526-0e5d742990af?w=400" class="option-img">
                            <div class="option-info">
                                <h4>Classic One-Piece</h4>
                                <p>经典版型 · 覆盖面广</p>
                            </div>
                        </div>
                        <div class="option-item" onclick="selectItem('style', 'Bikini Set', '分体比基尼')">
                            <img src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?w=400" class="option-img">
                            <div class="option-info">
                                <h4>Triangle Bikini</h4>
                                <p>热辣时尚 · 灵活调节</p>
                            </div>
                        </div>
                    </div>

                    <div id="custom-upload" class="hidden" style="padding: 40px; border: 1px dashed var(--border-color); text-align: center; background: #fdfdfd;">
                        <p>请拖拽或点击上传您的技术包 (Tech Pack) 或款式图片</p>
                        <input type="file" multiple>
                    </div>
                </div>

                <!-- 第二步：面料 -->
                <div class="step-content hidden" id="step-2">
                    <h2 style="font-size: 22px; margin-bottom: 30px;">面料与成分选择</h2>
                    <div class="option-grid">
                        <div class="option-item" onclick="selectItem('fabric', 'Nylon 190G', '哑光尼龙 (190G)')">
                            <div style="height:120px; background:#333;"></div>
                            <div class="option-info">
                                <h4>Matte Nylon</h4>
                                <p>80% Nylon, 20% Spandex</p>
                            </div>
                        </div>
                        <div class="option-item" onclick="selectItem('fabric', 'Repreve 200G', '再生环保面料')">
                            <div style="height:120px; background:#1a3c34;"></div>
                            <div class="option-info">
                                <h4>REPREVE® Eco</h4>
                                <p>100% 可回收材料</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 后面步骤略，保持 HTML 结构一致 -->
                <div class="step-content hidden" id="step-3"><h3>品牌定制内容</h3><p>此模块正在根据您的需求加载选项...</p></div>
                <div class="step-content hidden" id="step-4"><h3>交付与物流</h3><p>此模块正在根据您的需求加载选项...</p></div>
                <div class="step-content hidden" id="step-5"><h3>核对需求预览</h3><p>请在右侧检查您的最终选择，确认无误后提交。</p></div>

                <div class="button-group">
                    <button type="button" id="prevBtn" class="btn-outline" onclick="changeStep(-1)" disabled>返回上一步</button>
                    <button type="button" id="nextBtn" onclick="changeStep(1)">继续下一步</button>
                </div>
            </form>
        </main>

        <!-- 右侧：汇总预览 -->
        <aside class="summary-sidebar">
            <span class="summary-title">SELECTED DETAILS / 需求清单</span>
            
            <div class="summary-row">
                <span class="label">款式类型</span>
                <span class="value" id="sum-style">未选择</span>
            </div>
            <div class="summary-row">
                <span class="label">面料材质</span>
                <span class="value" id="sum-fabric">未选择</span>
            </div>
            <div class="summary-row">
                <span class="label">品牌辅料</span>
                <span class="value" id="sum-branding">未选择</span>
            </div>
            <div class="summary-row">
                <span class="label">交付方式</span>
                <span class="value" id="sum-shipping">未选择</span>
            </div>

            <div style="margin-top: 50px; padding: 20px; background: #fff; border: 1px solid var(--border-color); font-size: 13px;">
                <strong>温馨提示：</strong><br>
                提交后，我们的系统将自动为您生成初步技术规格书。业务代表将在1个工作日内联系您核对起订量（MOQ）与单价。
            </div>
        </aside>
    </div>

    <!-- 底部版权 -->
    <footer class="site-footer">
        © 2026 红绣服饰 (Hongxiu Clothing). All Rights Reserved. | 专属定制 · 品质追踪
    </footer>

    <script>
        let currentStep = 1;
        const totalSteps = 5;

        function changeStep(n) {
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.remove('active');
            currentStep += n;
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.add('active');

            document.getElementById('prevBtn').disabled = (currentStep === 1);
            document.getElementById('nextBtn').innerText = (currentStep === totalSteps) ? '确认提交需求' : '继续下一步';
        }

        function toggleStyleMode(mode) {
            const list = document.getElementById('existing-styles');
            const upload = document.getElementById('custom-upload');
            if(mode === 'existing') {
                list.classList.remove('hidden'); upload.classList.add('hidden');
            } else {
                list.classList.add('hidden'); upload.classList.remove('hidden');
                document.getElementById('sum-style').innerText = '自定义 OEM';
            }
        }

        function selectItem(category, value, displayName) {
            document.getElementById(`sum-${category}`).innerText = displayName;
            const container = document.getElementById(`step-${currentStep}`);
            container.querySelectorAll('.option-item').forEach(item => item.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }
    </script>
</body>
</html>
