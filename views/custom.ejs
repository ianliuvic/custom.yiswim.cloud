    .auth-modal .toggle-password:hover { color: var(--primary-color); }
    .auth-modal .eye-icon { width: 18px; height: 18px; }
    .auth-modal .auth-submit-btn { background: var(--primary-color); color: #fff; border: none; padding: 13px; font-size: 15px; font-weight: 600; border-radius: 0; cursor: pointer; transition: background 0.25s; margin-top: 4px; }
    .auth-modal .auth-submit-btn:hover { background: var(--primary-hover, #880000); }
    .auth-modal .auth-submit-btn:disabled { background: #d48080; cursor: not-allowed; }
    .auth-modal .links { margin-top: 20px; display: flex; flex-direction: column; align-items: center; gap: 10px; font-size: 13px; color: #666; }
    .auth-modal .links span { color: var(--primary-color); cursor: pointer; font-weight: 500; }
    .auth-modal .links span:hover { text-decoration: underline; }
    .auth-modal .help-text { font-size: 13px; color: #666; text-align: center; margin-bottom: 16px; line-height: 1.5; }
    .auth-hidden { display: none !important; }
</style>

<div class="auth-overlay" id="authOverlay">
    <div class="auth-modal">
        <button class="auth-close" onclick="closeAuth()">&times;</button>
        <div id="auth-status-msg" class="auth-status-msg auth-hidden"></div>

        <!-- Login -->
        <div id="login-box" class="auth-form-box">
            <h2><%= lng === 'zh' ? '用户登录' : 'Login' %></h2>
            <form id="authLoginForm">
                <input class="auth-input" type="text" id="authLoginUser" placeholder="<%= lng === 'zh' ? '用户名或邮箱' : 'Username or Email' %>" required>
                <div class="password-wrapper">
                    <input class="auth-input" type="password" id="authLoginPass" placeholder="<%= lng === 'zh' ? '密码' : 'Password' %>" required>
                    <span class="toggle-password" onclick="toggleAuthPassword('authLoginPass', this)">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>
                <button type="submit" class="auth-submit-btn"><%= lng === 'zh' ? '登 录' : 'Login' %></button>
            </form>
            <div style="text-align: center; margin: 16px 0; color: #94a3b8; font-size: 12px; position: relative;">
                <span style="background: #fff; padding: 0 10px; position: relative; z-index: 1;">OR</span>
                <div style="position: absolute; top: 50%; left: 0; right: 0; border-top: 1px solid #e1e4e8; z-index: 0;"></div>
            </div>
            <div class="google-btn-container" style="display: flex; justify-content: center; margin-bottom: 16px;"></div>
            <div class="links">
                <span onclick="switchAuthBox('register-box')"><%= lng === 'en' ? "Don't have an account? Register" : 'No account? Register' %></span>
                <span onclick="switchAuthBox('forgot-box')"><%= lng === 'zh' ? '忘记密码？' : 'Forgot password?' %></span>
            </div>
        </div>

        <!-- Register -->
        <div id="register-box" class="auth-form-box auth-hidden">
            <h2><%= lng === 'zh' ? '创建账号' : 'Create Account' %></h2>
            <form id="authRegisterForm">
                <input class="auth-input" type="text" id="authRegUser" placeholder="<%= lng === 'zh' ? '设置用户名' : 'Username' %>" required>
                <input class="auth-input" type="email" id="authRegEmail" placeholder="<%= lng === 'zh' ? '常用邮箱' : 'Email' %>" required>
                <div class="password-wrapper">
                    <input class="auth-input" type="password" id="authRegPass" placeholder="<%= lng === 'zh' ? '设置密码 (至少8位)' : 'Password (min 8 chars)' %>" required>
                    <span class="toggle-password" onclick="toggleAuthPassword('authRegPass', this)">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>
                <button type="submit" class="auth-submit-btn"><%= lng === 'zh' ? '注 册' : 'Register' %></button>
            </form>
            <div style="text-align: center; margin: 16px 0; color: #94a3b8; font-size: 12px; position: relative;">
                <span style="background: #fff; padding: 0 10px; position: relative; z-index: 1;">OR</span>
                <div style="position: absolute; top: 50%; left: 0; right: 0; border-top: 1px solid #e1e4e8; z-index: 0;"></div>
            </div>
            <div class="google-btn-container" style="display: flex; justify-content: center; margin-bottom: 16px;"></div>
            <div class="links">
                <span onclick="switchAuthBox('login-box')"><%= lng === 'zh' ? '已有账号？返回登录' : 'Already have an account? Login' %></span>
            </div>
        </div>

        <!-- Forgot Password -->
        <div id="forgot-box" class="auth-form-box auth-hidden">
            <h2><%= lng === 'zh' ? '找回密码' : 'Reset Password' %></h2>
            <p class="help-text"><%= lng === 'zh' ? '请输入您注册时使用的邮箱，我们将向您发送重置链接。' : 'Enter the email you registered with and we will send you a reset link.' %></p>
            <form id="authForgotForm">
                <input class="auth-input" type="email" id="authForgotEmail" placeholder="<%= lng === 'zh' ? '注册邮箱' : 'Registered email' %>" required>
                <button type="submit" class="auth-submit-btn"><%= lng === 'zh' ? '发送重置邮件' : 'Send Reset Email' %></button>
            </form>
            <div class="links">
                <span onclick="switchAuthBox('login-box')"><%= lng === 'zh' ? '记起密码了？返回登录' : 'Remember your password? Login' %></span>
            </div>
        </div>
    </div>
</div>

<script>
    /* ===== Auth Modal Logic ===== */
    (function() {
        var gClientId = '<%= typeof googleClientId !== "undefined" ? googleClientId : "" %>';

        function initGoogleBtn() {
            if (!gClientId || typeof google === 'undefined') return;
            google.accounts.id.initialize({ client_id: gClientId, callback: handleGoogleResponse });
            document.querySelectorAll('.google-btn-container').forEach(function(c) {
                google.accounts.id.renderButton(c, { theme: 'outline', size: 'large', width: '100%', locale: window.__lang || 'en' });
            });
        }

        // gsi/client loads async — try now, fallback to window.onload
        if (typeof google !== 'undefined') { initGoogleBtn(); }
        else { window.addEventListener('load', initGoogleBtn); }

        // === No-reload login: update header UI in-place ===
        function onLoginSuccess(username) {
            window.__isLoggedIn = true;

            // Desktop header text
            var headerTextSpans = document.querySelectorAll('.header-user-text');
            var lang = window.__lang || 'en';
            if (headerTextSpans.length > 0) {
                // First .header-user-text is for desktop logged-in state (replace guest buttons)
                headerTextSpans.forEach(function(span) {
                    span.innerHTML =
                        '<strong style="color: var(--text-main);">' + username + '</strong>' +
                        '<a href="/user" style="color: var(--text-light); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color=\'var(--primary-color)\'" onmouseout="this.style.color=\'var(--text-light)\'">' + (lang === 'zh' ? '用户中心' : 'User Center') + '</a>' +
                        '<a href="/logout" style="color: var(--text-light); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color=\'var(--primary-color)\'" onmouseout="this.style.color=\'var(--text-light)\'">' + (lang === 'zh' ? '退出' : 'Log Out') + '</a>';
                });
            }

            // Mobile header avatar menu
            var avatarWrap = document.querySelector('.header-avatar-wrap');
            if (avatarWrap) {
                avatarWrap.innerHTML =
                    '<button class="header-avatar-btn" onclick="toggleUserMenu(event)">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' +
                    '</button>' +
                    '<div class="header-user-menu" id="headerUserMenu">' +
                        '<div class="header-user-menu-name">' + username + '</div>' +
                        '<a href="/user" class="header-user-menu-item">' +
                            '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> User Center' +
                        '</a>' +
                        '<a href="/logout" class="header-user-menu-item header-user-menu-logout">' +
                            '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> Log Out' +
                        '</a>' +
                    '</div>';
            }

            // Close auth modal
            closeAuth();

            // Show success toast
            var toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:99999;padding:12px 24px;border-radius:0;background:#065f46;color:#fff;font-size:14px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,.15);transition:opacity .5s;';
            toast.textContent = lang === 'zh' ? '登录成功！' : 'Login successful!';
            document.body.appendChild(toast);
            setTimeout(function() { toast.style.opacity = '0'; }, 2500);
            setTimeout(function() { toast.remove(); }, 3000);
        }

        async function handleGoogleResponse(response) {
            hideAuthMsg();
            try {
                var res = await fetch('/api/google-auth', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token: response.credential }) });
                var result = await res.json();
                if (result.success) { window.dataLayer = window.dataLayer || []; window.dataLayer.push({ event: result.isNew ? 'user_register' : 'user_login', method: 'google' }); onLoginSuccess(result.username || 'User'); } else { showAuthMsg(result.message || 'Google Login Failed', 'error'); }
            } catch (err) { showAuthMsg(window.__lang === 'zh' ? '网络错误' : 'Network error', 'error'); }
        }

        window.openAuth = function(type) {
            var overlay = document.getElementById('authOverlay');
            overlay.classList.add('active');
            switchAuthBox(type === 'register' ? 'register-box' : 'login-box');
        };

        window.closeAuth = function() {
            document.getElementById('authOverlay').classList.remove('active');
            hideAuthMsg();
        };

        document.getElementById('authOverlay').addEventListener('click', function(e) { if (e.target === this) closeAuth(); });
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeAuth(); });

        window.switchAuthBox = function(boxId) {
            hideAuthMsg();
            document.querySelectorAll('.auth-form-box').forEach(function(b) { b.classList.add('auth-hidden'); });
            document.getElementById(boxId).classList.remove('auth-hidden');
        };

        function showAuthMsg(text, type) {
            var box = document.getElementById('auth-status-msg');
            box.innerText = text;
            box.classList.remove('auth-hidden', 'status-error', 'status-success');
            box.classList.add(type === 'success' ? 'status-success' : 'status-error');
        }

        function hideAuthMsg() {
            var box = document.getElementById('auth-status-msg');
            if (box) box.classList.add('auth-hidden');
        }

        window.toggleAuthPassword = function(inputId, el) {
            var input = document.getElementById(inputId);
            var eyeOpen = '<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
            var eyeClose = '<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
            input.type = input.type === 'password' ? 'text' : 'password';
            el.innerHTML = input.type === 'password' ? eyeClose : eyeOpen;
        };

        async function authSubmit(e, endpoint, payload) {
            e.preventDefault();
            hideAuthMsg();
            var btn = e.target.querySelector('.auth-submit-btn');
            var orig = btn.innerText;
            btn.innerText = window.__lang === 'zh' ? '处理中...' : 'Processing...';
            btn.disabled = true;
            try {
                var res = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                var result = await res.json();
                if (result.success) {
                    if (endpoint === '/api/login' || endpoint === '/api/google-auth') {
                        window.dataLayer = window.dataLayer || [];
                        window.dataLayer.push({ event: 'user_login', method: endpoint === '/api/google-auth' ? 'google' : 'email' });
                        onLoginSuccess(result.username || 'User');
                    } else {
                        if (endpoint === '/api/register' && result.isNew) {
                            window.dataLayer = window.dataLayer || [];
                            window.dataLayer.push({ event: 'user_register', method: 'email' });
                        }
                        showAuthMsg(result.message || (window.__lang === 'zh' ? '操作成功！' : 'Success!'), 'success');
                    }
                } else {
                    showAuthMsg(result.message || (window.__lang === 'zh' ? '操作失败' : 'Failed'), 'error');
                }
            } catch (err) {
                showAuthMsg(window.__lang === 'zh' ? '网络错误' : 'Network error', 'error');
            } finally { btn.innerText = orig; btn.disabled = false; }
        }

        document.getElementById('authLoginForm').addEventListener('submit', function(e) {
            authSubmit(e, '/api/login', { username: document.getElementById('authLoginUser').value, password: document.getElementById('authLoginPass').value });
        });

        document.getElementById('authRegisterForm').addEventListener('submit', function(e) {
            var pw = document.getElementById('authRegPass').value;
            if (pw.length < 8) { showAuthMsg(window.__lang === 'zh' ? '密码长度至少需要 8 位' : 'Password must be at least 8 characters', 'error'); e.preventDefault(); return; }
            authSubmit(e, '/api/register', { username: document.getElementById('authRegUser').value, email: document.getElementById('authRegEmail').value, password: pw });
        });

        document.getElementById('authForgotForm').addEventListener('submit', function(e) {
            authSubmit(e, '/api/forgot-password', { email: document.getElementById('authForgotEmail').value });
        });

        // Handle URL params
        var params = new URLSearchParams(window.location.search);
        if (params.get('activated') === 'true') {
            openAuth('login');
            setTimeout(function() { showAuthMsg(window.__lang === 'zh' ? '账号已激活，请登录。' : 'Account activated! Please login.', 'success'); }, 100);
        }
        if (params.get('auth') === 'login') openAuth('login');
        if (params.get('auth') === 'register') openAuth('register');
    })();
</script>
<% } %>

<!-- ===== Feedback Modal ===== -->
<div id="feedbackModalOverlay" style="display:none; position:fixed; inset:0; z-index:199990; background:rgba(0,0,0,0.55); backdrop-filter:blur(2px); justify-content:center; align-items:center;">
    <div class="feedback-modal-box">
        <div class="feedback-modal-header">
            <div>
                <div id="feedbackModalTitle" class="feedback-modal-title"></div>
                <div id="feedbackModalReward" class="feedback-modal-reward"></div>
            </div>
            <button onclick="closeFeedbackModal()" class="feedback-modal-close">&times;</button>
        </div>
        <div class="feedback-modal-body">
            <label class="feedback-label"><%= lng === 'zh' ? '描述内容' : 'Description' %> <span style="color:#94a3b8;font-size:12px;">(<%= lng === 'zh' ? '至少10字' : 'min 10 chars' %>)</span></label>
            <textarea id="feedbackContent" class="feedback-textarea" maxlength="2000" placeholder="<%= lng === 'zh' ? '请详细描述问题或使用体验...' : 'Please describe in detail...' %>"></textarea>
            <div class="feedback-char-count"><span id="feedbackCharCount">0</span> / 2000</div>
            <label class="feedback-label" style="margin-top:14px;"><%= lng === 'zh' ? '截图（可选，最多5张图片）' : 'Screenshots (optional, up to 5 images)' %></label>
            <div class="feedback-upload-area" onclick="document.getElementById('feedbackFileInput').click()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span><%= lng === 'zh' ? '点击上传截图' : 'Click to upload screenshots' %></span>
            </div>
            <input type="file" id="feedbackFileInput" accept="image/*" multiple style="display:none" onchange="handleFeedbackFiles(this)">
            <div id="feedbackPreviewGrid" class="feedback-preview-grid"></div>
        </div>
        <div class="feedback-modal-footer">
            <button onclick="closeFeedbackModal()" class="feedback-modal-cancel"><%= lng === 'zh' ? '取消' : 'Cancel' %></button>
            <button onclick="submitFeedback()" id="feedbackSubmitBtn" class="feedback-modal-submit"><%= lng === 'zh' ? '提交反馈' : 'Submit Feedback' %></button>
        </div>
    </div>
</div>

<!-- ===== Intro Guide Popup ===== -->
<div id="introPopupOverlay" style="display:none; position:fixed; inset:0; z-index:199999; background:rgba(0,0,0,0.6); backdrop-filter:blur(3px); justify-content:center; align-items:center;">
    <div style="position:relative; max-width:900px; width:92%; margin:auto; display:flex; flex-direction:column;">
        <!-- image with × inside top-right corner -->
        <div style="position:relative; line-height:0;">
            <img src="/intro.webp" alt="How it works" style="width:100%; display:block; border:1px solid #e2e8f0;">
            <button onclick="closeIntroPopup()" style="position:absolute; top:12px; right:12px; z-index:1; width:30px; height:30px; border-radius:0; background:rgba(255,255,255,0.9); border:1px solid #e2e8f0; color:#64748b; font-size:18px; line-height:1; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:0 1px 6px rgba(0,0,0,0.15); transition:all 0.2s;" onmouseover="this.style.background='#aa0000';this.style.color='#fff';this.style.borderColor='#aa0000'" onmouseout="this.style.background='rgba(255,255,255,0.9)';this.style.color='#64748b';this.style.borderColor='#e2e8f0'">&times;</button>
        </div>
        <!-- bottom bar: full-width button, no left text -->
        <div style="background:#fff; border:1px solid #e2e8f0; border-top:none; display:flex; justify-content:flex-end; align-items:center;">
            <button onclick="closeIntroPopup()" style="background:#aa0000; color:#fff; border:none; padding:12px 36px; font-size:13px; font-weight:600; cursor:pointer; border-radius:0; font-family:inherit; transition:background 0.2s; letter-spacing:0.3px;" onmouseover="this.style.background='#880000'" onmouseout="this.style.background='#aa0000'"><%= lng === 'zh' ? '开始定制 →' : 'Start Customizing →' %></button>
        </div>
    </div>
</div>
<script>
    (function() {
        var KEY = 'introShown';
        if (!sessionStorage.getItem(KEY)) {
            var overlay = document.getElementById('introPopupOverlay');
            overlay.style.display = 'flex';
            sessionStorage.setItem(KEY, '1');
        }
        window.closeIntroPopup = function() {
            document.getElementById('introPopupOverlay').style.display = 'none';
        };
        document.getElementById('introPopupOverlay').addEventListener('click', function(e) {
            if (e.target === this) closeIntroPopup();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeIntroPopup();
        });
    })();
</script>

</body>

</html>
