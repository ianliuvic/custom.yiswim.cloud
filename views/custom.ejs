            updateLogisticsSummary();

            // 5. йҮҚзҪ®е•ҶдёҡиҜ„дј° (Step 5)
            const stageRadio = document.querySelector('input[name="project_stage"][value="concept"]');
            if (stageRadio) stageRadio.checked = true;
            const volumeRadio = document.querySelector('input[name="est_volume"][value="sample_only"]');
            if (volumeRadio) { volumeRadio.checked = true; updateSummaryVolume('д»…ејҖеҸ‘ж ·иЎЈ'); }
            ['plan_colors', 'plan_sizes', 'target_market', 'target_price', 'final_remark'].forEach(id => {
                const el = document.getElementById(id); if(el) el.value = '';
            });

            // 6. иҝ”еӣһз¬¬дёҖжӯҘ
            if (currentStep !== 1) changeStep(1 - currentStep); 
        }

                // --- ж–°еўһпјҡжё…з©әеҪ“еүҚйқўж–ҷеҲҶзұ»зҡ„йҖүжӢ© ---
        function clearCurrentFabric() {
            if (!activeFabricCat || !fabricSelection[activeFabricCat]) return;
            if (fabricSelection[activeFabricCat].activeName === '') return; // дҝ®жӯЈпјҡеҲӨж–ӯ activeName
            
            const catName = fabricSelection[activeFabricCat].originalCatName;
            if (!confirm(`зЎ®е®ҡиҰҒжё…з©ә [${catName}] зҡ„йҖүжӢ©еҗ—пјҹ`)) return; // е»әи®®еҠ дёҠйҳІиҜҜи§ҰжҸҗзӨә

            // 1. йҮҚзҪ®еҪ“еүҚеҲҶзұ»зҡ„ж•°жҚ® (colorsе’Ңremarkе·Із»ҸеңЁжё…з©әconfigsж—¶иҝһеёҰжё…з©әдәҶ)
            fabricSelection[activeFabricCat].activeName = '';
            fabricSelection[activeFabricCat].configs = {};

            // 2. жӣҙж–° UIпјҡеҸ–ж¶ҲеҚЎзүҮйҖүдёӯзҠ¶жҖҒпјҢйҡҗи—Ҹй…ҚзҪ®йқўжқҝ
            document.getElementById(activeFabricCat).querySelectorAll('.fabric-item').forEach(item => item.classList.remove('selected'));
            document.getElementById('fabric-config-panel').classList.add('hidden');
            
            // 3. жӣҙж–°еҸідҫ§дҫ§иҫ№ж ҸжұҮжҖ»
            updateFabricSummary();
        }

        // жҺ§еҲ¶йқўж–ҷе®ўдҫӣзү©ж–ҷ (CMT) дҝЎжҒҜжЎҶзҡ„жҳҫйҡҗпјҢе№¶е№іж»‘ж»ҡеҠЁ
        function toggleFabricCmtInfo(isChecked) {
            const infoBox = document.getElementById('fabric-cmt-address-info');
            if (!infoBox) return;
        
            if (isChecked) {
                infoBox.classList.remove('hidden');
                // еұ•ејҖеҗҺпјҢз•Ҙеҫ®е»¶иҝҹд»ҘзЎ®дҝқ DOM жёІжҹ“е®ҢжҲҗпјҢз„¶еҗҺж»ҡеҠЁеҲ°и§ҶйҮҺдёӯеҝғ
                setTimeout(() => {
                    scrollElementToCenter('fabric-cmt-address-info');
                }, 50);
            } else {
                infoBox.classList.add('hidden');
                // ж”¶иө·ж—¶жё…з©әжүҖжңүе…іиҒ”зҡ„иҫ“е…Ҙж•°жҚ®пјҢдҝқжҢҒж•°жҚ®ж•ҙжҙҒ
                const trackingInput = document.getElementById('fabric-cmt-tracking');
                const descInput = document.getElementById('fabric-cmt-desc');
                if (trackingInput) trackingInput.value = '';
                if (descInput) descInput.value = '';
                
                // жё…з©әдёҠдј зҡ„ж–Үд»¶
                cmtFilesData['fabric'] = [];
                const nameEl = document.getElementById('fabricCmtFileName');
                if (nameEl) nameEl.innerText = 'зӮ№еҮ»дёҠдј еӣҫзүҮжҲ– PDF жё…еҚ•';
                renderCmtPreviews('fabric');
            }
            
            // жӣҙж–°еҸідҫ§дҫ§иҫ№ж Ҹзҡ„жұҮжҖ»зҠ¶жҖҒ
            updateFabricSummary();
        }

    </script>
</body>
</html>
