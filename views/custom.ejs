                        <!-- 3. 补充说明 (下一行，占满宽度) -->
                        <div>
                            <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">补充说明 (选填)</label>
                            <textarea class="oem-textarea" style="width: 100%; height:60px; font-size:12px;" placeholder="其他特殊要求，如：要求使用环保回收纱线制作标签..." oninput="labelConfig.sections.${conf.key}.remark = this.value; updateLabelSummary()">${data.remark}</textarea>
