        }
        
        // еҪ“ ODM жҲ– OEM ж•°йҮҸеҸҳеҢ–ж—¶пјҢеҲ·ж–°ж¬ҫејҸдёӢжӢүеҲ—иЎЁиҖҢдёҚйҮҚзҪ®иЎЁж ј
        function refreshSampleTableStyles() {
            renderSampleTable(); 
        }
        
        // ж ёеҝғжёІжҹ“еҮҪж•° (дҝ®еӨҚдёӢжӢүжЎҶзҠ¶жҖҒдёўеӨұй—®йўҳ)
        function renderSampleTable() {
            const tbody = document.getElementById('sample-table-body');
            const odmStyles = (typeof selectedOdmStyles !== 'undefined') ? selectedOdmStyles : [];
            const oemCountInput = document.getElementById('oem-collection-count');
            const oemCount = oemCountInput ? (parseInt(oemCountInput.value) || 0) : 0;
            
            let hasHighQty = false; // ж Үи®°жҳҜеҗҰеӯҳеңЁж•°йҮҸ > 2 зҡ„иЎҢ
        
            tbody.innerHTML = '';
            
            sampleRows.forEach((row, index) => {
                const tr = document.createElement('tr');
                
                // гҖҗж ёеҝғдҝ®еӨҚгҖ‘зӣҙжҺҘеңЁжӢјжҺҘеӯ—з¬ҰдёІж—¶жіЁе…Ҙ selected зҠ¶жҖҒ
                let rowStyleOptions = `<option value="">-- иҜ·йҖүжӢ©ж¬ҫејҸ --</option>`;
                
                // styleFound ж Үи®°пјҡз”ЁжқҘжЈҖжҹҘз”ЁжҲ·д»ҘеүҚйҖүзҡ„ж¬ҫејҸзҺ°еңЁиҝҳеңЁдёҚеңЁеҲ—иЎЁйҮҢ
                let styleFound = (row.style === ""); 
        
                odmStyles.forEach(name => {
                    const val = `ODM: ${name}`;
                    const isSelected = (row.style === val);
                    if (isSelected) styleFound = true;
                    rowStyleOptions += `<option value="${val}" ${isSelected ? 'selected' : ''}>${val}</option>`;
                });
        
                for (let i = 1; i <= oemCount; i++) {
                    const val = `OEM-з¬¬ ${i} ж¬ҫ`;
                    const isSelected = (row.style === val);
                    if (isSelected) styleFound = true;
                    rowStyleOptions += `<option value="${val}" ${isSelected ? 'selected' : ''}>${val}</option>`;
                }
        
                // е®№й”ҷжңәеҲ¶пјҡеҰӮжһңд№ӢеүҚйҖүзҡ„ж¬ҫејҸиў«еҲ йҷӨдәҶпјҲжҜ”еҰӮеңЁз¬¬дёҖжӯҘеҸ–ж¶ҲеӢҫйҖүпјүпјҢејәиЎҢйҮҚзҪ®иҜҘиЎҢзҡ„ж¬ҫејҸдёәз©ә
                if (!styleFound) {
                    row.style = "";
                }
        
                // з”ҹжҲҗж•ҙиЎҢзҡ„ HTMLпјҢеҢ…еҗ«ж¬ҫејҸе’Ңзұ»еһӢзҡ„ selected зҠ¶жҖҒпјҢд»ҘеҸҠе°әз Ғж•°йҮҸзҡ„ value
                tr.innerHTML = `
                    <td>
                        <select onchange="updateRowData(${index}, 'style', this.value)">
                            ${rowStyleOptions}
                        </select>
                    </td>
                    <td>
                        <select onchange="updateRowData(${index}, 'type', this.value)">
                            <option value="еҲқзүҲж · (Proto)" ${row.type==='еҲқзүҲж · (Proto)'?'selected':''}>еҲқзүҲж · (Proto)</option>
                            <option value="дҝ®ж”№/иҜ•з©ҝж · (Fit)" ${row.type==='дҝ®ж”№/иҜ•з©ҝж · (Fit)'?'selected':''}>дҝ®ж”№/иҜ•з©ҝж · (Fit)</option>
                            <option value="жӯЈзЎ®/дә§еүҚж · (PP)" ${row.type==='жӯЈзЎ®/дә§еүҚж · (PP)'?'selected':''}>жӯЈзЎ®/дә§еүҚж · (PP)</option>
                        </select>
                    </td>
                    <td>
                        <input type="text" list="common-sizes" value="${row.size}" placeholder="йҖүжҲ–еЎ«" onchange="updateRowData(${index}, 'size', this.value)">
                    </td>
                    <td>
                        <input type="number" value="${row.qty}" min="1" oninput="updateRowData(${index}, 'qty', this.value)">
                    </td>
                    <td>
                        <input type="text" value="${row.desc}" placeholder="дҫӢ: й»‘иүІзўҺиҠұж¬ҫ" oninput="updateRowData(${index}, 'desc', this.value)">
                    </td>
                    <td style="text-align:center;">
                        <button type="button" class="btn-remove-row" onclick="removeSampleRow(${index})">&times;</button>
                    </td>
                `;
                
                // жЈҖжҹҘж”¶иҙ№йў„иӯҰ
                if (parseInt(row.qty) > 2) {
                    hasHighQty = true;
                }
        
                tbody.appendChild(tr);
            });
        
            // еӨ„зҗҶж”¶иҙ№йў„иӯҰжЎҶжҳҫйҡҗ
            const warningEl = document.getElementById('sample-qty-warning');
            if (warningEl) {
                if (hasHighQty) {
                    warningEl.classList.remove('hidden');
                } else {
                    warningEl.classList.add('hidden');
                }
            }
        
            calculateSampleCost(); 
            updateLogisticsSummary();
        }

        // ж ҮзӯҫеҗҲи§„жҸҗзӨәеј№зӘ—жҺ§еҲ¶
