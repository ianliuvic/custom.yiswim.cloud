<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
    <style>
        /* 1. 基础布局变量 - 降低头部和底部的高度 */
        :root {
            --primary-color: #aa0000;
            --text-main: #2c3e50;
            --text-light: #7f8c8d;
            --border-color: #ececec;
            --header-height: 56px;   /* 从 70px 缩减到 56px */
            --footer-height: 36px;   /* 从 50px 缩减到 36px */
            --bg-sidebar: #fafafa;
        }

        body {
            height: 100vh !important; width: 100vw !important; overflow: hidden !important; 
            display: flex !important; flex-direction: column !important;
            justify-content: flex-start !important; align-items: stretch !important;
            margin: 0 !important; padding: 0 !important; background-color: #fff !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        /* 2. 顶部固定导航栏 (更紧凑) */
        .site-header {
            height: var(--header-height); min-height: var(--header-height); background: #fff;
            display: flex; justify-content: space-between; align-items: center;
            padding: 0 30px; border-bottom: 1px solid var(--border-color);
            z-index: 100; box-sizing: border-box;
        }
        .header-left { display: flex; align-items: center; gap: 12px; }
        .site-logo { height: 28px; width: auto; } /* Logo 适当等比缩小 */
        .site-title { font-size: 16px; font-weight: 600; color: var(--text-main); }

        /* 3. 中间主体容器 */
        .main-container { flex: 1; display: flex; overflow: hidden; width: 100%; }

        /* 3.1 左侧配置区 */
        .config-main {
            flex: 1; display: flex; flex-direction: column; height: 100%;
            border-right: 1px solid var(--border-color); position: relative;
        }
        
        /* 步进指示器 (压缩上下边距) */
        .stepper {
            padding: 20px 40px 0; /* 左右边距从 60 降到 40，顶部从 30 降到 20 */
            display: flex; gap: 15px; background: #fff; z-index: 10;
        }
        .step {
            flex: 1; padding-bottom: 10px; border-bottom: 3px solid #eee;
            font-size: 12px; color: var(--text-light); text-transform: uppercase;
        }
        .step.active { border-bottom-color: var(--primary-color); color: var(--primary-color); font-weight: 600; }

        /* 内容滚动区 (扩展空间) */
        .config-scroll-area { 
            flex: 1; overflow-y: auto; 
            padding: 20px 40px 30px; /* 左右边距释放 20px 给选项卡 */
            box-sizing: border-box; 
        }

        /* 底部操作按钮组 (压缩上下边距) */
        .button-group {
            padding: 12px 40px; /* 上下从 20px 降到 12px */
            background: #fff; border-top: 1px solid var(--border-color);
            display: flex; gap: 15px; z-index: 10;
        }

        /* 3.2 右侧汇总预览区 */
        .summary-sidebar {
            width: 340px; /* 从 380px 降到 340px，把宽度还给左侧展示区 */
            min-width: 340px; background-color: var(--bg-sidebar);
            padding: 30px; /* 内边距也略微缩减 */
            overflow-y: auto; height: 100%; box-sizing: border-box;
        }

        /* 4. 底部固定版权栏 (压缩高度) */
        .site-footer {
            height: var(--footer-height); min-height: var(--footer-height); background: #fff;
            border-top: 1px solid var(--border-color); padding: 0 30px;
            display: flex; align-items: center; font-size: 12px; color: #999; z-index: 100; box-sizing: border-box;
        }

        /* --- UI 选项卡片设计 (更紧凑的卡片排版) --- */
        .option-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); /* 卡片最小宽度从 220 降到 200，一行能排下更多 */
            gap: 15px; /* 间距变小 */
            margin-top: 15px; 
        }
        .option-item { border: 1px solid var(--border-color); background: #fff; cursor: pointer; transition: all 0.2s ease; position: relative; border-radius: 4px; overflow: hidden; }
        .option-item:hover { border-color: var(--primary-color); }
        .option-item.selected { border-color: var(--primary-color); background-color: #fff9f9; outline: 1px solid var(--primary-color); }
        
        /* 选项图片高度压缩 */
        .option-img { width: 100%; height: 140px; /* 从 180px 降到 140px，避免首屏被图片占满 */ object-fit: cover; background: #f9f9f9; border-bottom: 1px solid var(--border-color); }
        
        .option-info { padding: 12px; }
        .option-info h4 { margin: 0 0 4px; font-size: 14px; }
        .option-info p { margin: 0; font-size: 12px; color: var(--text-light); line-height: 1.4; }

        /* 按钮与表单元素 */
        button { padding: 10px 30px; border-radius: 4px; font-size: 13px; font-weight: 500; cursor: pointer; border: 1px solid var(--primary-color); transition: all 0.3s; }
        #nextBtn { background: var(--primary-color); color: #fff; }
        #prevBtn { background: #fff; color: var(--primary-color); }
        #prevBtn:disabled { border-color: #eee; color: #ccc; cursor: not-allowed; }

        /* 侧边栏及内部样式 */
        .summary-title { font-size: 16px; font-weight: 600; margin-bottom: 25px; display: block; color: var(--text-main); }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 13px; border-bottom: 1px dashed #e0e0e0; padding-bottom: 8px; }
        .summary-row .label { color: var(--text-light); }
        .summary-row .value { color: var(--text-main); font-weight: 500; text-align: right; max-width: 60%; line-height: 1.3; }
        
        .summary-sub-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px; padding-left: 10px; color: #666; }
        .summary-sub-row .value { color: #333; text-align: right; max-width: 60%; }

        /* 子标签页 */
        .sub-tabs { display: flex; gap: 0; border-bottom: 2px solid var(--border-color); margin-bottom: 25px; overflow-x: auto; }
        .sub-tab { padding: 10px 18px; cursor: pointer; font-size: 13px; color: var(--text-light); font-weight: 500; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.3s; white-space: nowrap; }
        .sub-tab:hover { color: var(--text-main); }
        .sub-tab.active { color: var(--primary-color); border-bottom-color: var(--primary-color); }
        
        .sub-pane { display: none; animation: fadeIn 0.3s; }
        .sub-pane.active { display: block; }

        .toggle-section { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; padding: 12px 20px; background: #f9f9f9; border-radius: 4px; border: 1px solid #eee; }
        .toggle-title { font-weight: 600; font-size: 14px; }
        .toggle-options label { cursor: pointer; display: inline-flex; align-items: center; gap: 6px; margin-right: 15px; font-size: 13px; }
        
        /* 上传框与占位框 */
        .placeholder-box { padding: 40px 20px; border: 1px dashed #ccc; text-align: center; color: #999; font-size: 13px; background: #fff; border-radius: 4px; }
        .premium-upload-box { border: 1px dashed #d9d9d9; background-color: #fafafa; border-radius: 6px; padding: 30px 20px; text-align: center; transition: all 0.3s ease; cursor: pointer; }
        .premium-upload-box:hover { border-color: var(--primary-color); background-color: #fff9f9; }
        .custom-file-input { margin-top: 10px; font-family: inherit; font-size: 12px; }
        .custom-file-input::file-selector-button { background-color: #fff; border: 1px solid var(--border-color); border-radius: 4px; padding: 6px 12px; color: var(--text-main); cursor: pointer; transition: 0.2s; }
        .custom-file-input::file-selector-button:hover { border-color: var(--primary-color); color: var(--primary-color); }

        /* 步骤引导描述框 */
        .step-desc {
            font-size: 13px;
            color: var(--text-main);
            background: #f4f6f8;
            padding: 12px 16px;
            border-left: 3px solid var(--primary-color);
            border-radius: 0 4px 4px 0;
            margin-top: 0;
            margin-bottom: 25px;
            line-height: 1.5;
        }

        .hidden { display: none !important; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d0d0d0; border-radius: 10px; }
    </style>
</head>
<body>

    <!-- 1. 顶部固定导航 -->
    <header class="site-header">
        <div class="header-left">
            <img src="/logo.png" alt="Hongxiu Logo" class="site-logo">
            <span class="site-title">Hongxiu Custom System</span>
        </div>
        <div style="font-size: 14px; color: var(--text-light);">
            当前用户：<strong><%= user.username %></strong> | 
            <a href="/logout" style="color: var(--primary-color); text-decoration: none; font-weight: 500;">安全退出</a>
        </div>
    </header>

    <!-- 2. 中间主体 -->
    <div class="main-container">
        
        <!-- 左侧：定制区域 -->
        <main class="config-main">
            <!-- 步进指示器 -->
            <nav class="stepper">
                <div class="step active" id="step-1-label">01. 款式定义</div>
                <div class="step" id="step-2-label">02. 面料材质</div>
                <div class="step" id="step-3-label">03. 品牌辅料</div>
                <div class="step" id="step-4-label">04. 物流交付</div>
                <div class="step" id="step-5-label">05. 需求汇总</div>
            </nav>

            <!-- 滚动内容区 -->
            <div class="config-scroll-area">
                <form id="configForm">
                    
                                        <!-- 步骤 1: 款式 -->
                    <div class="step-content" id="step-1">
                        <!-- 去掉 h2，使用新的引导框 -->
                        <div class="step-desc">请选择基础廓形，或开启 OEM 模式上传您的自主设计包。</div>
                        
                        <div style="margin-bottom: 25px; display: flex; gap: 30px;">
                            <label style="cursor: pointer;"><input type="radio" name="styleMode" checked onclick="toggleStyleMode('existing')"> 现有款式 (ODM)</label>
                            <label style="cursor: pointer;"><input type="radio" name="styleMode" onclick="toggleStyleMode('custom')"> 自主设计 (OEM)</label>
                        </div>

                        <div id="existing-styles" class="option-grid">
                            <div class="option-item" onclick="selectItem('style', 'Classic One-Piece')">
                                <img src="https://images.unsplash.com/photo-1576188973526-0e5d742990af?w=500" class="option-img">
                                <div class="option-info"><h4>Classic One-Piece</h4><p>经典廓形 · 覆盖全面</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('style', 'Triangle Bikini')">
                                <img src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?w=500" class="option-img">
                                <div class="option-info"><h4>Triangle Bikini</h4><p>时尚多变 · 系带调节</p></div>
                            </div>
                        </div>

                        <div id="custom-upload" class="hidden">
                            <div class="placeholder-box">
                                <p style="margin-bottom:15px; color:#666;">请上传您的设计稿或工艺单 (PDF/AI/PNG)</p>
                                <input type="file" multiple>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 2: 面料 -->
                    <div class="step-content hidden" id="step-2">
                        <div class="step-desc">选择最适合您产品定位的面料材质。如需特殊面料请在最后一步备注。</div>
                        
                        <div class="option-grid">
                            <div class="option-item" onclick="selectItem('fabric', 'Matte Nylon (190G)')">
                                <div style="height:140px; background:#333;"></div>
                                <div class="option-info"><h4>Matte Nylon</h4><p>80% Nylon, 20% Spandex</p></div>
                            </div>
                            <!-- 未来可以加更多面料 -->
                        </div>
                    </div>

                    <!-- ============================================== -->
                    <!-- 步骤 3: 辅料 (全新子页面结构) -->
                    <!-- ============================================== -->
                    <!-- 步骤 3: 辅料 -->
                    <div class="step-content hidden" id="step-3">
                        <div class="step-desc">请在下方标签页中分别配置您需要的品牌辅料。如果不需要某项辅料，保持默认“否”即可。</div>

                        <!-- 子标签页导航 (保持你之前的代码不变) -->
                        <div class="sub-tabs">
                            <div class="sub-tab active" onclick="switchSubTab('metal', this)">金属饰品</div>
                            <div class="sub-tab" onclick="switchSubTab('bag', this)">包装袋</div>
                            <div class="sub-tab" onclick="switchSubTab('hangtag', this)">吊牌</div>
                            <div class="sub-tab" onclick="switchSubTab('label', this)">标签(领标/水洗标)</div>
                            <div class="sub-tab" onclick="switchSubTab('hygiene', this)">卫生贴</div>
                            <div class="sub-tab" onclick="switchSubTab('other', this)">其他</div>
                        </div>

                        <!-- 1. 金属饰品 Pane -->
                        <div id="pane-metal" class="sub-pane active">
                            <div class="toggle-section">
                                <div class="toggle-title">是否需要金属饰品？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_metal" value="no" checked onchange="toggleTrim('metal', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_metal" value="yes" onchange="toggleTrim('metal', true)"> 是 (Yes)</label>
                                </div>
                            </div>
                            <div id="content-metal" class="placeholder-box hidden">
                                <h3>[ 金属饰品选项 - 占位 ]</h3>
                                <p>此处未来将展示：金色调节扣、银色Logo铭牌、防锈合金扣等图片选项。</p>
                            </div>
                        </div>

                        <!-- 2. 包装袋 Pane -->
                        <div id="pane-bag" class="sub-pane">
                            <div class="toggle-section">
                                <div class="toggle-title">是否需要定制品牌包装袋？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_bag" value="no" checked onchange="toggleTrim('bag', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_bag" value="yes" onchange="toggleTrim('bag', true)"> 是 (Yes)</label>
                                </div>
                            </div>

                            <div id="content-bag" class="hidden" style="animation: fadeIn 0.5s ease;">
                                
                                <!-- 1. 描述与灵感画廊 -->
                                <div class="bag-intro" style="margin-bottom: 40px;">
                                    <h3 style="font-size: 18px; color: var(--text-main); margin-bottom: 10px;">提升您的开箱体验 (Unboxing Experience)</h3>
                                    <p style="color: var(--text-light); font-size: 14px; line-height: 1.6; margin-bottom: 20px;">
                                        包装是品牌与消费者接触的第一道门面。我们提供从磨砂质感拉链袋到100%可降解环保袋的多种选择。您可以上传自己的 Logo 或印花设计，打造独一无二的品牌视觉。
                                    </p>
                                    <!-- 灵感图片展示区 -->
                                    <div style="display: flex; gap: 15px; overflow-x: auto; padding-bottom: 10px;">
                                        <img src="https://images.unsplash.com/photo-1607344645866-009c320b63e0?w=300" alt="示例1" style="height: 140px; width: 220px; object-fit: cover; border-radius: 6px; border: 1px solid #eee;">
                                        <img src="https://images.unsplash.com/photo-1586790170083-2f9ceadc732d?w=300" alt="示例2" style="height: 140px; width: 220px; object-fit: cover; border-radius: 6px; border: 1px solid #eee;">
                                        <img src="https://images.unsplash.com/photo-1620794341491-9f24dc3ad4fb?w=300" alt="示例3" style="height: 140px; width: 220px; object-fit: cover; border-radius: 6px; border: 1px solid #eee;">
                                    </div>
                                </div>

                                <!-- 2. 设计文件上传区 -->
                                <div class="premium-upload-box" style="margin-bottom: 40px;">
                                    <div style="margin-bottom: 15px; color: var(--primary-color);">
                                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                    </div>
                                    <h4 style="margin: 0 0 8px; font-size: 16px;">上传您的包装设计图稿或 Logo</h4>
                                    <p style="margin: 0 0 20px; font-size: 13px; color: #888;">支持的文件格式：PDF, AI, PSD, PNG (建议透明底)。最大限制 50MB。</p>
                                    <input type="file" id="bag-design-file" class="custom-file-input">
                                </div>

                                <!-- 3. 定制属性：材质选择 -->
                                <div class="attr-section" style="margin-bottom: 40px;">
                                    <h4 class="attr-title" style="font-size: 16px; margin-bottom: 15px; border-left: 3px solid var(--primary-color); padding-left: 10px;">A. 材质与袋型 (Material & Style)</h4>
                                    <div class="option-grid">
                                        <div class="option-item bag-mat" onclick="selectBagAttr('material', 'CPE 磨砂拉链袋', this)">
                                            <div style="height: 150px; background: #eef2f5; display: flex; align-items:center; justify-content:center; color:#999; border-bottom: 1px solid #eee;">[磨砂袋示意图]</div>
                                            <div class="option-info">
                                                <h4>CPE Frosted Zip Bag</h4>
                                                <p>半透明磨砂质感 · 高级顺滑拉链</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-mat" onclick="selectBagAttr('material', '环保可降解袋', this)">
                                            <div style="height: 150px; background: #f2f7f4; display: flex; align-items:center; justify-content:center; color:#749c74; border-bottom: 1px solid #eee;">[环保袋示意图]</div>
                                            <div class="option-info">
                                                <h4>Biodegradable Bag</h4>
                                                <p>100% 堆肥降解 · 欧美品牌首选</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-mat" onclick="selectBagAttr('material', '纯棉抽绳袋', this)">
                                            <div style="height: 150px; background: #f9f6f0; display: flex; align-items:center; justify-content:center; color:#a6937c; border-bottom: 1px solid #eee;">[棉布袋示意图]</div>
                                            <div class="option-info">
                                                <h4>Cotton Drawstring</h4>
                                                <p>天然原色棉布 · 可重复收纳使用</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- 4. 定制属性：尺寸选择 -->
                                <div class="attr-section" style="margin-bottom: 40px;">
                                    <h4 class="attr-title" style="font-size: 16px; margin-bottom: 15px; border-left: 3px solid var(--primary-color); padding-left: 10px;">B. 尺寸规格 (Dimensions)</h4>
                                    <div class="option-grid">
                                        <div class="option-item bag-size" onclick="selectBagAttr('size', '20x30cm (基础款)', this)">
                                            <div style="height: 120px; background: #fafafa; display: flex; align-items:center; justify-content:center; font-size:24px; color:#ccc; border-bottom: 1px solid #eee;">20 x 30</div>
                                            <div class="option-info">
                                                <h4>Standard (20x30 cm)</h4>
                                                <p>适合常规分体比基尼、单件泳裤</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-size" onclick="selectBagAttr('size', '25x35cm (加大款)', this)">
                                            <div style="height: 120px; background: #fafafa; display: flex; align-items:center; justify-content:center; font-size:24px; color:#ccc; border-bottom: 1px solid #eee;">25 x 35</div>
                                            <div class="option-info">
                                                <h4>Large (25x35 cm)</h4>
                                                <p>适合连体泳衣、长袖冲浪服或套装</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-size" onclick="selectBagAttr('size', '自定义尺寸', this)">
                                            <div style="height: 120px; background: #fafafa; display: flex; align-items:center; justify-content:center; font-size:24px; color:#ccc; border-bottom: 1px solid #eee;">? x ?</div>
                                            <div class="option-info">
                                                <h4>Custom Size</h4>
                                                <p>我有特殊尺寸需求（请在最后一步备注）</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- 5. 定制属性：印刷工艺 -->
                                <div class="attr-section" style="margin-bottom: 20px;">
                                    <h4 class="attr-title" style="font-size: 16px; margin-bottom: 15px; border-left: 3px solid var(--primary-color); padding-left: 10px;">C. 印刷工艺 (Print Finish)</h4>
                                    <div class="option-grid">
                                        <div class="option-item bag-print" onclick="selectBagAttr('print', '空白无印', this)">
                                            <div style="height: 120px; background: #fff; display: flex; align-items:center; justify-content:center; color:#ddd; border-bottom: 1px solid #eee;">[空白示意]</div>
                                            <div class="option-info">
                                                <h4>Blank (No Print)</h4>
                                                <p>保持原质感，极简成本优选</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-print" onclick="selectBagAttr('print', '单色印刷', this)">
                                            <div style="height: 120px; background: #fafafa; display: flex; align-items:center; justify-content:center; color:#999; border-bottom: 1px solid #eee;">[单色Logo示意]</div>
                                            <div class="option-info">
                                                <h4>1-Color Print</h4>
                                                <p>印制黑色/白色或单色 Logo，性价比最高</p>
                                            </div>
                                        </div>
                                        <div class="option-item bag-print" onclick="selectBagAttr('print', '多色/满印', this)">
                                            <div style="height: 120px; background: linear-gradient(45deg, #f1e1e1, #e1e8f1); display: flex; align-items:center; justify-content:center; color:#888; border-bottom: 1px solid #eee;">[彩色印花示意]</div>
                                            <div class="option-info">
                                                <h4>Multi-Color / Allover</h4>
                                                <p>复杂彩色图案或平铺满印，视觉冲击力强</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- 3. 吊牌 Pane -->
                        <div id="pane-hangtag" class="sub-pane">
                            <div class="toggle-section">
                                <div class="toggle-title">是否需要品牌吊牌？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_hangtag" value="no" checked onchange="toggleTrim('hangtag', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_hangtag" value="yes" onchange="toggleTrim('hangtag', true)"> 是 (Yes)</label>
                                </div>
                            </div>
                            <div id="content-hangtag" class="placeholder-box hidden">
                                <h3>[ 吊牌选项 - 占位 ]</h3>
                                <p>此处未来将展示：牛皮纸吊牌、铜版纸覆膜吊牌、异形吊牌等图片选项。</p>
                            </div>
                        </div>

                        <!-- 4. 标签 Pane -->
                        <div id="pane-label" class="sub-pane">
                            <div class="toggle-section">
                                <div class="toggle-title">是否需要缝制标签？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_label" value="no" checked onchange="toggleTrim('label', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_label" value="yes" onchange="toggleTrim('label', true)"> 是 (Yes)</label>
                                </div>
                            </div>
                            <div id="content-label" class="placeholder-box hidden">
                                <h3>[ 标签选项 - 占位 ]</h3>
                                <p>此处未来将展示：无感烫印标、高密织唛主标、丝印水洗标等图片选项。</p>
                            </div>
                        </div>

                        <!-- 5. 卫生贴 Pane -->
                        <div id="pane-hygiene" class="sub-pane">
                            <div class="toggle-section">
                                <div class="toggle-title">是否需要底裤卫生贴？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_hygiene" value="no" checked onchange="toggleTrim('hygiene', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_hygiene" value="yes" onchange="toggleTrim('hygiene', true)"> 是 (Yes)</label>
                                </div>
                            </div>
                            <div id="content-hygiene" class="placeholder-box hidden">
                                <h3>[ 卫生贴选项 - 占位 ]</h3>
                                <p>此处未来将展示：透明标准卫生贴、印字定制卫生贴等图片选项。</p>
                            </div>
                        </div>

                        <!-- 6. 其他 Pane -->
                        <div id="pane-other" class="sub-pane">
                            <div class="toggle-section">
                                <div class="toggle-title">是否有其他辅料需求？</div>
                                <div class="toggle-options">
                                    <label><input type="radio" name="need_other" value="no" checked onchange="toggleTrim('other', false)"> 否 (No)</label>
                                    <label><input type="radio" name="need_other" value="yes" onchange="toggleTrim('other', true)"> 是 (Yes)</label>
                                </div>
                            </div>
                            <div id="content-other" class="placeholder-box hidden">
                                <p style="margin-bottom: 10px; color:#333;">请输入您的其他特殊要求（如：特定的拉链、反光条等）：</p>
                                <textarea style="width:100%; height:100px; padding:10px; border:1px solid #ccc; font-family:inherit;"></textarea>
                            </div>
                        </div>
                    </div>
                    <!-- ============================================== -->

                    <!-- 步骤 4: 物流 -->
                    <div class="step-content hidden" id="step-4">
                        <div class="step-desc">请选择首选的交付与物流方式。最终费用将在确认具体起订量后核算。</div>
                        
                        <div class="option-grid">
                            <div class="option-item" onclick="selectItem('shipping', 'Air Express (DHL/FedEx)')">
                                <div class="option-info"><h4>Air Express</h4><p>空运快线 5-7 天</p></div>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 5: 确认 -->
                    <div class="step-content hidden" id="step-5">
                        <div class="step-desc">请最后核对右侧的需求清单。如有其他特殊说明（如尺码配比、混装要求等），请在下方留言。</div>
                        
                        <textarea style="width:100%; height:150px; padding:15px; border:1px solid var(--border-color); font-family:inherit; border-radius:4px; box-sizing:border-box;" placeholder="请输入整体订单备注..."></textarea>
                    </div>

                </form>
            </div>

            <!-- 按钮组 -->
            <div class="button-group">
                <button type="button" id="prevBtn" onclick="changeStep(-1)" disabled>返回上一步</button>
                <button type="button" id="nextBtn" onclick="changeStep(1)">继续下一步</button>
            </div>
        </main>

        <!-- 右侧汇总 (独立滚动) -->
        <aside class="summary-sidebar">
            <span class="summary-title">SELECTED DETAILS</span>
            
            <div class="summary-row"><span class="label">款式类型</span><span class="value" id="sum-style">未选择</span></div>
            <div class="summary-row"><span class="label">面料材质</span><span class="value" id="sum-fabric">未选择</span></div>
            
            <!-- 辅料汇总展开区 -->
            <div style="margin-bottom: 20px; border-bottom: 1px dashed #e0e0e0; padding-bottom: 10px;">
                <div style="display:flex; justify-content:space-between; font-size:14px; margin-bottom:15px;">
                    <span style="color: var(--text-light);">品牌辅料设置</span>
                </div>
                <div class="summary-sub-row"><span class="label">金属饰品:</span><span class="value" id="sum-trim-metal">不需要</span></div>
                <div class="summary-sub-row"><span class="label">包装袋:</span><span class="value" id="sum-trim-bag">不需要</span></div>
                <div class="summary-sub-row"><span class="label">吊牌:</span><span class="value" id="sum-trim-hangtag">不需要</span></div>
                <div class="summary-sub-row"><span class="label">缝制标签:</span><span class="value" id="sum-trim-label">不需要</span></div>
                <div class="summary-sub-row"><span class="label">卫生贴:</span><span class="value" id="sum-trim-hygiene">不需要</span></div>
                <div class="summary-sub-row"><span class="label">其他辅料:</span><span class="value" id="sum-trim-other">不需要</span></div>
            </div>

            <div class="summary-row"><span class="label">交付方式</span><span class="value" id="sum-shipping">未选择</span></div>

            <div style="margin-top: 50px; padding: 20px; background: #fff; border: 1px solid var(--border-color); font-size: 13px; line-height: 1.6;">
                <strong>注意事项：</strong><br><br>
                · 提交后系统将生成需求编号，业务经理将在1个工作日内联系您。<br>
                · 样板周期预计 7-10 个工作日。
            </div>
        </aside>
    </div>

    <!-- 底部固定版权 -->
    <footer class="site-footer">
        © 2026 红绣服饰 (Hongxiu Clothing). All Rights Reserved. | 专属定制 · 品质追踪
    </footer>

    <script>
        let currentStep = 1;
        const totalSteps = 5;

        // --- 整体流程控制 ---
        function changeStep(n) {
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.remove('active');
            currentStep += n;
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.add('active');
            document.getElementById('prevBtn').disabled = (currentStep === 1);
            
            if (currentStep === totalSteps) {
                document.getElementById('nextBtn').innerText = '确认并提交定制需求';
                document.getElementById('nextBtn').style.backgroundColor = '#27ae60';
                document.getElementById('nextBtn').style.borderColor = '#27ae60';
            } else {
                document.getElementById('nextBtn').innerText = '继续下一步';
                document.getElementById('nextBtn').style.backgroundColor = 'var(--primary-color)';
                document.getElementById('nextBtn').style.borderColor = 'var(--primary-color)';
            }
            document.querySelector('.config-scroll-area').scrollTop = 0;
        }

        // --- 款式切换逻辑 ---
        function toggleStyleMode(mode) {
            const list = document.getElementById('existing-styles');
            const upload = document.getElementById('custom-upload');
            if(mode === 'existing') {
                list.classList.remove('hidden'); upload.classList.add('hidden');
            } else {
                list.classList.add('hidden'); upload.classList.remove('hidden');
                document.getElementById('sum-style').innerText = 'OEM 自定义开发';
            }
        }

        // --- 通用选项选中逻辑 ---
        function selectItem(category, displayName) {
            document.getElementById(`sum-${category}`).innerText = displayName;
            const container = document.getElementById(`step-${currentStep}`);
            container.querySelectorAll('.option-item').forEach(item => {
                item.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
        }

        // --- 辅料 (子页面) 控制逻辑 ---
        
        // 1. 切换水平子标签
        function switchSubTab(paneId, el) {
            // 移除所有子页面的 active
            document.querySelectorAll('.sub-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
            // 激活当前
            document.getElementById(`pane-${paneId}`).classList.add('active');
            el.classList.add('active');
        }

        // 存储包装袋的多维配置数据
        let bagConfig = {
            material: '未选材质',
            size: '未选尺寸',
            print: '未选印刷'
        };

        // 处理包装袋各个属性的点击选择
        function selectBagAttr(attrType, displayName, el) {
            // 1. 记录数据
            bagConfig[attrType] = displayName;

            // 2. 视觉反馈：清除同一组（mat, size, print）内的高亮，然后高亮当前点击的卡片
            const container = document.getElementById('content-bag');
            container.querySelectorAll(`.bag-${attrType}`).forEach(item => {
                item.classList.remove('selected');
            });
            el.classList.add('selected');

            // 3. 更新右侧侧边栏汇总
            updateBagSummary();
        }

        // 统一更新右侧清单的展示文本
        function updateBagSummary() {
            const summaryText = document.getElementById('sum-trim-bag');
            
            // 如果三个都没选，提示待配置
            if (bagConfig.material === '未选材质' && bagConfig.size === '未选尺寸' && bagConfig.print === '未选印刷') {
                summaryText.innerText = '已开启 (待选择详细配置)';
            } else {
                // 拼接成精美的格式，例如: CPE 磨砂拉链袋 | 20x30cm | 单色印刷
                // 如果有未选的，就用 ?? 代替，提示用户还没选完
                const matStr = bagConfig.material !== '未选材质' ? bagConfig.material : '??';
                const sizeStr = bagConfig.size !== '未选尺寸' ? bagConfig.size.split(' ')[0] : '??'; // 只取尺寸数字部分
                const printStr = bagConfig.print !== '未选印刷' ? bagConfig.print : '??';
                
                summaryText.innerText = `${matStr} | ${sizeStr} | ${printStr}`;
            }

            summaryText.style.color = 'var(--primary-color)';
            summaryText.style.fontWeight = 'bold';
        }

        // 修改原有的 toggleTrim 函数
        function toggleTrim(category, isNeeded) {
            const contentBox = document.getElementById(`content-${category}`);
            const summaryText = document.getElementById(`sum-trim-${category}`);
            
            if (isNeeded) {
                contentBox.classList.remove('hidden');
                
                if (category === 'bag') {
                    // 如果开启包装袋，刷新一下当前的配置状态
                    updateBagSummary();
                } else {
                    summaryText.innerText = '已开启 (待配置)';
                    summaryText.style.color = 'var(--primary-color)';
                    summaryText.style.fontWeight = 'bold';
                }
            } else {
                contentBox.classList.add('hidden');
                summaryText.innerText = '不需要';
                summaryText.style.color = '#666';
                summaryText.style.fontWeight = 'normal';
            }
        }
    </script>
</body>
</html>
