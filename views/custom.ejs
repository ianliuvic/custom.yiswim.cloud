        function handleHygieneFiles(input) {
            const files = Array.from(input.files);
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) { alert(`文件 ${file.name} 超过 20MB`); return; }
                if (!hygieneConfig.files.some(f => f.name === file.name && f.size === file.size)) {
