        // ==========================================
        // ж ҮзӯҫйҖ»иҫ‘ (Label) - жҷәиғҪд»Јй…ҚдёҺиҮӘдё»е®ҡд№үзүҲ (жңҖж–°жқҗиҙЁ/е°әеҜё/зјқеҲ¶еҠЁжҖҒиҒ”еҠЁ)
        // ==========================================
        
        let labelConfig = {
            mode: 'auto',
            material: 'еҚ°ж Ү',
            size: '',
            method: 'еҜ№жҠҳзҺҜзјқ', // й»ҳи®ӨйҖүдёӯйЎ№
            components: ['дёҠиЈ…/иҝһдҪ“'],
            placements: {
                'top': 'йўҶеҗҺдёӯ (Center Back Neck)',
                'bottom': 'еҗҺи…°еҶ…дёӯ (Center Back Waist)'
            },
            placementFiles: {
                'top': [],
                'bottom': []
            },
            isSplit: false,        
            splitRemark: '',       
            remark: '',          
            designFiles: [],      
            otherMatFiles: [],
            sewingRemark: '',    // ж–°еўһпјҡзјқеҲ¶ж–№ејҸеӨҮжіЁ
            sewingFiles: []      // ж–°еўһпјҡзјқеҲ¶ж–№ејҸйҷ„д»¶
        };

        // 1. еҲҮжҚўжңҚиЈ…йғЁд»¶ (еӨҡйҖүжҺ§еҲ¶пјҢдё”иҮіе°‘дҝқз•ҷдёҖйЎ№)
        function toggleLabelComponent(compName, el) {
            let arr = labelConfig.components;
            
            // еҰӮжһңеҸӘжңүдёҖйЎ№дё”жӯЈжҳҜеҪ“еүҚйЎ№пјҢйҳ»жӯўеҸ–ж¶ҲпјҲеҝ…йҖүе…¶дёҖпјү
            if (arr.length === 1 && arr[0] === compName) {
                showToast('иҜ·иҮіе°‘дҝқз•ҷдёҖдёӘжү“ж ҮйғЁдҪҚ', 'warning');
                return;
            }
        
            const idx = arr.indexOf(compName);
            if (idx > -1) {
                // еҸ–ж¶ҲйҖүдёӯ
                arr.splice(idx, 1);
                el.classList.remove('selected');
            } else {
                // ж–°еўһйҖүдёӯ
                arr.push(compName);
                el.classList.add('selected');
            }
        
            labelConfig.components = arr;
            
            // иҒ”еҠЁжҺ§еҲ¶дёӢж–№зҡ„зҪ‘ж јжҳҫйҡҗ
            const topArea = document.getElementById('label-placement-top-area');
            const bottomArea = document.getElementById('label-placement-bottom-area');
            
            if (topArea) topArea.classList.toggle('hidden', !arr.includes('дёҠиЈ…/иҝһдҪ“'));
            if (bottomArea) bottomArea.classList.toggle('hidden', !arr.includes('дёӢиЈ…/иЈӨиЈ…'));
            
            // ж»ҡеҠЁеҜ№йҪҗ
            if (arr.includes('дёӢиЈ…/иЈӨиЈ…') && idx === -1) {
                setTimeout(() => scrollElementToCenter('label-placement-bottom-area'), 50);
            }
            
            updateLabelSummary();
        }
        
        // 2. йҖүжӢ©е…·дҪ“е®үиЈ…дҪҚзҪ® (жҢү top/bottom зӢ¬з«Ӣи®°еҪ•е№¶и®Ўз®—з®ӯеӨҙжҢҮеҗ‘)
        function selectLabelPlacement(gridType, posName, el) {
            // и®°еҪ•ж•°жҚ®
            labelConfig.placements[gridType] = posName;
            
            // еҸ–ж¶ҲеҪ“еүҚзҪ‘ж јеҶ…жүҖжңүеҚЎзүҮзҡ„йҖүдёӯзҠ¶жҖҒ
            const grid = document.getElementById(`label-placement-${gridType}-grid`);
            if (grid) {
                grid.querySelectorAll('.option-item').forEach(card => card.classList.remove('selected'));
                el.classList.add('selected');
            }
            
            // жҺ§еҲ¶еҜ№еә”зҪ‘ж јеҶ…йқўжқҝзҡ„жҳҫйҡҗе№¶и®Ўз®—з®ӯеӨҙдҪҚзҪ®
            const customArea = document.getElementById(`label-placement-custom-${gridType}`);
            if (customArea) {
                const isCustom = (posName === 'иҮӘе®ҡд№үе…¶д»–дҪҚзҪ®');
                customArea.classList.toggle('hidden', !isCustom);
                
                if (isCustom) {
                    // е»¶иҝҹи®Ўз®—д»ҘзЎ®дҝқ DOM жӣҙж–°е®ҢжҜ•
                    setTimeout(() => {
                        const arrow = customArea.querySelector('.config-arrow');
                        if (arrow && el) {
                            // и®Ўз®—е°Ҹз®ӯеӨҙзҡ„еҠЁжҖҒе·ҰеҒҸз§»йҮҸ (еұ…дёӯеҜ№йҪҗзӮ№еҮ»зҡ„еҚЎзүҮ)
                            const arrowPos = el.getBoundingClientRect().left - customArea.getBoundingClientRect().left + (el.getBoundingClientRect().width / 2) - 8;
                            arrow.style.left = `${arrowPos}px`;
                        }
                        // е№іж»‘ж»ҡеҠЁеұ…дёӯ
                        scrollElementToCenter(`label-placement-custom-${gridType}`);
                    }, 50);
                } else {
                    // ж”¶иө·ж—¶жё…з©әеӨҡдҪҷж–Үжң¬
                    const textInput = document.getElementById(`label-custom-${gridType}-text`);
                    if (textInput) textInput.value = '';
                }
            }
            
            updateLabelSummary();
        }

        function toggleLabelSplit(checked) {
            labelConfig.isSet = checked; // дёҺеҗҠзүҢз»ҹдёҖдҪҝз”Ёзұ»дјјзҡ„жҰӮеҝө
            
            const area = document.getElementById('label-split-detail-area');
            if (area) {
                area.classList.toggle('hidden', !checked);
                if (checked) {
                    // е№іж»‘ж»ҡеҠЁеҲ°иҫ“е…ҘжЎҶ
                    setTimeout(() => scrollElementToCenter('label-split-detail-area'), 50);
                } else {
                    // ж”¶иө·ж—¶жё…з©әж–Үжң¬жЎҶ
                    const textarea = document.getElementById('label-split-remark');
                    if (textarea) textarea.value = '';
                    labelConfig.splitRemark = '';
                }
            }
            updateLabelSummary();
        }

        // йў„и®ҫе®ҡд№үпјҡзЎ®дҝқдёҺжӮЁиҰҒжұӮзҡ„дёҖиҮҙ
        const labelMaterialTypes = [
            { name: 'еҚ°ж Ү', desc: '100%ж— и§Ұж„ҹ, жііиЈ…йҰ–йҖү', image: 'https://files.yiswim.cloud/uploads/img_12b71c3b-96ed-4d19-962c-af5d4d66bb8d_heattransfer.webp', icon: '' },
            { name: 'TPUж Ү', desc: 'й«ҳеј№йҳІж°ҙ, дәІиӮӨзЈЁз Ӯ', image: 'https://files.yiswim.cloud/uploads/img_345e3377-f8d5-479d-9437-c0caaa1fe532_tpu.webp', icon: '' },
            { name: 'з»Үе”ӣж Ү', desc: 'з»Ҹе…ёе“ҒзүҢж„ҹ, иҙЁж„ҹеҺҡе®һ', image: 'https://files.yiswim.cloud/uploads/img_b54b91f9-e177-46cf-a636-df595ea1baa8_zhimaibiao.webp', icon: '' },
            { name: 'е…¶д»–', desc: 'зјҺйқўж Ү/зү№з§Қж Үе®ҡеҲ¶', icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>' }
        ];
        
        // жӣҙж–°дёәд»…дҝқз•ҷ3дёӘйҖүйЎ№пјҢе№¶еҠ е…ҘеӣҫзүҮеұһжҖ§
        const sewingMethods = [
            { name: 'еҜ№жҠҳзҺҜзјқ', desc: 'еӨ№е…Ҙдҫ§зјқ/йўҶзјқ', image: 'https://files.yiswim.cloud/uploads/img_ef81a321-0e3f-4f28-9e37-b55e7f85b1a9_double-side.webp', icon: '' },
            { name: 'еҚ•иҫ№е№ізјқ', desc: 'еӣӣе‘ЁжҲ–еҚ•иҫ№иҪҰзәҝ', image: 'https://files.yiswim.cloud/uploads/img_d10c1d60-116f-4020-a85c-cdb20eddadec_single-side.webp', icon: '' },
            { name: 'е…¶д»–', desc: 'иҮӘе®ҡд№үзү№ж®ҠзјқеҲ¶', icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>' }
        ];

        // еҲқе§ӢеҢ–жёІжҹ“
        document.addEventListener('DOMContentLoaded', () => {
            const materialGrid = document.getElementById('label-material-grid');
            if (materialGrid) {
                materialGrid.innerHTML = labelMaterialTypes.map(t => {
                    let imgHtml = '';
                    // еҠЁжҖҒеҲӨж–ӯпјҡеҰӮжһңжңү image еұһжҖ§е°ұжёІжҹ“зңҹеӣҫпјҢеҗҰеҲҷжёІжҹ“зҒ°иүІ svg еҚ дҪҚ
                    if (t.image) {
                        imgHtml = `<div class="option-img-alt" style="height:140px; background:url('${t.image}') center/cover; border-bottom: 1px solid #e2e8f0;"></div>`;
                    } else {
                        imgHtml = `<div class="option-img-alt" style="height:140px; background:#f1f5f9; display:flex; align-items:center; justify-content:center; color:#94a3b8;">${t.icon}</div>`;
                    }
                    
                    return `
                    <div class="option-item metal-item ${labelConfig.material === t.name ? 'selected' : ''}" onclick="selectLabelMaterial('${t.name}', this)">
                        ${imgHtml}
                        <div class="option-info">
                            <h4>${t.name}</h4>
                            <p>${t.desc}</p>
                        </div>
                    </div>
                    `;
                }).join('');
            }
        
            const sewingGrid = document.getElementById('label-sewing-grid');
            if (sewingGrid) {
                sewingGrid.innerHTML = sewingMethods.map(m => {
                    let imgHtml = '';
                    if (m.image) {
                        imgHtml = `<div class="option-img-alt" style="height:140px; background:url('${m.image}') center/cover; border-bottom: 1px solid #e2e8f0;"></div>`;
                    } else {
                        imgHtml = `<div class="option-img-alt" style="height:140px; background:#f1f5f9; display:flex; align-items:center; justify-content:center; color:#94a3b8;">${m.icon}</div>`;
                    }
                    return `
                    <div class="option-item metal-item ${labelConfig.method === m.name ? 'selected' : ''}" onclick="selectLabelSewing('${m.name}', this)">
                        ${imgHtml}
                        <div class="option-info">
                            <h4>${m.name}</h4>
                            <p>${m.desc}</p>
                        </div>
                    </div>
                    `;
                }).join('');
