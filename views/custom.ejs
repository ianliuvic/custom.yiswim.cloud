            renderLabelPlacementPreviews(posType);
            updateLabelSummary();
            input.value = '';
        }
        
        function renderLabelPlacementPreviews(posType) {
            const gridId = posType === 'top' ? 'labelPlacementTopPreview' : 'labelPlacementBottomPreview';
            const grid = document.getElementById(gridId);
            if (!grid) return;
