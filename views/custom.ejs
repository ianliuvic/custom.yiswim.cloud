            const nameEl = document.getElementById('labelFileName');
            if (nameEl) nameEl.innerText = labelConfig.designFiles.length > 0 ? `е·ІйҖү ${labelConfig.designFiles.length} дёӘж–Үд»¶` : 'зӮ№еҮ»дёҠдј  AI / PDF / й«ҳжё…еӣҫ';
            
            renderLabelPreviews();
            updateLabelSummary();
        }

        // ==========================================
        // ж ҮзӯҫйҖ»иҫ‘пјҡиҮӘе®ҡд№үдҪҚзҪ®еӣҫзүҮдёҠдј еӨ„зҗҶ
        // ==========================================
        function handleLabelPlacementFiles(input, posType) {
            const files = Array.from(input.files);
            let targetArray = labelConfig.placementFiles[posType];
            
            files.forEach(file => {
                if (file.size > 20 * 1024 * 1024) { alert(`ж–Үд»¶ ${file.name} и¶…иҝҮ 20MB`); return; }
