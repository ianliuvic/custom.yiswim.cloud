        /* =========================================================
           7. дёҠдј жЎҶдёҺйҖҡз”ЁжҢүй’®
           ========================================================= */
        .premium-upload-box { border: 2px dashed #e2e8f0; background-color: #f8fafc; border-radius: 12px; padding: 40px 20px; text-align: center; transition: all 0.3s; cursor: pointer; }
