<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- 引入 public 文件夹下的通用样式 -->
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
    <style>
        /* 1. 基础布局变量与强制重置 */
        :root {
            --primary-color: #aa0000;
            --text-main: #2c3e50;
            --text-light: #7f8c8d;
            --border-color: #ececec;
            --header-height: 70px;
            --footer-height: 50px;
            --bg-sidebar: #fafafa;
        }

        /* 强制覆盖全局 style.css 的居中逻辑，实现全屏固定架构 */
        body {
            height: 100vh !important;
            width: 100vw !important;
            overflow: hidden !important; 
            display: flex !important;
            flex-direction: column !important;
            justify-content: flex-start !important;
            align-items: stretch !important;
            margin: 0 !important;
            padding: 0 !important;
            background-color: #fff !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        /* 2. 顶部固定导航栏 */
        .site-header {
            height: var(--header-height);
            min-height: var(--header-height);
            background: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            border-bottom: 1px solid var(--border-color);
            z-index: 100;
            box-sizing: border-box;
        }
        .header-left { display: flex; align-items: center; gap: 15px; }
        .site-logo { height: 38px; width: auto; }
        .site-title { font-size: 18px; font-weight: 600; color: var(--text-main); letter-spacing: 0.5px; }

        /* 3. 中间主体容器 */
        .main-container {
            flex: 1; 
            display: flex;
            overflow: hidden; 
            width: 100%;
        }

        /* 3.1 左侧配置区 - 采用 Flex 布局实现头尾固定、中间滚动 */
        .config-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            border-right: 1px solid var(--border-color);
            position: relative;
        }

        /* 步骤指示器 - 固定在左侧顶部 */
        .stepper {
            padding: 30px 60px 10px;
            display: flex;
            gap: 20px;
            background: #fff;
            z-index: 10;
        }
        .step {
            flex: 1;
            padding-bottom: 12px;
            border-bottom: 3px solid #eee;
            font-size: 13px;
            color: var(--text-light);
            text-transform: uppercase;
        }
        .step.active {
            border-bottom-color: var(--primary-color);
            color: var(--primary-color);
            font-weight: 600;
        }

        /* 内容滚动区 - 只有这里垂直滚动 */
        .config-scroll-area {
            flex: 1;
            overflow-y: auto;
            padding: 20px 60px 40px;
            box-sizing: border-box;
        }

        /* 操作按钮组 - 始终固定在左侧底部 */
        .button-group {
            padding: 20px 60px;
            background: #fff;
            border-top: 1px solid var(--border-color);
            display: flex;
            gap: 15px;
            z-index: 10;
        }

        /* 3.2 右侧汇总预览区 - 独立滚动 */
        .summary-sidebar {
            width: 380px;
            min-width: 380px;
            background-color: var(--bg-sidebar);
            padding: 40px;
            overflow-y: auto;
            height: 100%;
            box-sizing: border-box;
        }

        /* 4. 底部固定版权栏 */
        .site-footer {
            height: var(--footer-height);
            min-height: var(--footer-height);
            background: #fff;
            border-top: 1px solid var(--border-color);
            padding: 0 40px;
            display: flex;
            align-items: center;
            font-size: 13px;
            color: #999;
            z-index: 100;
            box-sizing: border-box;
        }

        /* --- UI 选项卡片设计 --- */
        .option-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .option-item {
            border: 1px solid var(--border-color);
            background: #fff;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
        }
        .option-item:hover { border-color: var(--primary-color); }
        .option-item.selected {
            border-color: var(--primary-color);
            background-color: #fff9f9;
            outline: 1px solid var(--primary-color);
        }
        .option-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: #f9f9f9;
            border-bottom: 1px solid var(--border-color);
        }
        .option-info { padding: 15px; }
        .option-info h4 { margin: 0 0 5px; font-size: 15px; }
        .option-info p { margin: 0; font-size: 13px; color: var(--text-light); }

        /* 按钮样式 */
        button {
            padding: 12px 35px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid var(--primary-color);
            transition: all 0.3s;
        }
        #nextBtn { background: var(--primary-color); color: #fff; }
        #prevBtn { background: #fff; color: var(--primary-color); }
        #prevBtn:disabled { border-color: #eee; color: #ccc; cursor: not-allowed; }

        /* 右侧汇总明细行 */
        .summary-title { font-size: 18px; font-weight: 600; margin-bottom: 30px; display: block; color: var(--text-main); }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 14px; border-bottom: 1px dashed #e0e0e0; padding-bottom: 10px; }
        .summary-row .label { color: var(--text-light); }
        .summary-row .value { color: var(--text-main); font-weight: 500; text-align: right; }

        /* 文件上传框 */
        .upload-box {
            padding: 60px 40px;
            border: 1px dashed var(--border-color);
            text-align: center;
            background: #fdfdfd;
        }

        .hidden { display: none !important; }

        /* 美化滚动条 */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 10px; }
    </style>
</head>
<body>

    <!-- 1. 顶部固定导航 -->
    <header class="site-header">
        <div class="header-left">
            <img src="/logo.png" alt="Hongxiu Logo" class="site-logo">
            <span class="site-title">Hongxiu Custom System</span>
        </div>
        <div style="font-size: 14px; color: var(--text-light);">
            当前用户：<strong><%= user.username %></strong> | 
            <a href="/logout" style="color: var(--primary-color); text-decoration: none; font-weight: 500;">安全退出</a>
        </div>
    </header>

    <!-- 2. 中间主体 -->
    <div class="main-container">
        
        <!-- 左侧：定制区域 -->
        <main class="config-main">
            <!-- 步进指示器 (固定) -->
            <nav class="stepper">
                <div class="step active" id="step-1-label">01. 款式定义</div>
                <div class="step" id="step-2-label">02. 面料材质</div>
                <div class="step" id="step-3-label">03. 品牌辅料</div>
                <div class="step" id="step-4-label">04. 物流交付</div>
                <div class="step" id="step-5-label">05. 需求汇总</div>
            </nav>

            <!-- 滚动内容区 -->
            <div class="config-scroll-area">
                <form id="configForm">
                    
                    <!-- 步骤 1: 款式 -->
                    <div class="step-content" id="step-1">
                        <h2 style="font-size: 24px; margin-top:0;">款式选择 / STYLE</h2>
                        <p style="color: var(--text-light); margin-bottom: 30px;">选择基础版型或开启 OEM 开发模式。</p>
                        
                        <div style="margin-bottom: 30px; display: flex; gap: 30px;">
                            <label style="cursor: pointer;"><input type="radio" name="styleMode" checked onclick="toggleStyleMode('existing')"> 现有款式 (ODM)</label>
                            <label style="cursor: pointer;"><input type="radio" name="styleMode" onclick="toggleStyleMode('custom')"> 自主设计 (OEM)</label>
                        </div>

                        <div id="existing-styles" class="option-grid">
                            <div class="option-item" onclick="selectItem('style', 'One-Piece', '简约连体款')">
                                <img src="https://images.unsplash.com/photo-1576188973526-0e5d742990af?w=500" class="option-img">
                                <div class="option-info"><h4>Classic One-Piece</h4><p>经典廓形 · 覆盖全面</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('style', 'Bikini', '分体比基尼')">
                                <img src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?w=500" class="option-img">
                                <div class="option-info"><h4>Triangle Bikini</h4><p>时尚多变 · 系带调节</p></div>
                            </div>
                        </div>

                        <div id="custom-upload" class="hidden">
                            <div class="upload-box">
                                <p>请上传您的设计稿或工艺单 (PDF/AI/PNG)</p>
                                <input type="file" multiple style="margin-top:20px;">
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 2: 面料 -->
                    <div class="step-content hidden" id="step-2">
                        <h2 style="font-size: 24px;">面料材质 / FABRIC</h2>
                        <div class="option-grid">
                            <div class="option-item" onclick="selectItem('fabric', 'Nylon 190G', '哑光尼龙 (190G)')">
                                <div style="height:180px; background:#333;"></div>
                                <div class="option-info"><h4>Matte Nylon</h4><p>80% Nylon, 20% Spandex</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('fabric', 'Recycled', '环保再生面料')">
                                <div style="height:180px; background:#1a3c34;"></div>
                                <div class="option-info"><h4>REPREVE® Eco</h4><p>可持续材料 · 高回弹</p></div>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 3: 辅料 -->
                    <div class="step-content hidden" id="step-3">
                        <h2 style="font-size: 24px;">品牌定制 / BRANDING</h2>
                        <div class="option-grid">
                            <div class="option-item" onclick="selectItem('branding', 'Heat Transfer', '烫印 Logo')">
                                <div class="option-info"><h4>Heat Transfer Logo</h4><p>无感舒适 · 适合高弹面料</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('branding', 'Metal Tag', '金属吊牌')">
                                <div class="option-info"><h4>Zinc Alloy Tag</h4><p>高端质感 · 多色可选</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('branding', 'Woven Label', '织唛主标')">
                                <div class="option-info"><h4>Woven Label</h4><p>经典品牌工艺</p></div>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 4: 物流 -->
                    <div class="step-content hidden" id="step-4">
                        <h2 style="font-size: 24px;">交付方式 / LOGISTICS</h2>
                        <div class="option-grid">
                            <div class="option-item" onclick="selectItem('shipping', 'Air Express', '空运快递 (5-7天)')">
                                <div class="option-info"><h4>Air Express</h4><p>DHL / FedEx / UPS</p></div>
                            </div>
                            <div class="option-item" onclick="selectItem('shipping', 'Sea Freight', '海运散货 (35天+)')">
                                <div class="option-info"><h4>Sea Freight</h4><p>适合大批量 · 成本最低</p></div>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 5: 确认 -->
                    <div class="step-content hidden" id="step-5">
                        <h2 style="font-size: 24px;">需求汇总确认</h2>
                        <p style="color: var(--text-light); margin-bottom: 30px;">请核对右侧清单。您可以在下方留言其他特殊需求。</p>
                        <textarea style="width:100%; height:150px; padding:15px; border:1px solid var(--border-color); font-family:inherit;" placeholder="备注：如尺码配比、特殊包装要求等..."></textarea>
                    </div>

                </form>
            </div>

            <!-- 按钮组 (固定) -->
            <div class="button-group">
                <button type="button" id="prevBtn" onclick="changeStep(-1)" disabled>返回上一步</button>
                <button type="button" id="nextBtn" onclick="changeStep(1)">继续下一步</button>
            </div>
        </main>

        <!-- 右侧汇总 (独立滚动) -->
        <aside class="summary-sidebar">
            <span class="summary-title">SELECTED DETAILS</span>
            
            <div class="summary-row"><span class="label">款式类型</span><span class="value" id="sum-style">未选择</span></div>
            <div class="summary-row"><span class="label">面料材质</span><span class="value" id="sum-fabric">未选择</span></div>
            <div class="summary-row"><span class="label">品牌辅料</span><span class="value" id="sum-branding">未选择</span></div>
            <div class="summary-row"><span class="label">交付方式</span><span class="value" id="sum-shipping">未选择</span></div>

            <div style="margin-top: 50px; padding: 20px; background: #fff; border: 1px solid var(--border-color); font-size: 13px; line-height: 1.6;">
                <strong>注意事项：</strong><br><br>
                · 提交后系统将生成需求编号，业务经理将在1个工作日内联系您。<br>
                · 初步报价基于当前面料价格，最终报价以正式合同为准。<br>
                · 样板周期预计 7-10 个工作日。
            </div>
        </aside>
    </div>

    <!-- 3. 底部固定版权 -->
    <footer class="site-footer">
        © 2026 红绣服饰 (Hongxiu Clothing). All Rights Reserved. | 专属定制 · 品质追踪
    </footer>

    <script>
        let currentStep = 1;
        const totalSteps = 5;

        function changeStep(n) {
            // 隐藏当前步骤
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.remove('active');
            
            currentStep += n;

            // 显示新步骤
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}-label`).classList.add('active');

            // 按钮状态更新
            document.getElementById('prevBtn').disabled = (currentStep === 1);
            
            if (currentStep === totalSteps) {
                document.getElementById('nextBtn').innerText = '确认并提交定制需求';
                document.getElementById('nextBtn').style.backgroundColor = '#27ae60';
                document.getElementById('nextBtn').style.borderColor = '#27ae60';
            } else {
                document.getElementById('nextBtn').innerText = '继续下一步';
                document.getElementById('nextBtn').style.backgroundColor = 'var(--primary-color)';
                document.getElementById('nextBtn').style.borderColor = 'var(--primary-color)';
            }

            // 重要：切换步骤后内容区自动置顶
            document.querySelector('.config-scroll-area').scrollTop = 0;
        }

        function toggleStyleMode(mode) {
            const list = document.getElementById('existing-styles');
            const upload = document.getElementById('custom-upload');
            if(mode === 'existing') {
                list.classList.remove('hidden'); upload.classList.add('hidden');
            } else {
                list.classList.add('hidden'); upload.classList.remove('hidden');
                document.getElementById('sum-style').innerText = 'OEM 自定义开发';
            }
        }

        function selectItem(category, value, displayName) {
            // 更新右侧汇总显示
            document.getElementById(`sum-${category}`).innerText = displayName;
            // 视觉高亮
            const container = document.getElementById(`step-${currentStep}`);
            container.querySelectorAll('.option-item').forEach(item => {
                item.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
        }
    </script>
</body>
</html>
