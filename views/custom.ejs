            renderLabelSewingPreviews();
            updateLabelSummary();
        }

        
        // 6. з»ҹдёҖзҡ„е…ЁеұҖж–Үд»¶дёҠдј еӨ„зҗҶ
        function handleLabelFiles(input) {
