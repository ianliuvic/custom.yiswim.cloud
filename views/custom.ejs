<!DOCTYPE html>
<html lang="<%= lng === 'zh' ? 'zh-CN' : 'en' %>">
<head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-WDPLK7NQ');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= lng === 'zh' ? '红绣定制系统——专业泳装ODM/OEM定制平台。在线配置面料、辅料、印花、吊牌，一站式完成打样与大货询盘。' : 'Hongxiu Custom System — Professional swimwear ODM/OEM customization platform. Configure fabrics, trims, prints, and labels online. Submit sampling or bulk inquiries in one flow.' %>">
    <meta name="keywords" content="<%= lng === 'zh' ? '泳装定制,比基尼定制,泳衣ODM,泳衣OEM,泳装工厂,红绣' : 'custom swimwear,bikini manufacturer,swimwear ODM,swimwear OEM,swimwear factory,Hongxiu' %>">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Hongxiu Clothing">
    <link rel="canonical" href="<%= baseUrl %>/">
    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= baseUrl %>/">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= lng === 'zh' ? '红绣定制系统——专业泳装ODM/OEM定制平台。在线配置面料、辅料、印花、吊牌，一站式完成打样与大货询盘。' : 'Hongxiu Custom System — Professional swimwear ODM/OEM customization platform. Configure fabrics, trims, prints and labels online.' %>">
    <meta property="og:image" content="<%= baseUrl %>/serp-image.webp">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Hongxiu Custom System">
    <meta property="og:locale" content="<%= lng === 'zh' ? 'zh_CN' : 'en_US' %>">
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description" content="<%= lng === 'zh' ? '红绣定制系统——专业泳装ODM/OEM定制平台。' : 'Hongxiu Custom System — Professional swimwear ODM/OEM customization platform.' %>">
    <meta name="twitter:image" content="<%= baseUrl %>/serp-image.webp">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/custom.css">
    <link rel="stylesheet" href="/modal.css">
    <style>
        /* 移动端抽屉（内联，防缓存） */
        .mobile-summary-fab { display: none !important; }
        .drawer-backdrop { display: none; }
        .drawer-handle { display: none; }
        @media (max-width: 1024px) {
            .mobile-summary-fab {
                display: flex !important;
                position: static !important;
                width: 44px !important; height: auto !important;
                min-width: 44px; max-width: 44px;
                min-height: unset; max-height: unset;
                border-radius: 0 !important;
                background: #fff !important;
                color: #64748b !important;
                border: 1px solid #e2e8f0 !important;
                padding: 0 !important;
                align-items: center; justify-content: center;
                align-self: stretch; flex-shrink: 0;
                cursor: pointer;
                -webkit-appearance: none; appearance: none;
            }
            .mobile-summary-fab:active { transform: scale(0.95); }
            /* Chatwoot 气泡避让底部按钮栏 */
            .woot-widget-bubble,
            .woot--bubble-holder { bottom: 75px !important; }
            .summary-sidebar {
                display: block !important;
                position: fixed !important;
                bottom: 0; left: 0; right: 0;
                width: 100% !important; min-width: unset !important;
                max-height: 75vh;
                z-index: 9999;
                background: #fff;
                border-radius: 0;
                box-shadow: 0 -10px 40px rgba(0,0,0,0.15);
                padding: 24px 24px 32px;
                transform: translateY(100%);
                transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
                overflow-y: auto;
            }
            .summary-sidebar.drawer-open { transform: translateY(0) !important; }
            .drawer-backdrop {
                position: fixed; inset: 0;
                background: rgba(0,0,0,0.4);
                z-index: 9998;
                backdrop-filter: blur(2px);
                opacity: 0; pointer-events: none;
                transition: opacity 0.3s;
            }
            .drawer-backdrop.active { display: block !important; opacity: 1; pointer-events: auto; }
            .drawer-handle {
                display: block !important;
                width: 40px; height: 4px;
                background: #cbd5e1;
                border-radius: 0;
                margin: 0 auto 16px;
            }
        }
    </style>
    <script>window.__lang = '<%= lng %>';</script>
    <script>window.__isLoggedIn = <%= user ? 'true' : 'false' %>;</script>
    <script src="/i18n.js"></script>
    <script src="/modal.js"></script>
    <% if (!user) { %><script src="https://accounts.google.com/gsi/client" async defer></script><% } %>
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WDPLK7NQ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- ===== Feedback Bar ===== -->
    <div id="feedbackBar" style="display:flex; align-items:center; justify-content:space-between; width:100%; height:40px; min-height:40px; flex-shrink:0; background:#fff8f0; border-bottom:1px solid #fde8cc; padding:0 30px; box-sizing:border-box; z-index:101;">
        <div style="display:flex; align-items:center; gap:12px; flex:1; min-width:0;">
            <span style="color:#92400e; font-size:12px; font-weight:600; white-space:nowrap;"><%= lng === 'zh' ? '帮助我们改进：' : 'Help us improve:' %></span>
            <button onclick="openFeedback('bug')" style="display:inline-flex; align-items:center; gap:5px; background:none; border:1px solid #f59e0b; color:#b45309; font-size:12px; font-weight:600; padding:4px 12px; border-radius:0; cursor:pointer; font-family:inherit; white-space:nowrap; transition:all 0.2s;" onmouseover="this.style.background='#f59e0b';this.style.color='#fff'" onmouseout="this.style.background='none';this.style.color='#b45309'">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <%= lng === 'zh' ? '报告页面问题' : 'Report a Bug' %>
                <span style="display:inline-block; background:#dcfce7; color:#16a34a; font-size:11px; font-weight:700; padding:1px 5px; margin-left:2px;">+$10</span>
            </button>
            <button onclick="openFeedback('experience')" style="display:inline-flex; align-items:center; gap:5px; background:none; border:1px solid #f59e0b; color:#b45309; font-size:12px; font-weight:600; padding:4px 12px; border-radius:0; cursor:pointer; font-family:inherit; white-space:nowrap; transition:all 0.2s;" onmouseover="this.style.background='#f59e0b';this.style.color='#fff'" onmouseout="this.style.background='none';this.style.color='#b45309'">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <%= lng === 'zh' ? '分享使用体验' : 'Share Feedback' %>
                <span style="display:inline-block; background:#dcfce7; color:#16a34a; font-size:11px; font-weight:700; padding:1px 5px; margin-left:2px;">+$5</span>
            </button>
        </div>
        <button onclick="dismissFeedbackBar()" title="Dismiss" style="background:none; border:none; color:#94a3b8; font-size:18px; cursor:pointer; padding:0 0 0 16px; line-height:1; flex-shrink:0;" onmouseover="this.style.color='#475569'" onmouseout="this.style.color='#94a3b8'">&#x2715;</button>
    </div>
    <!-- End Feedback Bar -->

    <header class="site-header">
        <div class="header-left" onclick="goToStep1()" style="cursor:pointer" title="Back to Step 1">
            <img src="/logo.png" alt="Hongxiu Logo" class="site-logo" onerror="this.style.display='none'">
            <span class="site-title">Hongxiu Custom System</span>
        </div>
        <div class="header-right" style="font-size: 13px; color: var(--text-light); display: flex; align-items: center; gap: 20px;">
            <a href="https://wearhongxiu.com" target="_blank" rel="noopener noreferrer" style="color: var(--text-light); text-decoration: none; transition: color 0.2s; display: inline-flex; align-items: center; gap: 5px;" onmouseover="this.style.color='var(--primary-color)'" onmouseout="this.style.color='var(--text-light)'">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span class="header-btn-label"><%= lng === 'zh' ? '企业官网' : 'Official Site' %></span>
            </a>
            <button onclick="setLanguage('<%= lng === 'zh' ? 'en' : 'zh' %>')" style="background: none; border: none; padding: 0; font-size: 13px; cursor: pointer; color: var(--text-light); transition: color 0.2s; display: inline-flex; align-items: center; gap: 5px;" onmouseover="this.style.color='var(--primary-color)'" onmouseout="this.style.color='var(--text-light)'">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <span class="header-btn-label"><%= lng === 'zh' ? 'EN' : '中文' %></span>
            </button>
            <% if (user) { %>
            <span class="header-user-text" style="display: flex; align-items: center; gap: 16px;">
                <strong style="color: var(--text-main);"><%= user.username %></strong>
                <a href="/user" style="color: var(--text-light); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--primary-color)'" onmouseout="this.style.color='var(--text-light)'"><%= lng === 'zh' ? '用户中心' : 'User Center' %></a>
                <a href="/logout" style="color: var(--text-light); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--primary-color)'" onmouseout="this.style.color='var(--text-light)'"><%= lng === 'zh' ? '退出' : 'Log Out' %></a>
            </span>
            <!-- 移动端：头像按钮 + 下拉菜单 -->
            <div class="header-avatar-wrap">
                <button class="header-avatar-btn" onclick="toggleUserMenu(event)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </button>
                <div class="header-user-menu" id="headerUserMenu">
                    <div class="header-user-menu-name"><%= user.username %></div>
                    <a href="/user" class="header-user-menu-item">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        User Center
                    </a>
                    <a href="/logout" class="header-user-menu-item header-user-menu-logout">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Log Out
                    </a>
                </div>
            </div>
            <% } else { %>
            <span class="header-user-text" style="display: flex; align-items: center; gap: 12px;">
                <button onclick="openAuth('login')" style="background: none; border: 1.5px solid var(--primary-color); color: var(--primary-color); padding: 6px 18px; border-radius: 0; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='var(--primary-color)';this.style.color='#fff'" onmouseout="this.style.background='none';this.style.color='var(--primary-color)'"><%= lng === 'zh' ? '登录' : 'Login' %></button>
                <button onclick="openAuth('register')" style="background: var(--primary-color); border: 1.5px solid var(--primary-color); color: #fff; padding: 6px 18px; border-radius: 0; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='var(--primary-hover)'" onmouseout="this.style.background='var(--primary-color)'"><%= lng === 'zh' ? '注册' : 'Register' %></button>
            </span>
            <!-- 移动端：未登录用户的登录按钮 -->
            <div class="header-avatar-wrap">
                <button class="header-avatar-btn" onclick="toggleGuestMenu(event)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </button>
                <div class="header-user-menu" id="headerGuestMenu">
                    <a href="javascript:void(0)" onclick="openAuth('login')" class="header-user-menu-item">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                        <%= lng === 'zh' ? '登录' : 'Login' %>
                    </a>
                    <a href="javascript:void(0)" onclick="openAuth('register')" class="header-user-menu-item">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                        <%= lng === 'zh' ? '注册' : 'Register' %>
                    </a>
                </div>
            </div>
            <% } %>
        </div>
    </header>

    <div class="main-container">
        <main class="config-main">
            <nav class="stepper">
                <div class="step active" id="step-1-label" onclick="goToStep(1)">01. Style Definition</div>
                <div class="step" id="step-2-label" onclick="goToStep(2)">02. Fabric Material</div>
                <div class="step" id="step-3-label" onclick="goToStep(3)">03. Brand Trims</div>
                <div class="step" id="step-4-label" onclick="goToStep(4)">04. Order & Delivery</div>
                <div class="step" id="step-5-label" onclick="goToStep(5)">05. Confirm & Submit</div>
            </nav>

            <div class="config-scroll-area">
                <form id="configForm" onsubmit="event.preventDefault();">
                    <!-- ==========================================
                         Step 1: Style Definition
                         ========================================== -->
                    <div class="step-content" id="step-1">
                        <div class="step-desc">Choose your customization mode: select from our library (ODM) or upload your own design package (OEM). Multiple styles supported.</div>
                        
                        <!-- --- 修改后 --- -->
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px;">
                            <div class="mode-switcher" style="margin-bottom: 0;"> <!-- 移除原有 margin-bottom -->
                                <div class="mode-option active" id="mode-odm" onclick="toggleStyleMode('existing')">ODM</div>
                                <div class="mode-option" id="mode-oem" onclick="toggleStyleMode('custom')">OEM</div>
                            </div>
                            
                            <button type="button" class="clear-all-btn" onclick="clearCurrentMode()" title="Clear current mode selections only">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;">
                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                Clear
                            </button>
                        </div>

                        <!-- 动态生成的 ODM 区域 -->
                        <div id="existing-styles">
                            <div class="category-nav" id="odm-category-nav"><p style="font-size:12px; color:#999;">Loading style data...</p></div>
                            <div id="odm-content-container"></div>
                        </div>

                        <!-- OEM 自主设计模块 -->
                        <div id="custom-upload" class="hidden" style="animation: fadeIn 0.4s ease;">
                            <!-- 新增：项目系列名称与款式数量 -->
                            <div class="oem-section-header" style="margin-bottom: 18px;">
                                <h4 class="section-heading" style="margin: 0;">A. Project Basic Info</h4>
                            </div>  
                            <div class="oem-upload-section" style="margin-bottom: 25px; padding: 20px; border: 1px solid #e2e8f0; border-radius: 0; background: #fbfcfd;">
                                <div style="display: flex; gap: 20px; align-items: flex-start; margin-bottom: 15px;">
                                    <div style="flex: 2;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">Project/Collection Name <span style="color:#ef4444;">*</span></label>
                                        <input type="text" id="oem-collection-name" class="oem-input-mini" style="width:100%; height:38px; box-sizing:border-box;" placeholder="E.g., 2026 Summer Neon Series" autocomplete="off" oninput="updateCombinedStyleSummary()">
                                    </div>
                                    <div style="flex: 1;">
                                        <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">Style Count <span style="color:#ef4444;">*</span></label>
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <input type="number" id="oem-collection-count" class="oem-input-mini" style="width:100%; height:38px; box-sizing:border-box;" value="0" min="0" max="50" oninput="renderOemStyleDescInputs()">
                                            <span style="font-size: 12px; color: #64748b;">style(s)</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- 项目简要描述 -->
                                <div style="margin-bottom: 15px;">
                                    <label style="display:block; font-size:12px; font-weight:600; color:#475569; margin-bottom:8px;">Project/Collection Description</label>
                                    <textarea id="oem-project-desc" class="oem-input-mini" style="width:100%; min-height:56px; box-sizing:border-box; resize:vertical; font-size:12px; line-height:1.6; padding:8px 12px;" placeholder="Briefly describe the overall info of styles you are uploading, e.g. product type, design style, target market, etc." maxlength="500"></textarea>
                                </div>
                                <!-- 动态生成的款式简述容器 -->
                                <div id="oem-style-desc-container" style="display: flex; flex-direction: column; gap: 10px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span style="font-size: 11px; font-weight: 600; color: var(--primary-color); min-width: 45px;">style(s) 1 :</span>
                                        <input type="text" class="oem-input-mini" style="flex: 1; height: 32px; font-size: 12px; background: #fff;" placeholder="Brief identifier (e.g., Red one-piece / Page 1 Bikini top)" value="" oninput="oemStyleDescriptions[0]=this.value; updateCombinedStyleSummary();">
                                    </div>
                                </div>
                            </div>
                            <!-- 微调后的极简提示 (暖色调/细虚线/小字体) -->
                            <div style="margin-bottom: 15px; padding: 8px 12px; background: #fffdf5; border: 1px dashed #fde68a; border-radius: 0; display: flex; align-items: flex-start; gap: 8px;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                <div style="font-size: 11px; color: #92400e; line-height: 1.5;"><strong>Upload Tip:</strong> If you submitted multiple designs, please ensure the <strong>reference image filenames</strong> or <strong>tech pack page numbers</strong> uploaded below clearly correspond to the "Style 1, Style 2…" descriptions in Area A.

</div>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 25px; align-items: start;">
                                <!-- A. 灵感参考图 -->
                                <div class="oem-upload-section">
                                    <div class="oem-section-header" style="margin-bottom: 12px;">
                                        <h4 class="section-heading" style="margin: 0 0 4px;">B. Reference & Inspiration</h4>
                                        <span class="oem-subtitle" style="margin-left: 13px;">Please upload style reference images or sketches</span>
                                    </div>
                                    <div class="oem-dropzone" id="oemRefDropzone" onclick="document.getElementById('oemRefFile').click()">
                                        <div style="text-align: center;">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                            <p style="margin-top: 8px; font-size: 12px; color: #64748b;">Drag or click to upload images</p>
                                        </div>
                                        <input type="file" id="oemRefFile" multiple class="hidden" onchange="handleOemFiles(this, 'ref')">
                                    </div>
                                    <div id="oemRefPreview" class="oem-image-preview-grid"></div>
                                </div>
                        
                                <!-- B. Tech Pack / Design Draft -->
                                <div class="oem-upload-section">
                                    <div class="oem-section-header" style="margin-bottom: 12px;">
                                        <h4 class="section-heading" style="margin: 0 0 4px;">C. Tech Pack / Design Draft</h4>
                                        <span class="oem-subtitle" style="margin-left: 13px;">&nbsp;</span>
                                    </div>

