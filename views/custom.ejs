            border: 1px solid var(--primary-color);
            box-shadow: 0 2px 4px rgba(170, 0, 0, 0.15); /* ж·Ўж·Ўзҡ„жҠ•еҪұ */
        }
        
        #nextBtn:hover:not(:disabled) {
            background: #c00000; /* з•Ҙеҫ®еҠ ж·ұ */
            filter: brightness(1.1); /* зЁҚеҫ®жҸҗдә®дёҖзӮ№зӮ№ */
            box-shadow: 0 4px 12px rgba(170, 0, 0, 0.25);
            transform: translateY(-1px);
        }
        
        #nextBtn:active:not(:disabled) {
            transform: translateY(0) scale(0.98);
        }
        
        /* зү№ж®Ҡпјҡз¬¬дә”жӯҘжҸҗдәӨзҠ¶жҖҒзҡ„ж ·ејҸеўһејәпјҲдёҚеҶҚдҪҝз”Ёз»ҝиүІпјү */
        #nextBtn.is-final {
            background: #1e293b; /* ж–№жЎҲпјҡжңҖеҗҺдёҖжӯҘдҪҝз”ЁзЁійҮҚзҡ„ж·ұжө·еҶӣи“қпјҢжҲ–дҝқжҢҒзәўиүІ */
