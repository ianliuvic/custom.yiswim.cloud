<!DOCTYPE html>
<html lang="<%= typeof lng !== 'undefined' && lng === 'zh' ? 'zh-CN' : 'en' %>">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VJRS8PCF14"></script>
    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-VJRS8PCF14');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <title><%= title %></title>
    <script>window.__lang = '<%= typeof lng !== 'undefined' ? lng : "en" %>';</script>
    <script src="/i18n.js"></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        :root {
            --primary-color: #aa0000;
            --primary-hover: #880000;
            --primary-light: rgba(170, 0, 0, 0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif; color: #1e293b; background: #fff; }

        /* Nav */
        .nav-wrapper { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: #fff; border-bottom: 1px solid #e5e7eb; }
        body { padding-top: 81px; }
        .landing-nav { display: flex; align-items: center; justify-content: space-between; max-width: 1440px; margin: 0 auto; padding: 16px 32px; }
        .landing-nav .logo-area { display: flex; align-items: center; gap: 10px; }
        .landing-nav .logo-area img { height: 48px; }
        .landing-nav .logo-area span { font-size: 18px; font-weight: 700; color: #1e293b; }
        .landing-nav .nav-actions { display: flex; align-items: center; gap: 12px; }
        .btn-login { padding: 8px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.25s; border: 1.5px solid var(--primary-color); color: var(--primary-color); background: transparent; }
        .btn-login:hover { background: var(--primary-color); color: #fff; }
        .btn-register { padding: 8px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.25s; border: 1.5px solid var(--primary-color); background: var(--primary-color); color: #fff; }
        .btn-register:hover { background: var(--primary-hover); border-color: var(--primary-hover); }
        .btn-lang { background: none; border: none; padding: 8px 12px; font-size: 14px; cursor: pointer; color: #64748b; transition: all 0.25s; display: inline-flex; align-items: center; gap: 6px; font-weight: 500; border-radius: 8px; }
        .btn-lang:hover { color: var(--primary-color); background: rgba(185, 28, 28, 0.06); }

        /* ===== Hero Split ===== */
        .hero-wrap { background: linear-gradient(150deg, #fdf2f2 0%, #fff9f9 35%, #fff 70%); }
        .hero-split { display: flex; align-items: center; gap: 48px; max-width: 1200px; margin: 0 auto; padding: 72px 48px 80px; }
        .hero-content { flex: 0.85; }
        .hero-visual { flex: 1.15; }
        .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--primary-light); color: var(--primary-color); font-size: 11px; font-weight: 600; padding: 4px 12px 4px 9px; border-radius: 20px; margin-bottom: 20px; letter-spacing: 0.4px; border: 1px solid rgba(170,0,0,0.15); }
        .hero-content h1 { font-size: 36px; font-weight: 800; line-height: 1.2; color: #0f172a; margin-bottom: 16px; }
        .hero-content h1 em { font-style: normal; color: var(--primary-color); }
        .hero-sub { font-size: 14px; color: #64748b; line-height: 1.8; margin-bottom: 32px; max-width: 420px; }
        .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
        .btn-cta { padding: 12px 28px; border-radius: 8px; font-size: 13.5px; font-weight: 700; cursor: pointer; text-decoration: none; transition: all 0.25s; display: inline-block; border: 2px solid transparent; }
        .btn-cta-primary { background: var(--primary-color); color: #fff; border-color: var(--primary-color); }
        .btn-cta-primary:hover { background: var(--primary-hover); border-color: var(--primary-hover); }
        .btn-cta-ghost { background: transparent; color: #475569; border-color: #d1d5db; }
        .btn-cta-ghost:hover { border-color: #94a3b8; color: #1e293b; }
        .hero-img-wrap { position: relative; }
        .hero-img-wrap img, .hero-img-wrap iframe { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.10); }

        /* ===== Stats Strip ===== */
        .stats-strip { background: #0f172a; padding: 30px 48px; }
        .stats-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); }
        .stat-item { text-align: center; padding: 6px 24px; border-right: 1px solid rgba(255,255,255,0.1); }
        .stat-item:last-child { border-right: none; }
        .stat-num { font-size: 32px; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; }
        .stat-num b { color: #f87171; font-weight: 800; }
        .stat-lbl { font-size: 11.5px; color: #94a3b8; font-weight: 500; letter-spacing: 0.6px; text-transform: uppercase; }

        /* ===== Value Props ===== */
        .vp-section { max-width: 1200px; margin: 0 auto; padding: 80px 48px; }
        .section-head { text-align: center; font-size: 28px; font-weight: 700; color: #0f172a; margin-bottom: 12px; }
        .section-sub { text-align: center; font-size: 15px; color: #64748b; margin-bottom: 50px; line-height: 1.6; }
        .vp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .vp-card { padding: 36px 30px 30px; border-radius: 18px; background: #fff; border: 1.5px solid #e2e8f0; transition: all 0.25s; }
        .vp-card:hover { border-color: rgba(170,0,0,0.28); box-shadow: 0 10px 36px rgba(170,0,0,0.07); transform: translateY(-3px); }
        .vp-icon { width: 50px; height: 50px; border-radius: 14px; background: var(--primary-light); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; color: var(--primary-color); }
        .vp-card h3 { font-size: 18px; font-weight: 700; color: #0f172a; margin-bottom: 10px; }
        .vp-card p { font-size: 14px; color: #64748b; line-height: 1.78; }
        .vp-tag { display: inline-block; margin-top: 16px; font-size: 11px; font-weight: 600; color: var(--primary-color); background: var(--primary-light); padding: 3px 10px; border-radius: 20px; }

        /* ===== How It Works ===== */
        .flow-section { background: #f8fafc; padding: 72px 48px; border-top: 1px solid #f0f0f0; }
        .flow-inner { max-width: 880px; margin: 0 auto; }
        .flow-steps { display: grid; grid-template-columns: repeat(4, 1fr); position: relative; margin-top: 8px; }
        .flow-connector { position: absolute; top: 23px; left: 12%; right: 12%; height: 2px; background: linear-gradient(90deg, var(--primary-color) 0%, #e2e8f0 70%); z-index: 0; }
        .flow-step { text-align: center; padding: 0 10px; position: relative; z-index: 1; }
        .flow-num { width: 48px; height: 48px; border-radius: 50%; background: var(--primary-color); color: #fff; font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; box-shadow: 0 4px 16px rgba(170,0,0,0.28); }
        .flow-step-name { font-size: 14px; font-weight: 700; color: #1e293b; margin-bottom: 5px; }
        .flow-step-desc { font-size: 12px; color: #94a3b8; line-height: 1.55; }

        /* Footer */
        .landing-footer { text-align: center; padding: 40px 24px; color: #94a3b8; font-size: 13px; border-top: 1px solid #f1f1f1; }

        /* ===== Auth Modal ===== */
        .auth-overlay { display: none; position: fixed; inset: 0; z-index: 10000; background: rgba(0,0,0,0.45); justify-content: center; align-items: center; animation: overlayIn 0.2s ease; }
        .auth-overlay.active { display: flex; }
        @keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }

        .auth-modal { position: relative; width: 100%; max-width: 420px; background: #fff; border-radius: 16px; padding: 40px 35px 32px; box-shadow: 0 20px 60px rgba(0,0,0,0.15); animation: modalIn 0.25s ease; overflow: hidden; }
        @keyframes modalIn { from { opacity: 0; transform: translateY(24px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
        .auth-modal::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: var(--primary-color); }

        .auth-close { position: absolute; top: 14px; right: 18px; background: none; border: none; font-size: 22px; color: #94a3b8; cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: all 0.2s; line-height: 1; }
        .auth-close:hover { color: #1e293b; background: #f1f5f9; }

        .auth-modal h2 { text-align: center; font-size: 22px; font-weight: 700; color: #1e293b; margin-bottom: 24px; }

        .auth-modal .status-msg { padding: 10px 14px; border-radius: 8px; font-size: 13px; text-align: center; margin-bottom: 16px; animation: fadeIn 0.3s ease; }
        .auth-modal .status-error { background: #fde8e8; color: #c81e1e; border: 1px solid #f8b4b4; }
        .auth-modal .status-success { background: #defadb; color: #1e5e20; border: 1px solid #bcf0da; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

        .auth-modal form { display: flex; flex-direction: column; }
        .auth-modal input { width: 100%; padding: 13px 14px; margin-bottom: 16px; border: 1px solid #e1e4e8; border-radius: 8px; font-size: 14px; outline: none; transition: all 0.25s; background: #fafbfc; font-family: inherit; }
        .auth-modal input::placeholder { color: #cbd5e1; }
        .auth-modal input:focus { background: #fff; border-color: var(--primary-color); box-shadow: 0 0 0 3px var(--primary-light); }

        .auth-modal .password-wrapper { position: relative; width: 100%; margin-bottom: 16px; }
        .auth-modal .password-wrapper input { margin-bottom: 0; padding-right: 44px; }
        .auth-modal .toggle-password { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); cursor: pointer; display: flex; align-items: center; color: #999; transition: color 0.3s; }
        .auth-modal .toggle-password:hover { color: var(--primary-color); }
        .auth-modal .eye-icon { width: 18px; height: 18px; }

        .auth-modal button[type="submit"] { background: var(--primary-color); color: #fff; border: none; padding: 13px; font-size: 15px; font-weight: 600; border-radius: 8px; cursor: pointer; transition: background 0.25s, transform 0.1s; margin-top: 4px; }
        .auth-modal button[type="submit"]:hover { background: var(--primary-hover); }
        .auth-modal button[type="submit"]:active { transform: scale(0.98); }
        .auth-modal button[type="submit"]:disabled { background: #d48080; cursor: not-allowed; transform: none; }

        .auth-modal .links { margin-top: 20px; display: flex; flex-direction: column; align-items: center; gap: 10px; font-size: 13px; color: #666; }
        .auth-modal .links span { color: var(--primary-color); cursor: pointer; font-weight: 500; transition: color 0.2s; }
        .auth-modal .links span:hover { color: var(--primary-hover); text-decoration: underline; }

        .auth-modal .help-text { font-size: 13px; color: #666; text-align: center; margin-bottom: 16px; line-height: 1.5; }

        .hidden { display: none !important; }

        @media (max-width: 768px) {
            .landing-nav { padding: 12px 16px; }
            .landing-nav .logo-area span { display: none; }
            .landing-nav .logo-area img { height: 36px; }
            .landing-nav .nav-actions { gap: 6px; }
            .btn-lang { padding: 6px 8px; font-size: 13px; }
            .btn-lang svg { display: none; }
            .btn-login, .btn-register { padding: 6px 14px; font-size: 13px; }
            .hero-split { flex-direction: column-reverse; gap: 36px; padding: 40px 16px 52px; }
            .hero-visual { width: 100%; }
            .hero-img-wrap iframe { width: 100%; }
            .hero-content h1 { font-size: 30px; }
            .hero-sub { font-size: 15px; max-width: 100%; }
            .stats-strip { padding: 24px 20px; }
            .stats-inner { grid-template-columns: repeat(2, 1fr); gap: 0; }
            .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding: 14px 0; }
            .stat-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.1); }
            .stat-item:nth-child(3), .stat-item:nth-child(4) { border-bottom: none; }
            .vp-section { padding: 52px 20px; }
            .vp-grid { grid-template-columns: 1fr; gap: 16px; }
            .section-head { font-size: 22px; }
            .flow-section { padding: 52px 20px; }
            .flow-steps { grid-template-columns: repeat(2, 1fr); gap: 32px; }
            .flow-connector { display: none; }
            .btn-cta { padding: 12px 24px; font-size: 14px; }
            .auth-modal { margin: 16px; padding: 32px 24px 24px; }
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <div class="nav-wrapper">
    <nav class="landing-nav">
        <a class="logo-area" href="/" style="text-decoration:none;color:inherit;">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
            <span><%= typeof lng !== 'undefined' && lng === 'en' ? 'Hongxiu Custom System' : '红绣定制系统' %></span>
        </a>
        <div class="nav-actions">
            <a class="btn-lang" href="https://wearhongxiu.com" target="_blank" rel="noopener">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <%= typeof lng !== 'undefined' && lng === 'zh' ? '企业官网' : 'Official Site' %>
            </a>
            <button class="btn-lang" onclick="setLanguage(window.__lang === 'en' ? 'zh' : 'en')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <%= typeof lng !== 'undefined' && lng === 'zh' ? 'EN' : '中文' %>
            </button>
            <button class="btn-login" onclick="openAuth('login')"><%= typeof lng !== 'undefined' && lng === 'zh' ? '登录' : 'Login' %></button>
            <button class="btn-register" onclick="openAuth('register')"><%= typeof lng !== 'undefined' && lng === 'zh' ? '注册' : 'Register' %></button>
        </div>
    </nav>
    </div>

    <!-- Hero -->
    <div class="hero-wrap">
        <div class="hero-split">
            <div class="hero-content">
                <div class="hero-badge">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    <%= lng === 'en' ? "World's Swimwear Capital · Direct Factory" : '世界泳装之都 · 源头工厂直营' %>
                </div>
                <h1>
                    <%- lng === 'en'
                        ? 'The Platform Built<br><em>Exclusively</em> for<br>Swimwear Brands.'
                        : '专为泳装品牌<br>打造的<em>一站式</em><br>数字化定制平台' %>
                </h1>
                <p class="hero-sub">
                    <%= lng === 'en'
                        ? 'ODM from our curated swimwear library, or OEM with your own designs — all online, direct from our factory in Xingcheng, China.'
                        : '从工厂现款中选品，或上传自主设计稿，全程在线管理，直达兴城源头工厂，24小时专属报价响应。' %>
                </p>
                <div class="hero-cta">
                    <button class="btn-cta btn-cta-primary" onclick="openAuth('register')">
                        <%= lng === 'en' ? 'Start Your Inquiry' : '立即开始定制' %>
                    </button>
                    <button class="btn-cta btn-cta-ghost" onclick="openAuth('login')">
                        <%= lng === 'en' ? 'Sign In' : '已有账号登录' %>
                    </button>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-img-wrap">
                    <iframe src="https://www.youtube.com/embed/YP5dcAD5ZUM" title="<%= lng === 'en' ? 'Premium swimwear customization' : '专业泳装定制' %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Strip -->
    <div class="stats-strip">
        <div class="stats-inner">
            <div class="stat-item">
                <div class="stat-num">10<b>+</b></div>
                <div class="stat-lbl"><%= lng === 'en' ? 'Years Manufacturing' : '年泳装制造经验' %></div>
            </div>
            <div class="stat-item">
                <div class="stat-num">200,000<b>+</b></div>
                <div class="stat-lbl"><%= lng === 'en' ? 'Units / Year' : '年产能（件）' %></div>
            </div>
            <div class="stat-item">
                <div class="stat-num">30<b>+</b></div>
                <div class="stat-lbl"><%= lng === 'en' ? 'Global Brand Partners' : '全球品牌合作伙伴' %></div>
            </div>
            <div class="stat-item">
                <div class="stat-num">24<b>h</b></div>
                <div class="stat-lbl"><%= lng === 'en' ? 'Quote Response' : '报价响应承诺' %></div>
            </div>
        </div>
    </div>

    <!-- Value Props -->
    <div class="vp-section">
        <div class="section-head"><%= lng === 'en' ? 'Why Work With Us' : '为什么选择我们' %></div>
        <p class="section-sub"><%= lng === 'en' ? 'Everything a swimwear brand needs — from a single source factory.' : '泳装品牌所需的一切，来自同一个源头工厂。' %></p>
        <div class="vp-grid">
            <div class="vp-card">
                <div class="vp-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <h3><%= lng === 'en' ? 'Direct Source Factory' : '源头工厂直营' %></h3>
                <p><%= lng === 'en'
                    ? "Based in Xingcheng — China's designated swimwear manufacturing hub. No middlemen, transparent pricing, and quality control at every stage directly in our hands."
                    : '工厂坐落于中国泳装之都兴城市，自有生产线，无中间商，价格透明，每道工序品质直控。' %></p>
                <span class="vp-tag"><%= lng === 'en' ? '📍 Xingcheng, Liaoning · China' : '📍 辽宁省兴城市' %></span>
            </div>
            <div class="vp-card">
                <div class="vp-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <h3><%= lng === 'en' ? 'Full-Service Customization' : '全流程深度定制' %></h3>
                <p><%= lng === 'en'
                    ? 'ODM from our curated library or OEM from your designs. Fabric, print, metal trims, padding, packaging — every detail configured in one platform.'
                    : '支持ODM现款定制与OEM自主设计，面料色彩、定制印花、金属扣件、胸垫、包装吊牌，每个细节均可在线配置。' %></p>
                <span class="vp-tag"><%= lng === 'en' ? 'ODM + OEM · NDA Protected' : 'ODM + OEM · NDA全程保密' %></span>
            </div>
            <div class="vp-card">
                <div class="vp-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <h3><%= lng === 'en' ? 'Digital & Fast' : '数字化 · 快速响应' %></h3>
                <p><%= lng === 'en'
                    ? 'Submit your full brief online in minutes. A dedicated sales manager reviews it and responds with a formal quote within 24 hours — no endless email chains.'
                    : '在线提交完整定制需求，专属业务经理全程跟进，24小时内提供正式报价，告别繁琐往来邮件。' %></p>
                <span class="vp-tag"><%= lng === 'en' ? '24h Quote Guarantee' : '24小时报价承诺' %></span>
            </div>
        </div>
    </div>

    <!-- How It Works -->
    <div class="flow-section">
        <div class="flow-inner">
            <div class="section-head"><%= lng === 'en' ? 'How It Works' : '下单流程' %></div>
            <p class="section-sub" style="margin-bottom:48px;"><%= lng === 'en' ? 'From first click to professional quote — four simple steps.' : '四步完成，从注册到收到专属报价。' %></p>
            <div class="flow-steps">
                <div class="flow-connector"></div>
                <div class="flow-step">
                    <div class="flow-num">01</div>
                    <div class="flow-step-name"><%= lng === 'en' ? 'Register' : '注册账号' %></div>
                    <div class="flow-step-desc"><%= lng === 'en' ? 'Free account, NDA auto-signed' : '免费注册，自动签署保密协议' %></div>
                </div>
                <div class="flow-step">
                    <div class="flow-num">02</div>
                    <div class="flow-step-name"><%= lng === 'en' ? 'Select or Design' : '选款或上传设计' %></div>
                    <div class="flow-step-desc"><%= lng === 'en' ? 'Browse ODM styles or upload your own' : '从现款库选品或上传自主设计稿' %></div>
                </div>
                <div class="flow-step">
                    <div class="flow-num">03</div>
                    <div class="flow-step-name"><%= lng === 'en' ? 'Configure & Submit' : '配置并提交' %></div>
                    <div class="flow-step-desc"><%= lng === 'en' ? 'Fabric, trims, delivery details' : '选择面料辅料，填写交付要求' %></div>
                </div>
                <div class="flow-step">
                    <div class="flow-num">04</div>
                    <div class="flow-step-name"><%= lng === 'en' ? 'Receive Quote' : '收到专属报价' %></div>
                    <div class="flow-step-desc"><%= lng === 'en' ? 'Professional quote within 24 hours' : '专属业务经理24小时内回复' %></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="landing-footer">
        <p>&copy; <script>document.write(new Date().getFullYear())</script> Hongxiu Custom System. All rights reserved. <span style="color: #d1d5db; margin: 0 6px;">|</span><a href="/privacy" style="color: #64748b; text-decoration: none; font-size: 13px; transition: color 0.2s;" onmouseover="this.style.color='#1e293b'" onmouseout="this.style.color='#64748b'"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Privacy Policy' : '隐私权政策' %></a></p>
    </footer>

    <!-- ===== Auth Modal ===== -->
    <div class="auth-overlay" id="authOverlay">
        <div class="auth-modal">
            <button class="auth-close" onclick="closeAuth()">&times;</button>
            <div id="auth-status-msg" class="status-msg hidden"></div>

            <!-- Login Form -->
            <div id="login-box" class="form-box">
                <h2><%= typeof lng !== 'undefined' && lng === 'en' ? 'Login' : '用户登录' %></h2>
                <form id="loginForm">
                    <input type="text" id="loginUser" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Username or Email' : '用户名或邮箱' %>" required>
                    <div class="password-wrapper">
                        <input type="password" id="loginPass" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Password' : '密码' %>" required>
                        <span class="toggle-password" onclick="togglePassword('loginPass', this)">
                            <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        </span>
                    </div>
                    <button type="submit"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Login' : '登 录' %></button>
                </form>
                <div style="text-align: center; margin: 16px 0; color: #94a3b8; font-size: 12px; position: relative;">
                    <span style="background: #fff; padding: 0 10px; position: relative; z-index: 1;">OR</span>
                    <div style="position: absolute; top: 50%; left: 0; right: 0; border-top: 1px solid #e1e4e8; z-index: 0;"></div>
                </div>
                <div class="google-btn-container" style="display: flex; justify-content: center; margin-bottom: 16px;"></div>
                <div class="links">
                    <span onclick="switchAuthBox('register-box')"><%= typeof lng !== 'undefined' && lng === 'en' ? "Don't have an account? Register" : '没有账号？点击注册' %></span>
                    <span onclick="switchAuthBox('forgot-box')"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Forgot password?' : '忘记密码？' %></span>
                </div>
            </div>

            <!-- Register Form -->
            <div id="register-box" class="form-box hidden">
                <h2><%= typeof lng !== 'undefined' && lng === 'en' ? 'Create Account' : '创建账号' %></h2>
                <form id="registerForm">
                    <input type="text" id="regUser" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Username' : '设置用户名' %>" required>
                    <input type="email" id="regEmail" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Email' : '常用邮箱' %>" required>
                    <div class="password-wrapper">
                        <input type="password" id="regPass" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Password (min 8 chars)' : '设置密码 (至少8位)' %>" required minlength="8">
                        <span class="toggle-password" onclick="togglePassword('regPass', this)">
                            <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        </span>
                    </div>
                    <button type="submit"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Register' : '注 册' %></button>
                </form>
                <div style="text-align: center; margin: 16px 0; color: #94a3b8; font-size: 12px; position: relative;">
                    <span style="background: #fff; padding: 0 10px; position: relative; z-index: 1;">OR</span>
                    <div style="position: absolute; top: 50%; left: 0; right: 0; border-top: 1px solid #e1e4e8; z-index: 0;"></div>
                </div>
                <div class="google-btn-container" style="display: flex; justify-content: center; margin-bottom: 16px;"></div>
                <div class="links">
                    <span onclick="switchAuthBox('login-box')"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Already have an account? Login' : '已有账号？返回登录' %></span>
                </div>
            </div>

            <!-- Forgot Password Form -->
            <div id="forgot-box" class="form-box hidden">
                <h2><%= typeof lng !== 'undefined' && lng === 'en' ? 'Reset Password' : '找回密码' %></h2>
                <p class="help-text">
                    <%= typeof lng !== 'undefined' && lng === 'en'
                        ? 'Enter the email you registered with and we will send you a reset link.'
                        : '请输入您注册时使用的邮箱，<br>我们将向您发送重置链接。' %>
                </p>
                <form id="forgotForm">
                    <input type="email" id="forgotEmail" placeholder="<%= typeof lng !== 'undefined' && lng === 'en' ? 'Registered email' : '注册邮箱' %>" required>
                    <button type="submit"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Send Reset Email' : '发送重置邮件' %></button>
                </form>
                <div class="links">
                    <span onclick="switchAuthBox('login-box')"><%= typeof lng !== 'undefined' && lng === 'en' ? 'Remember your password? Login' : '记起密码了？返回登录' %></span>
                </div>
            </div>
        </div>
    </div>

    <script>
        /* ===== Google Auth Init ===== */
        window.onload = function () {
            var gClientId = '<%= typeof googleClientId !== "undefined" ? googleClientId : "" %>';
            if (gClientId) {
                google.accounts.id.initialize({
                    client_id: gClientId,
                    callback: handleGoogleResponse
                });
                var googleBtnContainers = document.querySelectorAll('.google-btn-container');
                googleBtnContainers.forEach(function(container) {
                    google.accounts.id.renderButton(
                        container,
                        { theme: 'outline', size: 'large', width: '100%', locale: window.__lang || 'en' }
                    );
                });
            }
        };

        async function handleGoogleResponse(response) {
            hideMessage();
            var idToken = response.credential;
            try {
                var res = await fetch('/api/google-auth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: idToken })
                });
                var result = await res.json();
                if (result.success) {
                    window.location.href = '/';
                } else {
                    showMessage(result.message || (window.__lang === 'en' ? 'Google Login Failed' : 'Google 登录失败'), 'error');
                }
            } catch (err) {
                showMessage(window.__lang === 'en' ? 'Network error, try later' : '网络连接失败，请稍后再试', 'error');
            }
        }

        /* ===== Modal open / close ===== */
        function openAuth(type) {
            var overlay = document.getElementById('authOverlay');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
            if (type === 'register') {
                switchAuthBox('register-box');
            } else {
                switchAuthBox('login-box');
            }
        }

        function closeAuth() {
            var overlay = document.getElementById('authOverlay');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
            hideMessage();
        }

        // Close on overlay click (not modal itself)
        document.getElementById('authOverlay').addEventListener('click', function(e) {
            if (e.target === this) closeAuth();
        });

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeAuth();
        });

        /* ===== Toggle password visibility ===== */
        function togglePassword(inputId, el) {
            var input = document.getElementById(inputId);
            var eyeOpen = '<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
            var eyeClose = '<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
            if (input.type === 'password') {
                input.type = 'text';
                el.innerHTML = eyeOpen;
            } else {
                input.type = 'password';
                el.innerHTML = eyeClose;
            }
        }

        /* ===== Message helpers ===== */
        function showMessage(text, type) {
            var box = document.getElementById('auth-status-msg');
            box.innerText = text;
            box.classList.remove('hidden', 'status-error', 'status-success');
            box.classList.add(type === 'success' ? 'status-success' : 'status-error');
        }

        function hideMessage() {
            var box = document.getElementById('auth-status-msg');
            if (box) box.classList.add('hidden');
        }

        /* ===== Switch between login / register / forgot ===== */
        function switchAuthBox(boxId) {
            hideMessage();
            document.querySelectorAll('.auth-modal .form-box').forEach(function(b) { b.classList.add('hidden'); });
            document.getElementById(boxId).classList.remove('hidden');
            // Reset password fields
            document.querySelectorAll('.auth-modal input').forEach(function(inp) {
                if (inp.id.includes('Pass')) inp.type = 'password';
            });
        }

        /* ===== Unified form submit ===== */
        async function handleFormSubmit(e, endpoint, payload) {
            e.preventDefault();
            hideMessage();
            var btn = e.target.querySelector('button[type="submit"]');
            var originalText = btn.innerText;
            btn.innerText = window.__lang === 'en' ? 'Processing...' : '处理中...';
            btn.disabled = true;
            try {
                var response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var result = await response.json();
                if (result.success) {
                    if (endpoint === '/api/login') {
                        window.location.href = '/';
                    } else {
                        showMessage(result.message || (window.__lang === 'en' ? 'Success!' : '操作成功！'), 'success');
                    }
                } else {
                    showMessage(result.message || (window.__lang === 'en' ? 'Operation failed, please retry' : '操作失败，请重试'));
                }
            } catch (error) {
                showMessage(window.__lang === 'en' ? 'Network error, please try later' : '网络连接失败，请稍后再试');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }

        // Auto-hide message on input
        document.querySelectorAll('.auth-modal input').forEach(function(inp) {
            inp.addEventListener('input', hideMessage);
        });

        // Login
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            handleFormSubmit(e, '/api/login', {
                username: document.getElementById('loginUser').value,
                password: document.getElementById('loginPass').value
            });
        });

        // Register
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            var pw = document.getElementById('regPass').value;
            if (pw.length < 8) {
                showMessage(window.__lang === 'en' ? 'Password must be at least 8 characters' : '密码长度至少需要 8 位', 'error');
                e.preventDefault();
                return;
            }
            handleFormSubmit(e, '/api/register', {
                username: document.getElementById('regUser').value,
                email: document.getElementById('regEmail').value,
                password: pw
            });
        });

        // Forgot password
        document.getElementById('forgotForm').addEventListener('submit', function(e) {
            handleFormSubmit(e, '/api/forgot-password', {
                email: document.getElementById('forgotEmail').value
            });
        });

        // Handle ?activated=true query param (from email activation link)
        (function() {
            var params = new URLSearchParams(window.location.search);
            if (params.get('activated') === 'true') {
                openAuth('login');
                setTimeout(function() {
                    showMessage(window.__lang === 'en' ? 'Account activated! Please login.' : '账号已激活，请登录。', 'success');
                }, 100);
            }
            // Support /login redirect → open modal
            if (params.get('auth') === 'login') openAuth('login');
            if (params.get('auth') === 'register') openAuth('register');
        })();
    </script>

    <!-- === 1. Chatwoot 动态配置 (含多语言同步) === -->
    <script>
      var systemLang = window.__lang || 'en';
      var chatwootLocale = systemLang === 'en' ? 'en' : 'zh_CN';
      var chatwootToken = systemLang === 'en'
        ? '7SvUcM7Q35czsNHZYcZiXtNu'
        : 'qQNjoJ2DsKdY4Hxmv2pCNM6S';  // 中文Token
    
      window.chatwootSettings = {
        "position": "right",
        "type": "standard",
        "launcherTitle": "",
        "locale": chatwootLocale,
        "useBrowserLanguage": false
      };
    </script>
    
    <!-- === 2. Chatwoot 官方加载核心 === -->
    <script>
      (function(d,t) {
        var BASE_URL="https://chat.yiswim.cloud";
        var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
        g.src=BASE_URL+"/packs/js/sdk.js";
        g.async = true;
        s.parentNode.insertBefore(g,s);
        g.onload=function(){
          window.chatwootSDK.run({
            websiteToken: chatwootToken,   // 这里改为动态变量
            baseUrl: BASE_URL
          })
        }
      })(document,"script");
    </script>
    
    <!-- === 3. 寄生注入遮盖层 (去水印终极 Hack) === -->
    <script>
      window.addEventListener("chatwoot:ready", function () {
        let radar = setInterval(function() {
           let wootContainer = document.querySelector('.woot-widget-holder');
           if (wootContainer) {
              clearInterval(radar); 

              let shield = document.createElement('a');
              
              // 根据当前的语言，遮盖层的文字也做相应的翻译！极其专业！
              if (chatwootLocale === 'en') {
                  shield.innerHTML = '⚡️ Powered by Hongxiu Clothing';
              } else {
                  shield.innerHTML = '⚡️ 由红绣服饰支持';
              }
              
              shield.href = 'https://wearhongxiu.com'; // 修改为真实链接
              shield.target = '_blank';
              
              shield.style.cssText = `
                  display: block;
                  position: absolute;
                  bottom: 10px;
                  left: 0px;
                  width: 100%;
                  height: 24px;       /* 完美贴合输入框下方 */
                  line-height: 24px;
                  font-size: 12px;
                  background-color: #f9fafb; 
                  z-index: 2147483647; 
                  text-align: center;
                  color: #9ca3af;
                  text-decoration: none; 
                  cursor: pointer; 
                  border-radius: 0 0 10px 10px;
              `;
              wootContainer.appendChild(shield);
           }
        }, 100);
        setTimeout(() => clearInterval(radar), 5000);
      });
    </script>
</body>
</html>
