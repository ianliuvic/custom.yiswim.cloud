<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
</head>
<body>
    <div class="auth-container">
        
        <!-- 登录表单 (默认显示) -->
        <div id="login-box" class="form-box">
            <h2>用户登录</h2>
            <form id="loginForm">
                <input type="text" id="loginUser" placeholder="用户名或邮箱" required>
                <input type="password" id="loginPass" placeholder="密码" required>
                <button type="submit">登 录</button>
            </form>
            <div class="links">
                <span onclick="switchBox('register-box')">没有账号？点击注册</span>
                <span onclick="switchBox('forgot-box')">忘记密码？</span>
            </div>
        </div>

        <!-- 注册表单 (默认隐藏) -->
        <div id="register-box" class="form-box hidden">
            <h2>创建账号</h2>
            <form id="registerForm">
                <input type="text" id="regUser" placeholder="设置用户名" required>
                <input type="email" id="regEmail" placeholder="常用邮箱" required>
                <input type="password" id="regPass" placeholder="设置密码" required>
                <button type="submit">注 册</button>
            </form>
            <div class="links">
                <span onclick="switchBox('login-box')">已有账号？返回登录</span>
            </div>
        </div>

        <!-- 忘记密码表单 (默认隐藏) -->
        <div id="forgot-box" class="form-box hidden">
            <h2>找回密码</h2>
            <p class="help-text">请输入您注册时使用的邮箱，<br>我们将向您发送重置链接。</p>
            <form id="forgotForm">
                <input type="email" id="forgotEmail" placeholder="注册邮箱" required>
                <button type="submit">发送重置邮件</button>
            </form>
            <div class="links">
                <span onclick="switchBox('login-box')">记起密码了？返回登录</span>
            </div>
        </div>

    </div>

    <script>
        // 核心切换逻辑：隐藏所有表单，只显示目标表单
        function switchBox(boxId) {
            // 找到所有带有 form-box 类的 div，给它们添加 hidden 类
            document.querySelectorAll('.form-box').forEach(box => {
                box.classList.add('hidden');
            });
            // 移除目标 div 的 hidden 类，让它显示出来
            document.getElementById(boxId).classList.remove('hidden');
        }

        // 统一处理表单提交并发送给你的 Node.js 后端
        async function handleFormSubmit(e, endpoint, payload) {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = '处理中...';
            btn.disabled = true;

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const result = await response.json();
                if(result.success) {
                    // 如果是登录接口，成功后跳转
                    if (endpoint === '/api/login') {
                        window.location.href = '/'; // 跳转到主页
                    } else {
                        alert(result.message || '操作成功！');
                    }
                } else {
                    alert(result.message || '操作失败，请检查输入或重试');
                }
            } catch (error) {
                alert('网络或服务器错误，无法连接到后端！');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }

        // 绑定登录事件
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            const payload = {
                username: document.getElementById('loginUser').value,
                password: document.getElementById('loginPass').value
            };
            handleFormSubmit(e, '/api/login', payload);
        });

        // 绑定注册事件
        document.getElementById('registerForm').addEventListener('submit', (e) => {
            const payload = {
                username: document.getElementById('regUser').value,
                email: document.getElementById('regEmail').value,
                password: document.getElementById('regPass').value
            };
            handleFormSubmit(e, '/api/register', payload);
        });

        // 绑定忘记密码事件
        document.getElementById('forgotForm').addEventListener('submit', (e) => {
            const payload = {
                email: document.getElementById('forgotEmail').value
            };
            handleFormSubmit(e, '/api/forgot-password', payload);
        });
    </script>
</body>
</html>
