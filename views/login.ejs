<!DOCTYPE html>
<html lang="<%= typeof lng !== 'undefined' && lng === 'en' ? 'en' : 'zh-CN' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <title><%= title %></title>
    <script>window.__lang = '<%= typeof lng !== 'undefined' ? lng : "zh" %>';</script>
    <script src="/i18n.js"></script>
</head>
<body>
    <div class="auth-split">
        <!-- 左侧品牌区 -->
        <div class="auth-brand-panel">
            <div class="brand-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h1>红绣服饰<br>定制系统</h1>
            <p class="brand-sub">Hongxiu Custom System</p>
            <p class="brand-desc">专业泳装定制服务平台<br>从设计到生产的一站式解决方案</p>
        </div>
        <!-- 右侧登录区 -->
        <div class="auth-form-panel">
    <div class="auth-container">
        <div style="position: absolute; top: 15px; right: 20px;">
            <button onclick="setLanguage(window.__lang === 'en' ? 'zh' : 'en')" style="background: none; border: 1px solid #e0e0e0; border-radius: 20px; padding: 5px 14px; font-size: 12px; cursor: pointer; color: #64748b; transition: all 0.25s; display: inline-flex; align-items: center; gap: 5px; font-weight: 500; letter-spacing: 0.3px;" onmouseover="this.style.borderColor='#aa0000';this.style.color='#aa0000';this.querySelector('svg').style.stroke='#aa0000'" onmouseout="this.style.borderColor='#e0e0e0';this.style.color='#64748b';this.querySelector('svg').style.stroke='currentColor'">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: stroke 0.25s;"><path d="M5 8l6 0"/><path d="M4 12l7 0"/><path d="M8 8c0 2.5-1.5 5-4 6.5"/><path d="M6 8c0 1.5.8 3 2.5 4.5"/><path d="M14 12l3.5 8"/><path d="M14 12l-3.5 8"/><path d="M11.5 17h5"/></svg>
                <%= typeof lng !== 'undefined' && lng === 'en' ? '中文' : 'EN' %>
            </button>
        </div>
        <!-- 新增：消息提示区域 -->
        <div id="status-msg" class="status-msg hidden"></div>

        <!-- 登录表单 (默认显示) -->
        <div id="login-box" class="form-box">
            <h2>用户登录</h2>
            <form id="loginForm">
                <input type="text" id="loginUser" placeholder="用户名或邮箱" required>
                <!-- 登录表单中的密码框 -->
                <div class="password-wrapper">
                    <input type="password" id="loginPass" placeholder="密码" required>
                    <span class="toggle-password" onclick="togglePassword('loginPass', this)">
                        <!-- 初始显示闭眼图标 -->
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>
                <button type="submit">登 录</button>
            </form>
            <div class="links">
                <span onclick="switchBox('register-box')">没有账号？点击注册</span>
                <span onclick="switchBox('forgot-box')">忘记密码？</span>
            </div>
        </div>

        <!-- 注册表单 (默认隐藏) -->
        <div id="register-box" class="form-box hidden">
            <h2>创建账号</h2>
            <form id="registerForm">
                <input type="text" id="regUser" placeholder="设置用户名" required>
                <input type="email" id="regEmail" placeholder="常用邮箱" required>
                <!-- 注册表单中的密码框 -->
                <div class="password-wrapper">
                    <input type="password" id="regPass" placeholder="设置密码 (至少8位)" required minlength="8">
                    <span class="toggle-password" onclick="togglePassword('regPass', this)">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>
                <button type="submit">注 册</button>
            </form>
            <div class="links">
                <span onclick="switchBox('login-box')">已有账号？返回登录</span>
            </div>
        </div>

        <!-- 忘记密码表单 (默认隐藏) -->
        <div id="forgot-box" class="form-box hidden">
            <h2>找回密码</h2>
            <p class="help-text">请输入您注册时使用的邮箱，<br>我们将向您发送重置链接。</p>
            <form id="forgotForm">
                <input type="email" id="forgotEmail" placeholder="注册邮箱" required>
                <button type="submit">发送重置邮件</button>
            </form>
            <div class="links">
                <span onclick="switchBox('login-box')">记起密码了？返回登录</span>
            </div>
        </div>

    </div>
    </div>
    </div>

    <script>
        // 切换密码显示/隐藏
        function togglePassword(inputId, el) {
            const passwordInput = document.getElementById(inputId);
            
            // 睁眼图标的 SVG 路径
            const eyeOpen = `<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
            
            // 闭眼图标的 SVG 路径
            const eyeClose = `<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>`;
        
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                el.innerHTML = eyeOpen;
            } else {
                passwordInput.type = 'password';
                el.innerHTML = eyeClose;
            }
        }

        // 辅助函数：显示消息
        function showMessage(text, type = 'error') {
            const msgBox = document.getElementById('status-msg');
            msgBox.innerText = text;
            msgBox.classList.remove('hidden', 'status-error', 'status-success');
            
            // 根据类型添加对应的 CSS 类
            if (type === 'success') {
                msgBox.classList.add('status-success');
            } else {
                msgBox.classList.add('status-error');
            }
        }
        
        // 辅助函数：隐藏消息
        function hideMessage() {
            document.getElementById('status-msg').classList.add('hidden');
        }
        
        // 核心逻辑：切换表单时，顺便隐藏旧的消息
        function switchBox(boxId) {
            hideMessage();
            
            // 重置所有密码框为隐藏
            document.querySelectorAll('input[type="text"]').forEach(input => {
                if (input.id.includes('Pass')) { // 针对密码框
                    input.type = 'password';
                }
            });
            // 顺便把图标也重置回闭眼（可选，如果需要更严谨的话）
        
            document.querySelectorAll('.form-box').forEach(box => {
                box.classList.add('hidden');
            });
            document.getElementById(boxId).classList.remove('hidden');
        }

        // 修改后的统一提交函数
        async function handleFormSubmit(e, endpoint, payload) {
            e.preventDefault();
            hideMessage(); // 提交前清理旧提示
            
            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = '处理中...';
            btn.disabled = true;
        
            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const result = await response.json();
                
                if(result.success) {
                    // 如果是登录成功，直接跳转
                    if (endpoint === '/api/login') {
                        window.location.href = '/'; 
                    } else {
                        // 注册或重置邮件成功
                        showMessage(result.message || '操作成功！', 'success');
                    }
                } else {
                    // 失败：显示后端传回的错误（可能是频率限制，也可能是密码错误）
                    showMessage(result.message || '操作失败，请重试');
                }
            } catch (error) {
                showMessage('网络连接失败，请稍后再试');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }
        
        // 优化体验：当用户点击输入框开始输入时，自动隐藏错误提示
        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', hideMessage);
        });

        // 绑定登录事件
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            const payload = {
                username: document.getElementById('loginUser').value,
                password: document.getElementById('loginPass').value
            };
            handleFormSubmit(e, '/api/login', payload);
        });

        // 绑定注册事件
        document.getElementById('registerForm').addEventListener('submit', (e) => {
            const password = document.getElementById('regPass').value;
        
            // --- 新增：前端校验逻辑 ---
            if (password.length < 8) {
                // 使用我们之前写的 showMessage 函数（如果没有该函数，请用 alert）
                showMessage('密码长度至少需要 8 位', 'error');
                e.preventDefault(); // 阻止表单提交
                return;
            }
        
            const payload = {
                username: document.getElementById('regUser').value,
                email: document.getElementById('regEmail').value,
                password: password
            };
            handleFormSubmit(e, '/api/register', payload);
        });

        // 绑定忘记密码事件
        document.getElementById('forgotForm').addEventListener('submit', (e) => {
            const payload = {
                email: document.getElementById('forgotEmail').value
            };
            handleFormSubmit(e, '/api/forgot-password', payload);
        });
    </script>
</body>
</html>
