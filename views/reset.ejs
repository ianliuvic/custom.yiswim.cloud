<!DOCTYPE html>
<html lang="<%= typeof lng !== 'undefined' && lng === 'en' ? 'en' : 'zh-CN' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title><%= title %></title>
    <script>window.__lang = '<%= typeof lng !== 'undefined' ? lng : "zh" %>';</script>
    <script src="/i18n.js"></script>
</head>
<body>
    <div class="auth-container">
        <div style="position: absolute; top: 15px; right: 20px;">
            <button onclick="setLanguage(window.__lang === 'en' ? 'zh' : 'en')" style="background: none; border: 1px solid #e0e0e0; border-radius: 6px; padding: 4px 10px; font-size: 12px; cursor: pointer; color: #64748b;">🌐 <%= typeof lng !== 'undefined' && lng === 'en' ? '中文' : 'EN' %></button>
        </div>
        
        <div id="status-msg" class="status-msg hidden"></div>

        <div class="form-box">
            <h2>设置新密码</h2>
            <p class="help-text">请输入您的新密码并确认。<br>密码长度建议不少于 8 位。</p>
            
            <form id="resetForm">
                <div class="password-wrapper">
                    <input type="password" id="newPass" placeholder="新密码" required minlength="8">
                    <span class="toggle-password" onclick="togglePassword('newPass', this)">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>

                <div class="password-wrapper">
                    <input type="password" id="confirmPass" placeholder="确认新密码" required minlength="8">
                    <span class="toggle-password" onclick="togglePassword('confirmPass', this)">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                    </span>
                </div>

                <button type="submit">确认修改</button>
            </form>
            
            <div class="links">
                <a href="/login" style="text-decoration: none;"><span>返回登录</span></a>
            </div>
        </div>
    </div>

    <script>
        // 从 EJS 模板中获取 Node.js 传过来的 token
        const resetToken = '<%= token %>';

        // 消息提示函数
        function showMessage(text, type = 'error') {
            const msgBox = document.getElementById('status-msg');
            msgBox.innerText = text;
            msgBox.classList.remove('hidden', 'status-error', 'status-success');
            msgBox.classList.add(type === 'success' ? 'status-success' : 'status-error');
        }

        function hideMessage() {
            document.getElementById('status-msg').classList.add('hidden');
        }

        // 小眼睛切换逻辑
        function togglePassword(inputId, el) {
            const passwordInput = document.getElementById(inputId);
            const eyeOpen = `<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
            const eyeClose = `<svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>`;

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                el.innerHTML = eyeOpen;
            } else {
                passwordInput.type = 'password';
                el.innerHTML = eyeClose;
            }
        }

        // 绑定输入框，输入时隐藏错误信息
        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', hideMessage);
        });

        // 表单提交事件
        document.getElementById('resetForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideMessage();

            const newPass = document.getElementById('newPass').value;
            const confirmPass = document.getElementById('confirmPass').value;

            // 1. 前端校验两次密码是否一致
            if (newPass !== confirmPass) {
                showMessage('两次输入的密码不一致！');
                return;
            }

            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = '处理中...';
            btn.disabled = true;

            try {
                // 2. 发送请求给 Node.js 后端
                const response = await fetch('/api/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        token: resetToken, // 携带 URL 中的 token
                        newPassword: newPass // 携带新密码明文
                    })
                });
                
                const result = await response.json();
                
                if(result.success) {
                    showMessage('密码重置成功！即将跳转到登录页...', 'success');
                    // 3秒后自动跳转回登录页
                    setTimeout(() => {
                        window.location.href = '/login';
                    }, 3000);
                } else {
                    showMessage(result.message || '操作失败，请检查链接是否过期');
                }
            } catch (error) {
                showMessage('网络连接失败，请稍后再试');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
